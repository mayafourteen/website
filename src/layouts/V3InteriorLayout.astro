---
// Shared shell for every V3 menu destination (About, Video Sets, Audio
// Sets, Press, Book Maya). One layout so each page only supplies its own
// content — keeps the five pages visually consistent by construction
// rather than by copy-pasted CSS.
import BaseLayout from './BaseLayout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import HamburgerMenu from '../components/HamburgerMenu.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow: string;
}

const { title, description, eyebrow } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass="page-v3-interior" lang="en">
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/maya-landing-bw.jpg" alt="Maya Fourteen" filtered />
  </div>

  <HamburgerMenu />

  <div class="content-wrapper">
    <p class="eyebrow fade-item">{eyebrow}</p>
    <h1 class="page-title fade-item">{title}</h1>
    <div class="page-body fade-item">
      <slot />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 2.2s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(15px); transform: translateY(30px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-v3-interior) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  .background-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .content-wrapper {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding: 140px 10% 100px;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 16px 0;
    animation-delay: 0.2s;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 40px 0;
    animation-delay: 0.4s;
  }

  .page-body {
    animation-delay: 0.7s;
    text-align: left;
  }

  .page-body :global(p) {
    font-weight: 200;
    line-height: 1.8;
    letter-spacing: 0.04em;
    font-size: clamp(1rem, 1.15vw, 1.2rem);
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 24px 0;
  }

  .page-body :global(.section-title) {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin: 40px 0 20px 0;
  }

  .page-body :global(.link-list) {
    list-style: none;
    margin: 0 0 24px 0;
    padding: 0;
  }

  .page-body :global(.link-list li) {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .page-body :global(.link-list li:last-child) {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .page-body :global(.link-list strong) {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    color: #fff;
    margin-bottom: 6px;
  }

  .page-body :global(.link-list a) {
    display: inline-block;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.78rem;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .page-body :global(.link-list a:hover) {
    color: #fff;
    transform: translateY(-2px);
  }

  .page-body :global(.cta-button) {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.9rem;
    text-decoration: none;
    color: #000;
    background: #fff;
    padding: 16px 36px;
    margin-top: 12px;
    transition: opacity 0.3s ease;
  }

  .page-body :global(.cta-button:hover) {
    opacity: 0.85;
  }

  .page-body :global(.embed-frame) {
    width: 100%;
    border: none;
    display: block;
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .content-wrapper {
      padding: 110px 8% 70px;
    }
  }
</style>
