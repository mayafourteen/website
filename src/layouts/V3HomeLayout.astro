---
// V3 homepage shell — cinematic entrance, not the About page. Content is
// deliberately minimal: hero, title, tagline, hamburger nav, social icons.
// See PROJECT.md v2 milestone notes for the "homepage as entrance, not
// biography" rationale.
import V3BaseLayout from './V3BaseLayout.astro';
import HeroBackground from '../components/v3/HeroBackground.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import SocialNav from '../components/v3/SocialNav.astro';
import { primarySocialLinks } from '../data/v3/primarySocialLinks.js';
import { images } from '../data/v3/images.js';

const fontsHref = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400&display=swap';

interface Props {
  title: string;
  description?: string;
  lang: string;
  epkHref?: string;
}

const { title, description, lang, epkHref } = Astro.props;

// "[ enter ]" hero CTA — opens the same nav menu as the hamburger icon
// (see the forwarding script below), not a navigation link.
const enterLabelByLang: Record<string, string> = { en: 'enter', pt: 'entrar', es: 'entrar' };
const enterLabel = enterLabelByLang[lang] ?? 'enter';

// All 3 homepages are genuine translations of each other (unlike interior
// pages, which stay EN/PT only) — real hreflang alternates, not a fallback.
const homeHreflangAlternates = { en: '/en', pt: '/pt', es: '/es' };
---

<V3BaseLayout
  title={title}
  description={description}
  bodyClass="page-v2-home"
  lang={lang}
  hreflangAlternates={homeHreflangAlternates}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <!-- Preload the two render-blocking resources that actually gate this
         page's LCP: the hero background photo (see HeroBackground.astro —
         it already renders eager + fetchpriority="high", this just lets
         the browser discover it from the raw HTML instead of waiting on
         CSS/JS to insert the <img>) and the font stylesheet (an external
         CSS request the browser wouldn't otherwise prioritize this early,
         which otherwise delays first paint of "MAYA FOURTEEN" in its real
         typeface). imagesrcset/imagesizes mirror HeroBackground's own
         srcset/sizes so the preload can't fetch a different candidate
         than the one actually rendered. -->
    <link
      rel="preload"
      as="image"
      href={images.heroLandingColor.src}
      imagesrcset={images.heroLandingColor.webpSrcset}
      imagesizes="100vw"
      type="image/webp"
      fetchpriority="high"
    />
    <link rel="preload" as="style" href={fontsHref} />
    <!-- media="print" + onload swap keeps this off the render-blocking path
         (the preload above was only ever a priority hint, not a guarantee
         the stylesheet itself wouldn't still block first paint) — same
         final CSS applies once loaded, so nothing renders differently,
         it just doesn't hold up the initial paint waiting for it.
         noscript fallback covers the no-JS case. -->
    <link href={fontsHref} rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href={fontsHref} rel="stylesheet"></noscript>
    <!-- Only the brand icons SocialNav actually renders (YouTube, SoundCloud,
         Instagram) are used from Font Awesome — the full all.min.css bundle
         was ~99% unused CSS on this page, so load just the core + brands.
         Same preload/media=print swap as the fonts CSS above: still ~99KB
         either way, but no longer blocks first paint getting there. -->
    <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css"></noscript>
    <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css"></noscript>
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/maya-landing-color.webp" alt="Maya Fourteen" />
  </div>

  <div class="scrim" aria-hidden="true"></div>

  <HamburgerMenu lang={lang} />

  <div class="content-wrapper">
    <div class="title-group">
      <h1 class="logo-text fade-item">Maya <br class="logo-break" />Fourteen</h1>
      <div class="slogan fade-item">'I build sets that grow on you'</div>
      <button
        type="button"
        class="hero-cta hero-cta-enter"
        id="hero-enter-cta"
        aria-label="Open menu"
        aria-controls="hamburger-overlay"
      ><span class="hero-cta-bracket hero-cta-bracket-open">[</span> <span class="hero-cta-letters">{enterLabel.split('').map((ch, i) => (
          <span class="hero-cta-letter" style={`--i: ${i}`}>{ch}</span>
        ))}</span> <span class="hero-cta-bracket hero-cta-bracket-close">]</span></button>
    </div>

    <SocialNav links={primarySocialLinks} epkHref={epkHref} />
  </div>
</V3BaseLayout>

<script>
  // "[ enter ]" opens the exact same nav overlay as the hamburger icon —
  // forwards a real click to the hamburger's own button so its existing
  // handler (open/close state, focus, escape-to-close, aria-expanded) is
  // the single source of truth. Not a reimplementation: if that handler
  // changes, this stays in sync automatically.
  document.getElementById('hero-enter-cta')?.addEventListener('click', () => {
    document.getElementById('hamburger-trigger')?.click();
  });

  // Preview-only toggle between the two attention-effect candidates on
  // [enter]: default is the breathing-opacity pulse (CSS-only, always
  // on); ?fx=letter swaps it for the sequential letter-dimming wave
  // instead, so both can be compared live before picking one for good.
  if (new URLSearchParams(window.location.search).get('fx') === 'letter') {
    document.getElementById('hero-enter-cta')?.classList.add('fx-letter');
  }
</script>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-v2-home) {
    /* Single source of truth for the header chrome's edge offset — both
       HamburgerMenu (top-right) and LanguageMenu (top-left) read this
       instead of hardcoding their own numbers, so they can't drift out
       of sync again. */
    --v3-header-inset: 20px;
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* Icons are the credibility signals — with a ~30-second attention budget,
     the full reveal sequence should be finished well under 2s, not the
     production trio's more leisurely ~3.7s. Overriding SocialNav's own
     delay from outside keeps that shared component untouched for the
     pages that already rely on its current timing. */
  .content-wrapper :global(.nav-links) {
    animation-delay: 0.55s;
  }

  /* Balance the language selector against the hamburger icon's visual
     weight — scoped to the V3 homepage only, LanguageMenu's own default
     styling (used by every other page) is untouched.

     Optical alignment: measured via Range.getBoundingClientRect on this
     trigger's text node vs. getBoundingClientRect on .hamburger-line
     (HamburgerMenu.astro), across every /v3/ page (home, interior, EPK)
     and both desktop/mobile viewports. With the symmetric 14px this rule
     used to set on both sides, the label's ink started a flat 34px from
     the left viewport edge while the hamburger lines' ink ended 30px from
     the right edge — a 4px gap from the "E"/"P"/"S" glyphs' own
     left-side bearing sitting outside the padding box (the hamburger's
     lines are drawn rectangles with no such bearing, so their ink matches
     their layout box exactly). Trimming padding-left by that measured 4px
     (14px -> 10px) brings both ink distances to 30px, equal to the pixel,
     identically on every page and both viewports. Right padding (caret
     spacing) and the hamburger are untouched. This same fix is mirrored
     in V3InteriorLayout.astro and the three epk*.astro pages, which each
     have their own copy of this rule. */
  :global(.page-v2-home) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Desktop only: independently positions the name+slogan block near the
     viewport's optical center (~46vh) without moving the icon row. Under
     the flex-end-anchored .content-wrapper below, adding margin/padding
     above a flex-flow title-group does NOT shift it — the bottom-anchored
     stack's positions are computed backward from the last item, so
     leading space just eats into existing blank space instead of moving
     anything (confirmed by measuring rendered position before/after a
     margin-based attempt). Taking title-group out of that flow entirely
     via position:absolute sidesteps it: SocialNav becomes the sole flex
     child of .content-wrapper, still pinned to the bottom exactly as
     before. --name-half-line mirrors .logo-text's own font-size clamp
     scaled by (line-height / 2), so translateY cancels out exactly half
     the name's own rendered height regardless of viewport width — landing
     the name's true vertical center (not the group's) at `top`, with the
     slogan and CTA flowing below it at their own unchanged spacing. Reset
     to a normal flow item for mobile/tablet-portrait, which use their own
     space-between composition instead. */
  .title-group {
    --name-half-line: clamp(1.84rem, 4.6vw, 3.335rem);
    position: absolute;
    top: 46vh;
    left: 50%;
    transform: translate(-50%, calc(-1 * var(--name-half-line)));
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Absolutely-positioned flex containers don't reliably shrink-to-fit
       their content's natural width (measured ~720px here — exactly half
       the 1440px viewport — instead of "MAYA FOURTEEN"'s true ~1000px
       single-line width), which wrapped the name onto two lines on
       desktop. width:max-content forces sizing from content instead. */
    width: max-content;
    max-width: 90vw;
  }

  .background-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
  }

  /* Composes the text against the lower third of the frame rather than
     dead-center — keeps the title/tagline off the subject's face and
     gives the page a deliberate, cinematic bottom-weighted read instead
     of sitting flush on top of the busiest part of the photo. */
  .scrim {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(0, 0, 0, 0.45) 70%,
      rgba(0, 0, 0, 0.68) 100%
    );
    pointer-events: none;
  }

  /* height (not min-height) + border-box is deliberate: Chrome has a real
     flexbox bug where min-height combined with justify-content and
     padding on a column flex container mis-resolves the free space to
     distribute, silently pushing later items far below the viewport
     (confirmed by isolating the exact CSS in a minimal standalone test —
     it reproduced with plain colored boxes, no fonts or Astro involved).
     A definite `height` avoids that code path entirely. 100vh declared
     first as a fallback for browsers without dvh support; 100dvh (mobile
     Chrome/Safari's dynamic viewport height) overrides it where
     supported, so the icon row's bottom padding tracks the real visible
     viewport instead of the tallest possible one (URL bar collapsed) —
     otherwise the row sits clipped until the user scrolls. Bottom padding
     also adds the iOS home-indicator safe area so the icon row never
     sits flush against it. */
  .content-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100vh;
    height: 100dvh;
    box-sizing: border-box;
    text-align: center;
    padding: 100px 10% calc(9vh + env(safe-area-inset-bottom, 0px));
  }

  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 5.8rem);
    line-height: 1.15;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 8px 0;
    animation-delay: 0.15s;
  }

  /* Hidden on desktop, where "Maya Fourteen" reads as one line. Shown
     (as a real line break) only in the mobile query below, where it
     replaces relying on the browser to wrap at the word space — natural
     wrapping put "Fourteen" alone on its own line already, but its
     trailing letter-spacing still overflowed past the padded edge on a
     390px phone (see that rule for the actual size fix). */
  .logo-break {
    display: none;
  }

  .slogan {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-style: italic;
    letter-spacing: 0.15em;
    font-weight: 300;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.85);
    animation-delay: 0.32s;
  }

  /* Quiet aside, not a button (functionally it's one — see the forwarding
     script above — but should never read as one): the name's own display
     serif, not the slogan's italic voice, so it reads as a soft
     typographic echo of "MAYA FOURTEEN" rather than a continuation of the
     tagline. Lowercase and only slightly tracked (vs. the name's heavy
     0.22em uppercase spacing) keeps it hushed. Real <button> means native
     focus/keyboard behavior — no custom handling needed to match the
     hamburger's. */
  .hero-cta {
    display: inline-block;
    margin-bottom: 46px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: 'Cormorant Garamond', serif;
    font-style: normal;
    font-weight: 300;
    /* Equal to .slogan's own clamp — same "size" in the literal sense of
       matching that line's font-size exactly, not derived from the old
       hero-cta value. */
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    /* Muted desert gold, tuned against the hero photo's own sand/sunset
       tones rather than staying white like the rest of the page's text —
       .slogan is deliberately untouched. */
    color: #d9a96a;
    text-decoration: none;
    transition: color 0.3s ease, letter-spacing 0.3s ease;
  }

  .hero-cta:hover,
  .hero-cta:focus-visible,
  .hero-cta:active {
    color: #fff;
  }

  /* [enter]/[entrar] only: reuses the exact same reveal as .title-group's
     .fade-item elements (smoothReveal — opacity+blur+translateY, same
     cubic-bezier), not a custom fade, so it genuinely reads as "the same
     entrance style" rather than a look-alike. Timed off .slogan, the
     last .fade-item to finish (0.32s delay + 1.1s duration = 1.42s):
     starts ~0.5s after that (1.9s) and runs at half speed — 2x the
     title/slogan's 1.1s, so 2.2s — finishing at 4.1s. The breathing pulse
     is delayed to start at that exact same 4.1s mark, so it only ever
     picks up once the fade-in has fully landed; nothing here is ever
     abrupt. (Can't just add .fade-item to this element instead of
     duplicating its keyframe/easing — .hero-cta-enter's own `animation`
     shorthand would silently override it anyway, since two classes both
     setting `animation` on one element never combine, only the
     later-cascading one applies.) */
  .hero-cta-enter {
    opacity: 0;
    animation:
      smoothReveal 2.2s cubic-bezier(0.19, 1, 0.22, 1) 1.9s forwards,
      heroCtaBreathe 3s ease-in-out 4.1s infinite;
  }

  @keyframes heroCtaBreathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .hero-cta-enter:hover,
  .hero-cta-enter:focus-visible,
  .hero-cta-enter:active {
    letter-spacing: 0.09em;
  }

  /* Preview-only alternative to the breathing pulse above (see the
     ?fx=letter toggle in the script below): each letter dims in sequence
     instead of the whole word pulsing as one unit. Still fades/blurs in
     first via the same smoothReveal — just without the breathing pulse
     layered after it, since the individual letters take over the ongoing
     motion instead. */
  .hero-cta-enter.fx-letter {
    animation: smoothReveal 2.2s cubic-bezier(0.19, 1, 0.22, 1) 1.9s forwards;
  }

  .hero-cta-letter {
    display: inline-block;
    animation: heroCtaLetterWave 2.4s ease-in-out 4.1s infinite;
    animation-play-state: paused;
  }

  .hero-cta-enter.fx-letter .hero-cta-letter {
    animation-play-state: running;
    animation-delay: calc(4.1s + var(--i) * 0.1s);
  }

  @keyframes heroCtaLetterWave {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  /* Brackets at full glyph size dwarfed the lowercase word and read as a
     frame around it rather than a hug. Shrinking to ~72% and nudging up
     with vertical-align (glyphs default-align to the baseline, which for
     a bracket sits well below the lowercase x-height's optical center)
     brings them level with the word instead of hanging above/below it.
     Spacing from the word is a real space character in the markup now
     (not the em-based margin this rule used before) — renders as literal
     "[ enter ]"/"[ entrar ]", including for copy/paste and screen readers.
     Color inherits from .hero-cta so hover/focus/active brightens both
     identically. */
  .hero-cta-bracket {
    display: inline-block;
    font-size: 0.72em;
    vertical-align: 0.09em;
  }

  /* Mobile-only vertical composition. justify-content:space-between with
     exactly two flex items (title-group, icon row) gives a hard guarantee
     against overflow: the title-group's top edge is pinned by padding-top
     and the icon row's bottom edge is pinned by padding-bottom, whatever
     free space is left goes into the single gap between them. Tuning the
     padding values directly controls where the title sits (~torso height)
     and keeps the icon row anchored at the bottom, always visible without
     scrolling — this doesn't depend on guessing exact font metrics the
     way splitting space across two independent auto-margins did. Desktop's
     lower-third composition is untouched — .title-group is
     `display:contents` there, so it isn't a flex item at all. */
  @media (max-width: 768px) {
    .content-wrapper {
      justify-content: space-between;
      padding: 36vh 8% calc(6vh + env(safe-area-inset-bottom, 0px));
    }

    .logo-break {
      display: block;
    }

    /* The desktop clamp's 3.2rem floor plus 0.22em letter-spacing made
       "FOURTEEN" — now guaranteed its own line by .logo-break above —
       wider than the padded content area on a 390px phone, overflowing
       past the right edge. Trimming both brings it back inside with
       margin to spare (verified via getClientRects, not just visually),
       without touching the desktop values. */
    .logo-text {
      font-size: clamp(2.8rem, 8vw, 5.8rem);
      letter-spacing: 0.12em;
    }

    /* Cancels the desktop absolute-positioning treatment above — back to
       a normal in-flow block so space-between (not the optical-center
       math) governs where the whole title+slogan+CTA group sits. */
    .title-group {
      position: static;
      transform: none;
      display: block;
      flex-shrink: 0;
      width: auto;
      max-width: none;
    }

    .content-wrapper :global(.nav-links) {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    /* No font-size override here (unlike this rule's earlier version) —
       the base clamp's 1.1rem floor already applies at this width and
       must stay identical to .slogan's own floor, not a separate mobile
       value. Padding expands the actual hit area to a 44px-tall box
       without shifting surrounding layout: matching negative margins on
       top/left/right cancel the padding's own space, and margin-bottom
       drops by the same amount added as padding-bottom so the gap to the
       icon row below is unchanged from the pre-padding 46px. */
    .hero-cta {
      padding: 14px 10px;
      margin-top: -14px;
      margin-right: -10px;
      margin-bottom: 32px;
      margin-left: -10px;
    }
  }

  /* Tablets in portrait (iPad-class widths, e.g. 768-1024px) fall outside
     the phone breakpoint above but are too narrow/tall-aspect for the
     desktop optical-center composition to read well — same reasoning as
     the mobile block, just at a wider min-width. Reuses only the
     positioning mechanics (space-between + block title-group), not the
     phone-specific font-size/letter-spacing/line-break fixes, since
     those exist purely for 390px-wide overflow and don't apply here. */
  @media (min-width: 769px) and (max-width: 1024px) and (orientation: portrait) {
    .content-wrapper {
      justify-content: space-between;
      padding: 36vh 8% calc(6vh + env(safe-area-inset-bottom, 0px));
    }

    .title-group {
      position: static;
      transform: none;
      display: block;
      flex-shrink: 0;
      width: auto;
      max-width: none;
    }

    .content-wrapper :global(.nav-links) {
      margin-bottom: 0;
      flex-shrink: 0;
    }
  }
</style>
