---
// V3 homepage shell — cinematic entrance, not the About page. Content is
// deliberately minimal: hero, title, tagline, hamburger nav, social icons.
// See PROJECT.md v2 milestone notes for the "homepage as entrance, not
// biography" rationale.
import V3BaseLayout from './V3BaseLayout.astro';
import HeroBackground from '../components/v3/HeroBackground.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import { images } from '../data/v3/images.js';

const fontsHref = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400&display=swap';

interface Props {
  title: string;
  description?: string;
  lang: string;
  epkHref?: string;
}

const { title, description, lang, epkHref } = Astro.props;

// "[ enter ]" hero CTA — opens the same nav menu as the hamburger icon
// (see the forwarding script below), not a navigation link.
const enterLabelByLang: Record<string, string> = { en: 'enter', pt: 'entrar', es: 'entrar' };
const enterLabel = enterLabelByLang[lang] ?? 'enter';

// All 3 homepages are genuine translations of each other (unlike interior
// pages, which stay EN/PT only) — real hreflang alternates, not a fallback.
const homeHreflangAlternates = { en: '/page-en', pt: '/page-pt', es: '/page-es' };
---

<V3BaseLayout
  title={title}
  description={description}
  bodyClass="page-v2-home"
  lang={lang}
  hreflangAlternates={homeHreflangAlternates}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <!-- Preload the two render-blocking resources that actually gate this
         page's LCP: the hero background photo (see HeroBackground.astro —
         it already renders eager + fetchpriority="high", this just lets
         the browser discover it from the raw HTML instead of waiting on
         CSS/JS to insert the <img>) and the font stylesheet (an external
         CSS request the browser wouldn't otherwise prioritize this early,
         which otherwise delays first paint of "MAYA FOURTEEN" in its real
         typeface). imagesrcset/imagesizes mirror HeroBackground's own
         srcset/sizes so the preload can't fetch a different candidate
         than the one actually rendered. -->
    <link
      rel="preload"
      as="image"
      href={images.heroDefault.src}
      imagesrcset={images.heroDefault.srcset}
      imagesizes="100vw"
      fetchpriority="high"
    />
    <link rel="preload" as="style" href={fontsHref} />
    <link href={fontsHref} rel="stylesheet">
    <!-- Only the brand icons HamburgerMenu's social row renders (YouTube,
         SoundCloud, Instagram) are used from Font Awesome — the full
         all.min.css bundle was ~99% unused CSS on this page, so load just
         the core + brands. -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/maya-landing-color.webp" alt="Maya Fourteen" />
  </div>

  <div class="scrim" aria-hidden="true"></div>

  <HamburgerMenu lang={lang} />

  <div class="content-wrapper">
    <div class="title-group">
      <h1 class="logo-text fade-item">Maya <br class="logo-break" />Fourteen</h1>
      <div class="slogan fade-item">'I build sets that grow on you'</div>

      <div class="landing-cta-row fade-item">
        <button
          type="button"
          class="hero-cta"
          id="hero-enter-cta"
          aria-label="Open menu"
          aria-controls="hamburger-overlay"
        ><span class="hero-cta-bracket hero-cta-bracket-open">[</span>{enterLabel}<span class="hero-cta-bracket hero-cta-bracket-close">]</span></button>
        <a href={epkHref ?? '/epk'} class="hero-cta hero-cta-epk"><span class="hero-cta-bracket hero-cta-bracket-open">[</span>EPK<span class="hero-cta-bracket hero-cta-bracket-close">]</span></a>
      </div>
    </div>
  </div>
</V3BaseLayout>

<script>
  // "[ enter ]" opens the exact same nav overlay as the hamburger icon —
  // forwards a real click to the hamburger's own button so its existing
  // handler (open/close state, focus, escape-to-close, aria-expanded) is
  // the single source of truth. Not a reimplementation: if that handler
  // changes, this stays in sync automatically.
  document.getElementById('hero-enter-cta')?.addEventListener('click', () => {
    document.getElementById('hamburger-trigger')?.click();
  });
</script>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-v2-home) {
    /* Single source of truth for the header chrome's edge offset — both
       HamburgerMenu (top-right) and LanguageMenu (top-left) read this
       instead of hardcoding their own numbers, so they can't drift out
       of sync again. */
    --v3-header-inset: 20px;
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* The enter/EPK pair, living inside .title-group directly below the
     slogan (not pinned to the viewport bottom like the old icon row it
     replaced) — reveals right after the slogan (0.15s/0.32s), just
     slightly behind it. */
  .landing-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 48px;
    animation-delay: 0.4s;
  }

  /* Balance the language selector against the hamburger icon's visual
     weight — scoped to the V3 homepage only, LanguageMenu's own default
     styling (used by every other page) is untouched.

     Optical alignment: measured via Range.getBoundingClientRect on this
     trigger's text node vs. getBoundingClientRect on .hamburger-line
     (HamburgerMenu.astro), across every /v3/ page (home, interior, EPK)
     and both desktop/mobile viewports. With the symmetric 14px this rule
     used to set on both sides, the label's ink started a flat 34px from
     the left viewport edge while the hamburger lines' ink ended 30px from
     the right edge — a 4px gap from the "E"/"P"/"S" glyphs' own
     left-side bearing sitting outside the padding box (the hamburger's
     lines are drawn rectangles with no such bearing, so their ink matches
     their layout box exactly). Trimming padding-left by that measured 4px
     (14px -> 10px) brings both ink distances to 30px, equal to the pixel,
     identically on every page and both viewports. Right padding (caret
     spacing) and the hamburger are untouched. This same fix is mirrored
     in V3InteriorLayout.astro and the three epk*.astro pages, which each
     have their own copy of this rule. */
  :global(.page-v2-home) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Desktop only: independently positions the name+slogan block near the
     viewport's optical center (~46vh) without moving the CTA row below it.
     Under the flex-end-anchored .content-wrapper below, adding margin/
     padding above a flex-flow title-group does NOT shift it — the
     bottom-anchored stack's positions are computed backward from the last
     item, so leading space just eats into existing blank space instead of
     moving anything (confirmed by measuring rendered position before/after
     a margin-based attempt). Taking title-group out of that flow entirely
     via position:absolute sidesteps it: .landing-cta-row becomes the sole
     flex child of .content-wrapper, still pinned to the bottom exactly as
     before. --name-half-line mirrors .logo-text's own font-size clamp
     scaled by (line-height / 2), so translateY cancels out exactly half
     the name's own rendered height regardless of viewport width — landing
     the name's true vertical center (not the group's) at `top`, with the
     slogan and CTA flowing below it at their own unchanged spacing. Reset
     to a normal flow item for mobile/tablet-portrait, which use their own
     space-between composition instead. */
  .title-group {
    --name-half-line: clamp(1.84rem, 4.6vw, 3.335rem);
    position: absolute;
    top: 46vh;
    left: 50%;
    transform: translate(-50%, calc(-1 * var(--name-half-line)));
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Absolutely-positioned flex containers don't reliably shrink-to-fit
       their content's natural width (measured ~720px here — exactly half
       the 1440px viewport — instead of "MAYA FOURTEEN"'s true ~1000px
       single-line width), which wrapped the name onto two lines on
       desktop. width:max-content forces sizing from content instead. */
    width: max-content;
    max-width: 90vw;
  }

  .background-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
  }

  /* Composes the text against the lower third of the frame rather than
     dead-center — keeps the title/tagline off the subject's face and
     gives the page a deliberate, cinematic bottom-weighted read instead
     of sitting flush on top of the busiest part of the photo. */
  .scrim {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(0, 0, 0, 0.45) 70%,
      rgba(0, 0, 0, 0.68) 100%
    );
    pointer-events: none;
  }

  /* height (not min-height) + border-box is deliberate: Chrome has a real
     flexbox bug where min-height combined with justify-content and
     padding on a column flex container mis-resolves the free space to
     distribute, silently pushing later items far below the viewport
     (confirmed by isolating the exact CSS in a minimal standalone test —
     it reproduced with plain colored boxes, no fonts or Astro involved).
     A definite `height` avoids that code path entirely. 100vh declared
     first as a fallback for browsers without dvh support; 100dvh (mobile
     Chrome/Safari's dynamic viewport height) overrides it where
     supported, so the icon row's bottom padding tracks the real visible
     viewport instead of the tallest possible one (URL bar collapsed) —
     otherwise the row sits clipped until the user scrolls. Bottom padding
     also adds the iOS home-indicator safe area so the icon row never
     sits flush against it. */
  .content-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100vh;
    height: 100dvh;
    box-sizing: border-box;
    text-align: center;
    padding: 100px 10% calc(9vh + env(safe-area-inset-bottom, 0px));
  }

  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 5.8rem);
    line-height: 1.15;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 8px 0;
    animation-delay: 0.15s;
  }

  /* Hidden on desktop, where "Maya Fourteen" reads as one line. Shown
     (as a real line break) only in the mobile query below, where it
     replaces relying on the browser to wrap at the word space — natural
     wrapping put "Fourteen" alone on its own line already, but its
     trailing letter-spacing still overflowed past the padded edge on a
     390px phone (see that rule for the actual size fix). */
  .logo-break {
    display: none;
  }

  .slogan {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-style: italic;
    letter-spacing: 0.15em;
    font-weight: 300;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.85);
    animation-delay: 0.32s;
  }

  /* Quiet aside, not a prominent button (the enter control is functionally
     one — see the forwarding script above — but should never read as one):
     the name's own display serif, not the slogan's italic voice, so it
     reads as a soft typographic echo of "MAYA FOURTEEN" rather than a
     continuation of the tagline. Lowercase and only slightly tracked (vs.
     the name's heavy 0.22em uppercase spacing) keeps it hushed. Shared by
     both the enter <button> and the EPK <a> so they read as one pair —
     real <button>/<a> elements mean native focus/keyboard behavior, no
     custom handling needed to match the hamburger's. */
  .hero-cta {
    display: inline-block;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: 'Cormorant Garamond', serif;
    font-style: normal;
    font-weight: 300;
    /* Matches .slogan's own clamp exactly — "slogan-size", since this pair
       now lives directly below it as part of the same title block. */
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    color: rgba(255, 255, 255, 0.58);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .hero-cta:hover,
  .hero-cta:focus-visible,
  .hero-cta:active {
    color: #fff;
  }

  /* EPK reads as the secondary of the pair — dimmer at rest and on hover,
     never brighter than enter's own states. */
  .hero-cta-epk {
    color: rgba(255, 255, 255, 0.45);
  }

  .hero-cta-epk:hover,
  .hero-cta-epk:focus-visible,
  .hero-cta-epk:active {
    color: rgba(255, 255, 255, 0.82);
  }

  /* Brackets at full glyph size dwarfed the lowercase word and read as a
     frame around it rather than a hug. Shrinking to ~72% and nudging up
     with vertical-align (glyphs default-align to the baseline, which for
     a bracket sits well below the lowercase x-height's optical center)
     brings them level with the word instead of hanging above/below it.
     Tight explicit margins (not a Unicode thin/hair space in the text
     itself, which varies by font) give consistent ~0.15em gaps. Color
     inherits from .hero-cta so hover/focus/active brightens both
     identically. */
  .hero-cta-bracket {
    display: inline-block;
    font-size: 0.72em;
    vertical-align: 0.09em;
  }

  .hero-cta-bracket-open {
    margin-right: 0.15em;
  }

  .hero-cta-bracket-close {
    margin-left: 0.15em;
  }

  /* Mobile-only vertical composition. .landing-cta-row now lives inside
     .title-group (see markup — it's the block right below .slogan), so
     .content-wrapper only ever has that one flow child on mobile;
     justify-content:center simply centers the whole title+slogan+CTA
     cluster as a unit, top-to-bottom padding giving it room either side.
     Desktop's lower-third composition is untouched — .title-group is
     `position:absolute` there, so it isn't a flex item at all. */
  @media (max-width: 768px) {
    .content-wrapper {
      justify-content: center;
      padding: 36vh 8% calc(6vh + env(safe-area-inset-bottom, 0px));
    }

    .logo-break {
      display: block;
    }

    /* The desktop clamp's 3.2rem floor plus 0.22em letter-spacing made
       "FOURTEEN" — now guaranteed its own line by .logo-break above —
       wider than the padded content area on a 390px phone, overflowing
       past the right edge. Trimming both brings it back inside with
       margin to spare (verified via getClientRects, not just visually),
       without touching the desktop values. */
    .logo-text {
      font-size: clamp(2.8rem, 8vw, 5.8rem);
      letter-spacing: 0.12em;
    }

    /* Cancels the desktop absolute-positioning treatment above — back to
       a normal in-flow block, its children (name, slogan, CTA row) simply
       stacking in document order. */
    .title-group {
      position: static;
      transform: none;
      display: block;
      flex-shrink: 0;
      width: auto;
      max-width: none;
    }

    /* Tighter gap between enter/EPK than desktop's 48px — the pair reads
       as one unit at this width. Padding expands each item's own tap
       target to a 44px-tall box without needing a font-size bump: the
       base clamp already floors at 1.1rem here (2.2vw of a 390px
       viewport is well under that floor). */
    .landing-cta-row {
      gap: 28px;
    }

    .hero-cta {
      padding: 14px 10px;
    }
  }

  /* Tablets in portrait (iPad-class widths, e.g. 768-1024px) fall outside
     the phone breakpoint above but are too narrow/tall-aspect for the
     desktop optical-center composition to read well — same reasoning as
     the mobile block, just at a wider min-width. Reuses only the
     positioning mechanics (center + block title-group), not the
     phone-specific font-size/letter-spacing/line-break fixes, since
     those exist purely for 390px-wide overflow and don't apply here. */
  @media (min-width: 769px) and (max-width: 1024px) and (orientation: portrait) {
    .content-wrapper {
      justify-content: center;
      padding: 36vh 8% calc(6vh + env(safe-area-inset-bottom, 0px));
    }

    .title-group {
      position: static;
      transform: none;
      display: block;
      flex-shrink: 0;
      width: auto;
      max-width: none;
    }
  }
</style>
