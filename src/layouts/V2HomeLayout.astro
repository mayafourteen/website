---
// V2 homepage shell — cinematic entrance, not the About page. Content is
// deliberately minimal: hero, title, tagline, hamburger nav, social icons.
// See PROJECT.md v2 milestone notes for the "homepage as entrance, not
// biography" rationale.
import BaseLayout from './BaseLayout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import HamburgerMenu from '../components/HamburgerMenu.astro';
import SocialNav from '../components/SocialNav.astro';
import { primarySocialLinks } from '../data/primarySocialLinks.js';

interface Props {
  title: string;
  description?: string;
  lang: string;
  epkHref?: string;
}

const { title, description, lang, epkHref } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass="page-v2-home" lang={lang}>
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/maya-landing-bw.jpg" alt="Maya Fourteen" filtered />
  </div>

  <div class="scrim" aria-hidden="true"></div>

  <HamburgerMenu />

  <div class="content-wrapper">
    <h1 class="logo-text fade-item">Maya Fourteen</h1>
    <div class="slogan fade-item">'I build sets that grow on you'</div>

    <SocialNav links={primarySocialLinks} epkHref={epkHref} />
  </div>
</BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-v2-home) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* Icons are the credibility signals — with a ~30-second attention budget,
     the full reveal sequence should be finished well under 2s, not the
     production trio's more leisurely ~3.7s. Overriding SocialNav's own
     delay from outside keeps that shared component untouched for the
     pages that already rely on its current timing. */
  .content-wrapper :global(.nav-links) {
    animation-delay: 0.55s;
  }

  .background-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Composes the text against the lower third of the frame rather than
     dead-center — keeps the title/tagline off the subject's face and
     gives the page a deliberate, cinematic bottom-weighted read instead
     of sitting flush on top of the busiest part of the photo. */
  .scrim {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(0, 0, 0, 0.45) 70%,
      rgba(0, 0, 0, 0.68) 100%
    );
    pointer-events: none;
  }

  .content-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    min-height: 100vh;
    text-align: center;
    padding: 100px 10% 9vh;
  }

  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 5.8rem);
    line-height: 1.15;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 8px 0;
    animation-delay: 0.15s;
  }

  .slogan {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-style: italic;
    letter-spacing: 0.15em;
    font-weight: 300;
    margin-bottom: 50px;
    color: rgba(255, 255, 255, 0.85);
    animation-delay: 0.32s;
  }
</style>
