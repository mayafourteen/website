---
import { languages } from '../data/languages.js';
---

<div class="language-wrapper">
  <div class="languages">
    {languages.map((lang, i) => (
      <Fragment>
        {i > 0 && <span class="dot">•</span>}
        <a href={lang.href} target={lang.external ? '_blank' : undefined}>{lang.code}</a>
      </Fragment>
    ))}
  </div>
  <div class="select-language">[ Language · Idioma ]</div>
</div>

<style>
  .language-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: white;
    white-space: nowrap;
  }

  .languages {
    display: flex;
    align-items: center;
    gap: 2.5vw;
    font-weight: 300;
    letter-spacing: 0.25em;
    font-size: 2.2vw;
  }

  .languages a {
    color: white;
    text-decoration: none;
  }

  .languages a:hover {
    opacity: 0.7;
  }

  .dot {
    font-size: 1.2em;
    line-height: 1;
  }

  .select-language {
    margin-top: 1.8vh;
    font-size: 0.9vw;
    letter-spacing: 0.3em;
    font-weight: 300;
    opacity: 0.75;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .languages {
      font-size: 5.5vw;
      gap: 6vw;
      letter-spacing: 0.3em;
      font-weight: 600;
    }

    .dot {
      font-size: 1em;
    }

    .select-language {
      font-size: 3.2vw;
      margin-top: 3vh;
      opacity: 0.85;
      font-weight: 500;
    }
  }
</style>
