---
import { findImageBySrc } from '../../data/v3/images.js';

interface Props {
  src: string;
  alt: string;
  filtered?: boolean;
}

const { src, alt, filtered = false } = Astro.props;

// Every caller passes a plain path (see src/data/v3/images.js); look up the
// real on-disk width/height/srcset there instead of taking them as props,
// so no call site can drift out of sync with the actual files. This
// component is always used as a full-viewport, position:fixed background —
// i.e. always the page's hero/LCP element — so it's always eager with
// fetchpriority="high" and sizes="100vw", never lazy.
const meta = findImageBySrc(src);
---

<picture>
  {meta?.webpSrcset && (
    <source type="image/webp" srcset={meta.webpSrcset} sizes="100vw" />
  )}
  <img
    src={src}
    srcset={meta?.srcset}
    sizes={meta?.srcset ? '100vw' : undefined}
    width={meta?.width}
    height={meta?.height}
    alt={alt}
    loading="eager"
    fetchpriority="high"
    class:list={['hero-image', { filtered }]}
  />
</picture>

<style>
  picture {
    display: contents;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image.filtered {
    filter: brightness(38%) grayscale(100%);
  }
</style>
