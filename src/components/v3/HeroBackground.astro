---
import { findImageBySrc } from '../../data/v3/images.js';

interface Props {
  src: string;
  alt: string;
  filtered?: boolean;
}

const { src, alt, filtered = false } = Astro.props;

// Every caller passes a plain path (see src/data/v3/images.js); look up the
// real on-disk width/height/srcset there instead of taking them as props,
// so no call site can drift out of sync with the actual files. This
// component is always used as a full-viewport, position:fixed background —
// i.e. always the page's hero/LCP element — so it's always eager with
// fetchpriority="high", never lazy.
const meta = findImageBySrc(src);

// This is a full-bleed object-fit:cover background. On a portrait phone the
// landscape photo is scaled up to cover the tall viewport, so its rendered
// width is ~2-3x the viewport width — a plain "100vw" would make the browser
// pick a variant far too small and the hero looks soft. On portrait screens
// we ask for ~240vw so a large, crisp variant is chosen; landscape/desktop
// keep 100vw.
const HERO_SIZES = '(max-aspect-ratio: 1/1) 240vw, 100vw';
---

<picture>
  {meta?.avifSrcset && (
    <source type="image/avif" srcset={meta.avifSrcset} sizes={HERO_SIZES} />
  )}
  {meta?.webpSrcset && (
    <source type="image/webp" srcset={meta.webpSrcset} sizes={HERO_SIZES} />
  )}
  <img
    src={src}
    srcset={meta?.srcset}
    sizes={meta?.srcset ? HERO_SIZES : undefined}
    width={meta?.width}
    height={meta?.height}
    alt={alt}
    loading="eager"
    fetchpriority="high"
    class:list={['hero-image', { filtered }]}
  />
</picture>

<style>
  picture {
    display: contents;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image.filtered {
    filter: brightness(38%) grayscale(100%);
  }
</style>
