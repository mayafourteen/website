---
import { navItems } from '../../data/v3/navItems.js';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const items = navItems[lang] ?? navItems.en;

// "You are here": mark the item matching the current URL so the open menu
// orients the visitor (gold underline via .is-current below).
const currentPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
---

<button
  type="button"
  class="hamburger-trigger"
  id="hamburger-trigger"
  aria-expanded="false"
  aria-controls="hamburger-overlay"
  aria-label="Open menu"
>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<nav id="hamburger-overlay" class="menu-overlay" aria-hidden="true" aria-label="Primary">
  <button type="button" class="menu-close" id="hamburger-close" aria-label="Close menu">&times;</button>
  <ul class="menu-list">
    {items.map((item) => (
      <li><a
        href={item.href}
        aria-current={item.href === currentPath ? 'page' : undefined}
        class:list={['menu-list-item', { 'menu-list-item--highlight': item.highlight, 'is-current': item.href === currentPath }]}
      >{item.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const trigger = document.getElementById('hamburger-trigger');
  const overlay = document.getElementById('hamburger-overlay');
  const closeBtn = document.getElementById('hamburger-close');

  function openMenu() {
    overlay?.classList.add('is-open');
    overlay?.setAttribute('aria-hidden', 'false');
    trigger?.setAttribute('aria-expanded', 'true');
    trigger?.classList.add('is-active');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('is-open');
    overlay?.setAttribute('aria-hidden', 'true');
    trigger?.setAttribute('aria-expanded', 'false');
    trigger?.classList.remove('is-active');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', () => {
    if (overlay?.classList.contains('is-open')) closeMenu();
    else openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>

<style>
  /* --v3-header-inset is defined once per page shell (V3HomeLayout /
     V3InteriorLayout) so this and LanguageMenu's edge offset can never
     drift out of sync; falls back to 20px for pages that don't define it
     (e.g. the EPK pages, which use neither layout directly). */
  .hamburger-trigger {
    position: fixed;
    top: calc(var(--v3-header-inset, 20px) + env(safe-area-inset-top, 0px));
    right: calc(var(--v3-header-inset, 20px) + env(safe-area-inset-right, 0px));
    z-index: 60;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background: #fff;
    box-shadow: 0 0 6px rgba(0, 0, 0, 0.35);
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  .hamburger-trigger.is-active .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger-trigger.is-active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger-trigger.is-active .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 55;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Fully opaque: the old 0.97 let bright page content (EPK cards,
       video thumbnails) ghost faintly through the open menu. */
    background: #000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .menu-close {
    position: absolute;
    top: calc(14px + env(safe-area-inset-top, 0px));
    right: calc(20px + env(safe-area-inset-right, 0px));
    background: transparent;
    border: none;
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    padding: 8px;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .menu-list-item {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 300;
    color: #fff;
    text-decoration: none;
    padding: 14px 24px;
    opacity: 0.8;
    transition: opacity 0.3s ease, letter-spacing 0.3s ease;
  }

  .menu-list-item:hover {
    opacity: 1;
    letter-spacing: 0.18em;
  }

  /* Current page: white underline with a soft slow flash, the "you are
     here" marker. White, not gold, so it never competes with the gold
     EPK item (Antonio's call). Drawn as a pseudo-element so only the
     line pulses, never the label text. */
  .menu-list-item.is-current {
    opacity: 1;
    position: relative;
  }

  .menu-list-item.is-current::after {
    content: '';
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 8px;
    height: 1px;
    background: #fff;
    animation: menuCurrentPulse 2.6s ease-in-out infinite;
  }

  @keyframes menuCurrentPulse {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 0.3; }
  }

  /* The one lit item in the menu (currently EPK — see navItems.js):
     desert-gold like the homepage's [ enter ], full opacity, with the
     same slow breathing pulse so it quietly says "this way" to promoters
     without shouting. The pulse animates opacity between 1 and 0.6 —
     safe alongside the stagger transition below because that runs on the
     parent <li>, not this <a>. Hover goes white like everything else. */
  .menu-list-item--highlight {
    color: #d9a96a;
    opacity: 1;
    animation: menuItemBreathe 3s ease-in-out 0.8s infinite;
  }

  .menu-list-item--highlight:hover {
    color: #fff;
  }

  @keyframes menuItemBreathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* Staggered entrance: each item settles in slightly after the last,
     reinforcing the menu as a deliberate sequence of destinations rather
     than a static list. Reset to invisible whenever the overlay closes so
     it replays on the next open. */
  .menu-list li {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .menu-overlay.is-open .menu-list li {
    opacity: 1;
    transform: translateY(0);
  }

  .menu-list li:nth-child(1) { transition-delay: 0.05s; }
  .menu-list li:nth-child(2) { transition-delay: 0.1s; }
  .menu-list li:nth-child(3) { transition-delay: 0.15s; }
  .menu-list li:nth-child(4) { transition-delay: 0.2s; }
  .menu-list li:nth-child(5) { transition-delay: 0.25s; }
  .menu-list li:nth-child(6) { transition-delay: 0.3s; }
  .menu-list li:nth-child(7) { transition-delay: 0.35s; }
</style>
