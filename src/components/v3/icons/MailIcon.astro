---
// Contact glyph for the homepage social row. Thin-stroke envelope (not a
// heavy filled one) so it reads as a clean line mark next to the other
// icons rather than a clunky utility glyph. stroke:currentColor -> white
// via the row's color. Routes to /{lang}/book, not a raw mailto, so the
// address isn't exposed to scrapers on the highest-traffic page.
---
<svg class="social-svg mail-svg" viewBox="0 0 24 24" width="24" height="24" role="img" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><title>Contact</title><rect x="2.75" y="5.25" width="18.5" height="13.5" rx="2.4" /><path d="m3.75 7.25 7.35 4.94a1.6 1.6 0 0 0 1.8 0l7.35-4.94" /></svg>

<style>
  .mail-svg {
    width: 1.65rem;
    height: 1.65rem;
    display: block;
    fill: none;
    stroke: #fff;
  }
  @media (max-width: 768px) {
    .mail-svg {
      width: 1.45rem;
      height: 1.45rem;
    }
  }
</style>
