---
// Envelope glyph for the "Contact" entry in the homepage social row.
// Inline SVG, fill:currentColor -> white via the row's color, matching
// every other icon (no Font Awesome dependency). Routes to /{lang}/book,
// not a raw mailto, so the address isn't exposed to scrapers on the
// highest-traffic page.
---
<svg class="social-svg mail-svg" viewBox="0 0 24 24" width="24" height="24" role="img" aria-hidden="true" focusable="false" fill-rule="evenodd" clip-rule="evenodd"><title>Contact</title><path d="M3.5 5h17A1.5 1.5 0 0 1 22 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-17A1.5 1.5 0 0 1 2 17.5v-11A1.5 1.5 0 0 1 3.5 5Zm.72 2L12 12.16 19.78 7H4.22ZM20 8.28l-7.44 4.94a1 1 0 0 1-1.12 0L4 8.28V17h16V8.28Z" /></svg>

<style>
  .social-svg {
    width: 1.65rem;
    height: 1.65rem;
    display: block;
    fill: #fff;
  }
  @media (max-width: 768px) {
    .social-svg {
      width: 1.45rem;
      height: 1.45rem;
    }
  }
</style>
