---
// True page-bottom footer for interior pages: a single "MENU" control that
// opens the same hamburger overlay as the top-right trigger (via a forwarded
// click, same pattern as the landing page's [enter] CTA), so the page bottom
// always has a way back into full site navigation.
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
// "Menu" is identical in EN and PT-BR; Spanish takes the accent.
const label = lang === 'es' ? 'Menú' : 'Menu';
---

<footer class="text-footer">
  <button type="button" class="text-footer-link" id="text-footer-menu">{label}</button>
</footer>

<script>
  document.getElementById('text-footer-menu')?.addEventListener('click', () => {
    document.getElementById('hamburger-trigger')?.click();
  });
</script>

<style>
  .text-footer {
    /* Must be a positioned element (not static): the page's hero photo
       sits in a position:fixed background-container, and per CSS stacking
       rules ANY positioned element paints above non-positioned ones
       regardless of DOM order — without this, the fixed background painted
       over this footer's text even though it comes later in the markup
       (content-wrapper avoids the same issue via its own position:relative). */
    position: relative;
    margin-top: 60px;
    padding-bottom: calc(40px + env(safe-area-inset-bottom, 0px));
    text-align: center;
    /* This footer sits directly over the page's photo background (there's
       no opaque page body behind it), and that photo's brightness varies
       by page/crop — a lighter patch of sand or sky can wash out the dim
       text otherwise. A faint bottom-weighted scrim (plus the text-shadow
       on the link below) keeps it legible regardless of what's behind it. */
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.35));
  }

  .text-footer-link {
    font-family: 'Cormorant Garamond', serif;
    /* 1.019rem = a further +10% on the previous 0.926rem (itself +15% from
       the original 0.805rem), bringing it up to sit properly against the
       rest of the page's type scale. letter-spacing stays 0.15em: em is
       relative to font-size, so it scales proportionally with this for free. */
    font-size: 1.019rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    /* Raised from 0.45 to 0.65 alpha: the dimmer value read as too faint /
       too transparent against the photo, so this makes the control clearly
       more visible while still staying quieter than the hover (0.9). */
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    text-shadow: 0 1px 5px rgba(0, 0, 0, 0.85);
    transition: color 0.3s ease;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .text-footer-link:hover,
  .text-footer-link:focus-visible {
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 480px) {
    .text-footer {
      margin-top: 44px;
    }
  }
</style>
