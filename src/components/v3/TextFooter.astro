---
// True page-bottom footer for interior pages — a single discreet "EPK"
// text link (not an icon), plain, with a thin rule above. Not used on the
// EPK pages themselves (linking EPK from EPK is redundant, and their own
// "Discover MAYA" row already covers socials).
interface Props {
  epkHref: string;
}

const { epkHref } = Astro.props;
---

<footer class="text-footer">
  <div class="text-footer-links">
    <a href={epkHref} class="text-footer-link">EPK</a>
  </div>
</footer>

<style>
  .text-footer {
    /* Must be a positioned element (not static): the page's hero photo
       sits in a position:fixed background-container, and per CSS stacking
       rules ANY positioned element paints above non-positioned ones
       regardless of DOM order — without this, the fixed background painted
       over this footer's text even though it comes later in the markup
       (content-wrapper avoids the same issue via its own position:relative). */
    position: relative;
    margin-top: 60px;
    padding-top: 24px;
    padding-bottom: calc(40px + env(safe-area-inset-bottom, 0px));
    border-top: 1px solid rgba(255, 255, 255, 0.25);
    text-align: center;
    /* This footer sits directly over the page's photo background (there's
       no opaque page body behind it), and that photo's brightness varies
       by page/crop — a lighter patch of sand or sky can wash out the dim
       rule/text otherwise. A faint bottom-weighted scrim (plus the
       text-shadow on the link below) keeps both legible regardless of
       what's directly behind them. */
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.35));
  }

  .text-footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .text-footer-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    text-shadow: 0 1px 5px rgba(0, 0, 0, 0.85);
    transition: color 0.3s ease;
  }

  .text-footer-link:hover,
  .text-footer-link:focus-visible {
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 480px) {
    .text-footer {
      margin-top: 44px;
      padding-top: 20px;
    }
  }
</style>
