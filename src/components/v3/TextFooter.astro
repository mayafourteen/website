---
// True page-bottom footer for interior pages: a single control that opens
// the same hamburger overlay as the top-right trigger (via a forwarded
// click, same pattern as the landing page's [enter] CTA), so the page
// bottom always has a way back into full site navigation.
//
// Two modes:
//  - 'menu' (default): a plain "MENU" button that opens the same hamburger
//    overlay as the top-right trigger — the utilitarian way back in.
//  - 'explore': a gold "[ explore ]" LINK (not a menu-opener) to the site's
//    landing page — for pages a cold visitor may land on from an external
//    link (e.g. /subscribe shared on social). "MENU" gives them no reason
//    to click; "[ explore ]" sends them to the entrance to discover the
//    rest of the site. Links straight to /{lang} (the splash) rather than
//    "/" so there's no language-router redirect hop.
interface Props {
  lang?: string;
  cta?: 'menu' | 'explore';
}
const { lang = 'en', cta = 'menu' } = Astro.props;
// "Menu" is identical in EN and PT-BR; Spanish takes the accent.
const menuLabel = lang === 'es' ? 'Menú' : 'Menu';
const exploreLabel = lang === 'en' ? 'explore' : 'explorar';
const isExplore = cta === 'explore';
const exploreHref = `/${lang}`;
---

<footer class="text-footer">
  {isExplore ? (
    <a href={exploreHref} class="text-footer-link text-footer-link--explore">[ {exploreLabel} ]</a>
  ) : (
    <button type="button" class="text-footer-link" id="text-footer-menu">{menuLabel}</button>
  )}
</footer>

<script>
  document.getElementById('text-footer-menu')?.addEventListener('click', () => {
    document.getElementById('hamburger-trigger')?.click();
  });
</script>

<style>
  .text-footer {
    /* Must be a positioned element (not static): the page's hero photo
       sits in a position:fixed background-container, and per CSS stacking
       rules ANY positioned element paints above non-positioned ones
       regardless of DOM order — without this, the fixed background painted
       over this footer's text even though it comes later in the markup
       (content-wrapper avoids the same issue via its own position:relative). */
    position: relative;
    margin-top: 60px;
    padding-bottom: calc(40px + env(safe-area-inset-bottom, 0px));
    text-align: center;
    /* This footer sits directly over the page's photo background (there's
       no opaque page body behind it), and that photo's brightness varies
       by page/crop — a lighter patch of sand or sky can wash out the dim
       text otherwise. A faint bottom-weighted scrim (plus the text-shadow
       on the link below) keeps it legible regardless of what's behind it. */
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.35));
  }

  .text-footer-link {
    font-family: 'Cormorant Garamond', serif;
    /* 1.17rem = a further ~15% on the previous 1.019rem (which was itself
       two bumps up from the original 0.805rem) — Antonio kept reading it
       as too small against the page's type scale. letter-spacing stays
       0.15em: em is relative to font-size, so it scales along for free. */
    font-size: 1.17rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    /* Raised from 0.45 to 0.65 alpha: the dimmer value read as too faint /
       too transparent against the photo, so this makes the control clearly
       more visible while still staying quieter than the hover (0.9). */
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    text-shadow: 0 1px 5px rgba(0, 0, 0, 0.85);
    transition: color 0.3s ease;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .text-footer-link:hover,
  .text-footer-link:focus-visible {
    color: rgba(255, 255, 255, 0.9);
  }

  /* Explore variant: desert-gold and lowercase, matching the [ enter ] /
     [ explore ] gold gateways elsewhere on the site. Brightens to white on
     hover like the plain footer, so the two modes feel like one control. */
  .text-footer-link--explore {
    color: #d9a96a;
    text-transform: lowercase;
    letter-spacing: 0.08em;
  }

  .text-footer-link--explore:hover,
  .text-footer-link--explore:focus-visible {
    color: #fff;
  }

  @media (max-width: 480px) {
    .text-footer {
      margin-top: 44px;
    }
  }
</style>
