---
// Newsletter CTA block — replaces the inline signup form on content pages
// (video-sets, audio-sets, book). Instead of a bare email field, it shows a
// short invitation and a gold bracket button that routes to the dedicated
// /subscribe landing page, where the full "inner circle" pitch lives. Keeps
// one high-quality conversion surface and echoes the site's [ enter ] /
// [ explore ] gold-gateway motif.
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;

const COPY: Record<string, { heading: string; text: string; button: string; href: string }> = {
  en: {
    heading: 'The inner circle',
    text: 'New sets, dates and private invitations reach this list before they ever go public.',
    button: 'subscribe',
    href: '/en/subscribe',
  },
  pt: {
    heading: 'O círculo interno',
    text: 'Novos sets, datas e convites privados chegam a esta lista antes de irem ao público.',
    button: 'assinar',
    href: '/pt/subscribe',
  },
  es: {
    heading: 'El círculo interno',
    text: 'Nuevos sets, fechas e invitaciones privadas llegan a esta lista antes de hacerse públicas.',
    button: 'suscribirse',
    href: '/es/subscribe',
  },
};
const copy = COPY[lang] ?? COPY.en;
---

<section class="newsletter-cta" aria-label={copy.heading}>
  <h2 class="newsletter-cta-heading">{copy.heading}</h2>
  <p class="newsletter-cta-text">{copy.text}</p>
  <a class="newsletter-cta-button" href={copy.href}>{copy.button}<span class="cta-arrow" aria-hidden="true">&rarr;</span></a>
</section>

<style>
  .newsletter-cta {
    margin-top: 56px;
    padding: 0;
    max-width: 640px;
  }

  .newsletter-cta-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    margin: 0 0 8px;
  }

  .newsletter-cta-text {
    font-size: 0.88em;
    opacity: 0.75;
    margin: 0 0 22px;
    line-height: 1.55;
    max-width: 44ch;
  }

  /* Solid gold button — the only filled color element on an otherwise
     monochrome page, so it reads instantly as the primary action. Dark
     text keeps it premium rather than loud. */
  .newsletter-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: 'Inter', Arial, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0a0a0c;
    background: #d9a96a;
    text-decoration: none;
    padding: 14px 30px;
    border-radius: 1px;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .newsletter-cta-button:hover {
    background: #e6c08b;
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(217, 169, 106, 0.28);
  }

  .cta-arrow {
    transition: transform 0.25s ease;
  }

  .newsletter-cta-button:hover .cta-arrow {
    transform: translateX(3px);
  }
</style>
