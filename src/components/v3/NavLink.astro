---
interface Props {
  href: string;
  title: string;
  // EPK links in this row should navigate in the same tab (it's an
  // internal page); every other icon (external social profiles) opens in
  // a new tab. Defaults to new-tab since that's every caller except the
  // EPK entry.
  newTab?: boolean;
}

const { href, title, newTab = true } = Astro.props;
---

<a href={href} target={newTab ? '_blank' : undefined} rel={newTab ? 'noopener' : undefined} title={title}>
  <slot />
</a>

<style>
  a {
    color: #fff;
    text-decoration: none;
    transition: all 0.4s ease;
    opacity: 0.75;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 45px;
  }

  a:hover {
    opacity: 1;
    transform: translateY(-3px);
  }
</style>
