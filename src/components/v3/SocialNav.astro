---
import NavLink from './NavLink.astro';
import EpkIcon from './icons/EpkIcon.astro';
import BeatportIcon from './icons/BeatportIcon.astro';
import BeepdIcon from './icons/BeepdIcon.astro';
import ResidentAdvisorIcon from './icons/ResidentAdvisorIcon.astro';
import InstagramIcon from './icons/InstagramIcon.astro';
import YoutubeIcon from './icons/YoutubeIcon.astro';
import SoundcloudIcon from './icons/SoundcloudIcon.astro';
import SpotifyIcon from './icons/SpotifyIcon.astro';
import MailIcon from './icons/MailIcon.astro';
import { socialLinks } from '../../data/v3/socialLinks.js';

interface Props {
  epkHref?: string;
  contactHref?: string;
  videoHref?: string;
  audioHref?: string;
  links?: typeof socialLinks;
}

const { epkHref, contactHref, videoHref, audioHref, links = socialLinks } = Astro.props;

// EPK and Contact are always internal (same-tab). On the homepage, YouTube and
// SoundCloud are re-pointed at the on-site Video/Audio pages (which embed the
// same content) so warm visitors stay in the funnel instead of bouncing to the
// platforms; the EPK discover row leaves them external by not passing the
// overrides. Everything still external opens a new tab.
const resolveHref = (link: { name: string; href: string }) =>
  link.name === 'epk' && epkHref ? epkHref
  : link.name === 'contact' && contactHref ? contactHref
  : link.name === 'youtube' && videoHref ? videoHref
  : link.name === 'soundcloud' && audioHref ? audioHref
  : link.href;
const isInternal = (link: { name: string }) =>
  link.name === 'epk'
  || link.name === 'contact'
  || (link.name === 'youtube' && !!videoHref)
  || (link.name === 'soundcloud' && !!audioHref);
---

<div class="nav-links fade-item">
  {links.map((link) => (
    <NavLink href={resolveHref(link)} title={link.title} newTab={!isInternal(link)}>
      {link.name === 'epk' && <EpkIcon />}
      {link.name === 'contact' && <MailIcon />}
      {link.name === 'beatport' && <BeatportIcon />}
      {link.name === 'beepd' && <BeepdIcon />}
      {link.name === 'residentadvisor' && <ResidentAdvisorIcon />}
      {link.name === 'instagram' && <InstagramIcon />}
      {link.name === 'youtube' && <YoutubeIcon />}
      {link.name === 'soundcloud' && <SoundcloudIcon />}
      {link.name === 'spotify' && <SpotifyIcon />}
    </NavLink>
  ))}
</div>

<style>
  .nav-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 35px;
    animation-delay: 1.5s;
    margin-bottom: 50px;
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 20px;
    }
  }
</style>
