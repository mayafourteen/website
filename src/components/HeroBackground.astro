---
interface Props {
  src: string;
  alt: string;
  filtered?: boolean;
}

const { src, alt, filtered = false } = Astro.props;
---

<img src={src} alt={alt} class:list={['hero-image', { filtered }]} />

<style>
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image.filtered {
    filter: brightness(38%) grayscale(100%);
  }
</style>
