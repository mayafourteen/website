---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
---

<BaseLayout
  title="MAYA FOURTEEN"
  description="Official website of award-winning electronic music artist Maya Fourteen. Choose your preferred language to explore her world."
  bodyClass="page-landing"
>
  <div class="container">
    <HeroBackground src="/images/maya-landing.jpg" alt="Maya Fourteen" />
    <LanguageSwitcher />
  </div>
</BaseLayout>

<style>
  :global(.page-landing) {
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
  }

  .container {
    position: relative;
    width: 100vw;
    height: 100vh;
  }
</style>
