---
// Landing page for Brevo's double opt-in confirmation link — replaces
// Brevo's default hosted "success" page. Language-neutral by design:
// one form serves all three site languages, and Brevo allows a single
// redirect URL per form, so this page confirms in all three and offers
// the three homes. noindex: it only exists to be arrived at from the
// confirmation email.
import V3BaseLayout from '../layouts/V3BaseLayout.astro';
import HeroBackground from '../components/v3/HeroBackground.astro';

const fontsHref = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400&display=swap';
---

<V3BaseLayout
  title="MAYA FOURTEEN | Subscription confirmed"
  description="Your subscription is confirmed."
  bodyClass="page-subscribed"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href={fontsHref} rel="stylesheet">
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/maya-landing-bw.jpg" alt="Maya Fourteen" filtered />
  </div>

  <div class="content-subscribed">
    <p class="eyebrow">Maya Fourteen</p>
    <h1 class="headline">You're in.</h1>
    <p class="subline">Inscrição confirmada · Suscripción confirmada</p>
    <p class="promise">New sets, releases, dates and special invitations, before anyone else.</p>
    <nav class="home-links" aria-label="Go to the site">
      <a href="/en">English</a>
      <span class="dot" aria-hidden="true">•</span>
      <a href="/pt">Português</a>
      <span class="dot" aria-hidden="true">•</span>
      <a href="/es">Español</a>
    </nav>
  </div>
</V3BaseLayout>

<style>
  :global(.page-subscribed) {
    overflow: hidden;
  }

  .background-container {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .content-subscribed {
    position: relative;
    z-index: 1;
    height: 100vh;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    padding: 0 24px;
  }

  .eyebrow {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 200;
    font-size: 0.8rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    margin: 0 0 18px;
    opacity: 0.55;
  }

  .headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    letter-spacing: 0.06em;
    margin: 0;
  }

  .subline {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    opacity: 0.6;
    margin: 14px 0 0;
  }

  .promise {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    opacity: 0.85;
    margin: 26px 0 0;
    max-width: 480px;
  }

  .home-links {
    margin-top: 46px;
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .home-links a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .home-links a:hover {
    color: #fff;
  }

  .dot {
    opacity: 0.4;
  }
</style>
