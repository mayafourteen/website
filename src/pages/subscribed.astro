---
// Self-hosted fonts (fontsource, bundled locally): removes the two
// Google Fonts round-trips from the critical path and the GDPR gray zone
// of shipping visitor IPs to Google. Same families/weights as before.
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/inter/200.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
// Landing page for Brevo's double opt-in confirmation link — replaces
// Brevo's default hosted "success" page. Language-neutral by design:
// one form serves all three site languages, and Brevo allows a single
// redirect URL per form, so this page confirms in all three and offers
// the three homes. noindex: it only exists to be arrived at from the
// confirmation email.
//
// The payoff of the /subscribe page: that page shows the safe CLOSED with
// Maya's hand on it; this one is the same safe standing OPEN, full-bleed.
// A left-weighted scrim darkens the empty wall so the text column reads
// cleanly while the open vault glows on the right, pulling the eye in.
import V3BaseLayout from '../layouts/V3BaseLayout.astro';
import HeroBackground from '../components/v3/HeroBackground.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import TextFooter from '../components/v3/TextFooter.astro';
---

<V3BaseLayout
  title="MAYA FOURTEEN | Subscription confirmed"
  description="Your subscription is confirmed."
  bodyClass="page-subscribed"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <div class="background-container">
    <HeroBackground src="/images/subscribed-hero-vault.webp" alt="An antique vault standing open" />
  </div>
  <div class="scrim" aria-hidden="true"></div>

  <HamburgerMenu lang="en" />

  <div class="content-subscribed">
    <p class="eyebrow">Maya inner circle</p>
    <h1 class="headline">You're in!</h1>
    <span class="gold-rule" aria-hidden="true"></span>
    <p class="subline">Inscrição confirmada&nbsp;·&nbsp;Suscripción confirmada</p>
    <p class="promise">New sets, releases, dates and special invitations, before anyone else.</p>
    <a class="enter-site" href="/">[ explore ]</a>
  </div>

  <TextFooter lang="en" />
</V3BaseLayout>

<style>
  .background-container {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  /* Left-weighted cinematic scrim: dark over the empty wall (where the
     text sits), clearing by ~78% so the open vault on the right stays
     visible. A faint bottom vignette seats the footer. */
  .scrim {
    position: fixed;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(90deg, rgba(5, 5, 5, 0.92) 0%, rgba(5, 5, 5, 0.7) 30%, rgba(5, 5, 5, 0.28) 55%, rgba(5, 5, 5, 0) 80%),
      linear-gradient(180deg, rgba(5, 5, 5, 0) 60%, rgba(5, 5, 5, 0.6) 100%);
  }

  :global(.page-subscribed) :global(.text-footer) {
    position: relative;
    z-index: 2;
  }

  .content-subscribed {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    text-align: left;
    color: #fff;
    padding: 0 7vw;
    max-width: 620px;
  }

  /* Gentle staged fade-in so the moment settles in. prefers-reduced-motion
     is neutralised globally in V3BaseLayout. */
  .content-subscribed > * {
    opacity: 0;
    transform: translateY(12px);
    animation: arrive 0.9s ease forwards;
  }

  .content-subscribed .eyebrow { animation-delay: 0.15s; }
  .content-subscribed .headline { animation-delay: 0.32s; }
  .content-subscribed .gold-rule { animation-delay: 0.5s; }
  .content-subscribed .subline { animation-delay: 0.64s; }
  .content-subscribed .promise { animation-delay: 0.78s; }
  .content-subscribed .enter-site { animation-delay: 0.96s; }

  /* Clear in-content way out: a gold "[ explore ]" that sends the new
     subscriber into the site (root auto-routes to their language's
     entrance). Sits in the visible content block so nobody has to spot
     the hamburger or scroll to the MENU footer to leave. */
  .enter-site {
    display: inline-block;
    margin-top: 42px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: #d9a96a;
    text-decoration: none;
    transition: letter-spacing 0.3s ease, color 0.3s ease;
  }

  .enter-site:hover,
  .enter-site:focus-visible {
    color: #fff;
    letter-spacing: 0.16em;
  }
  .content-subscribed .home-links { animation-delay: 0.96s; }

  @keyframes arrive {
    to { opacity: 1; transform: translateY(0); }
  }

  .eyebrow {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 200;
    font-size: 0.78rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    margin: 0 0 20px;
    opacity: 0.6;
  }

  .headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .gold-rule {
    display: block;
    width: 72px;
    height: 1px;
    margin: 30px 0 0;
    background: linear-gradient(90deg, #d9a96a, rgba(217, 169, 106, 0));
  }

  .subline {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    opacity: 0.62;
    margin: 24px 0 0;
  }

  .promise {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.1rem, 2.2vw, 1.45rem);
    line-height: 1.4;
    opacity: 0.9;
    margin: 18px 0 0;
    max-width: 30ch;
  }

  .home-links {
    margin-top: 48px;
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .home-links a {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .home-links a:hover {
    color: #fff;
  }

  .dot {
    opacity: 0.4;
  }

  /* Phones: the vault is a tall crop, so lean the scrim more vertical and
     keep the text column comfortable with normal side padding. */
  @media (max-width: 760px) {
    .scrim {
      background:
        linear-gradient(90deg, rgba(5, 5, 5, 0.9) 0%, rgba(5, 5, 5, 0.62) 55%, rgba(5, 5, 5, 0.2) 100%),
        linear-gradient(180deg, rgba(5, 5, 5, 0.3) 0%, rgba(5, 5, 5, 0) 40%, rgba(5, 5, 5, 0.7) 100%);
    }

    .content-subscribed {
      padding: 0 26px;
    }
  }
</style>
