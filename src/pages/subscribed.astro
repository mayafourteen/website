---
// Self-hosted fonts (fontsource, bundled locally): removes the two
// Google Fonts round-trips from the critical path and the GDPR gray zone
// of shipping visitor IPs to Google. Same families/weights as before.
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/inter/200.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
// Landing page for Brevo's double opt-in confirmation link — replaces
// Brevo's default hosted "success" page. Language-neutral by design:
// one form serves all three site languages, and Brevo allows a single
// redirect URL per form, so this page confirms in all three and offers
// the three homes. noindex: it only exists to be arrived at from the
// confirmation email.
//
// The "arrival": a pure black moment. Centrepiece is the open vault
// (safe_open, grayscale to match the /subscribe closed-safe coding) —
// held small and contained, not full-bleed, so it reads as "the safe is
// open, step in" rather than another hero. Its dark edges dissolve into
// the page black; a faint gold glow and a single gold thread finish it.
import V3BaseLayout from '../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import TextFooter from '../components/v3/TextFooter.astro';
---

<V3BaseLayout
  title="MAYA FOURTEEN | Subscription confirmed"
  description="Your subscription is confirmed."
  bodyClass="page-subscribed"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <div class="subscribed-bg" aria-hidden="true"></div>

  <HamburgerMenu lang="en" />

  <div class="content-subscribed">
    <img
      class="vault"
      src="/images/confirm-safe-open.webp"
      srcset="/images/confirm-safe-open-640w.webp 640w, /images/confirm-safe-open-960w.webp 960w, /images/confirm-safe-open.webp 1120w"
      sizes="(max-width: 480px) 260px, 420px"
      width="1106"
      height="1024"
      alt="An antique vault standing open"
      loading="eager"
      decoding="async"
    />
    <p class="eyebrow">Maya Fourteen</p>
    <h1 class="headline">You're in.</h1>
    <span class="gold-rule" aria-hidden="true"></span>
    <p class="subline">Inscrição confirmada · Suscripción confirmada</p>
    <p class="promise">New sets, releases, dates and special invitations, before anyone else.</p>
    <nav class="home-links" aria-label="Go to the site">
      <a href="/en">English</a>
      <span class="dot" aria-hidden="true">•</span>
      <a href="/pt">Português</a>
      <span class="dot" aria-hidden="true">•</span>
      <a href="/es">Español</a>
    </nav>
  </div>

  <TextFooter lang="en" />
</V3BaseLayout>

<style>
  /* Full-bleed near-black with a single soft gold glow high-centered,
     behind the headline. No photo — see the page note above. */
  .subscribed-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% 34%, rgba(217, 169, 106, 0.13), rgba(5, 5, 5, 0) 60%),
      #050505;
  }

  /* Footer sits over the fixed background — own stacking so it paints
     above the z-index:0 layer. */
  :global(.page-subscribed) :global(.text-footer) {
    z-index: 1;
  }

  .content-subscribed {
    position: relative;
    z-index: 1;
    min-height: 86vh;
    min-height: 86dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    padding: 0 24px;
  }

  /* Gentle staged fade-in — the "moment" settles in rather than snapping.
     prefers-reduced-motion is neutralised globally in V3BaseLayout. */
  .content-subscribed > * {
    opacity: 0;
    transform: translateY(10px);
    animation: arrive 0.9s ease forwards;
  }

  .content-subscribed .vault { animation-delay: 0.05s; }
  .content-subscribed .eyebrow { animation-delay: 0.3s; }
  .content-subscribed .headline { animation-delay: 0.45s; }
  .content-subscribed .gold-rule { animation-delay: 0.6s; }
  .content-subscribed .subline { animation-delay: 0.72s; }
  .content-subscribed .promise { animation-delay: 0.86s; }
  .content-subscribed .home-links { animation-delay: 1.05s; }

  @keyframes arrive {
    to { opacity: 1; transform: translateY(0); }
  }

  /* The open vault — small and contained, its dark edges melting into the
     page black. Kept modest so it reads as an invitation, not a hero. */
  .vault {
    display: block;
    width: 100%;
    max-width: 420px;
    height: auto;
    margin: 0 0 34px;
  }

  .eyebrow {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 200;
    font-size: 0.8rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    margin: 0 0 18px;
    opacity: 0.55;
  }

  @media (max-width: 480px) {
    .vault {
      max-width: 260px;
      margin-bottom: 26px;
    }
  }

  .headline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.4rem, 6.5vw, 4rem);
    letter-spacing: 0.06em;
    margin: 0;
  }

  .gold-rule {
    display: block;
    width: 64px;
    height: 1px;
    margin: 26px 0 0;
    background: linear-gradient(90deg, rgba(217, 169, 106, 0), #d9a96a, rgba(217, 169, 106, 0));
  }

  .subline {
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    opacity: 0.6;
    margin: 22px 0 0;
  }

  .promise {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    opacity: 0.85;
    margin: 20px 0 0;
    max-width: 480px;
  }

  .home-links {
    margin-top: 46px;
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: 'Inter', Arial, sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .home-links a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .home-links a:hover {
    color: #fff;
  }

  .dot {
    opacity: 0.4;
  }
</style>
