---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
---

<V3InteriorLayout
  title="Audio"
  eyebrow="How does she sound"
  description="Stream Maya Fourteen's sets and tracks on SoundCloud."
  heroImage="/images/epk/epk-discography.jpg"
>
  <p>
    Studio mixes, live recordings and releases, streaming directly from SoundCloud.
  </p>

  <iframe
    class="embed-frame"
    height="300"
    scrolling="no"
    src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
    title="Maya Fourteen: SoundCloud audio sets"
    loading="lazy"
  ></iframe>

  <a class="cta-button" href="https://soundcloud.com/mayafourteen" target="_blank">Listen on SoundCloud</a>
</V3InteriorLayout>
