---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import { videoSets } from '../../data/v3/videoSets.js';
---

<V3InteriorLayout
  title="Sets em Vídeo"
  eyebrow="Ela também se apresenta ao vivo"
  description="Assista aos sets em vídeo e apresentações ao vivo de Maya Fourteen no YouTube."
  heroImage="/images/epk/epk-world-stages.jpg"
  heroImageCredit
>
  <p>
    Sets completos e imagens de apresentações, publicados conforme são lançados.
  </p>

  <ul class="video-list">
    {videoSets.map((video) => (
      <li>
        <div class="video-frame">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={video.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="video-caption">{video.title}</p>
      </li>
    ))}
  </ul>

  <a class="cta-button" href="https://www.youtube.com/@MayaFourteen" target="_blank">Assistir no YouTube</a>
</V3InteriorLayout>

<style>
  .video-list {
    list-style: none;
    margin: 0 0 32px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .video-frame {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .video-frame iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-caption {
    margin: 10px 0 0 0;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.65);
  }
</style>
