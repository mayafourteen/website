---
// ES counterpart of epk.astro — same structure/CSS, copy translated
// from the real ES gamma EPK page. New page: ES has no other interior
// pages (About/Press/etc stay EN/PT only, per the project's ES
// deferral), but EPK is an explicit exception per this brief. See
// epk.astro for the full sourcing notes.
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import { pressItems } from '../../data/v3/pressItems.js';
import { socialLinks } from '../../data/v3/socialLinks.js';

const discoverLinks = socialLinks.filter((l) =>
  ['instagram', 'youtube', 'soundcloud', 'spotify'].includes(l.name)
);
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="EPK de Maya Fourteen — biografía, credenciales, escenarios internacionales, discografía y contacto para contrataciones."
  bodyClass="page-epk"
  lang="es"
  languageHrefOverrides={{ en: '/v3/epk', pt: '/v3/epk-pt', es: '/v3/epk-es' }}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  {/* navItems has no 'es' key (ES has no other interior pages) — falls back to the English nav automatically */}
  <HamburgerMenu lang="es" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img class="epk-hero-image" src="/images/epk/epk-hero.jpg" alt="Maya Fourteen" />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Press Kit Electrónico</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ y Productora Internacional</p>
        <p class="epk-subtagline">Artista Electrónica Premiada</p>
      </div>
    </section>

    <!-- PERFIL ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-overview.jpg" alt="Maya Fourteen actuando" />
      <div class="epk-media-text">
        <h2>Perfil Artístico</h2>
        <p>
          Maya Fourteen es una artista brasileña de música electrónica conocida por
          un enfoque refinado y narrativo del sonido. Fusiona elementos orgánicos,
          progresivos y de carácter tech con un fuerte instinto melódico, lo que le
          permite adaptarse con fluidez a distintos estados de ánimo y entornos.
        </p>
      </div>
    </section>

    <!-- TRAYECTORIA INTERNACIONAL -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-global-performances.jpg" alt="Maya Fourteen en Terra Solis Dubai" />
      <div class="epk-media-text">
        <h2>Trayectoria Internacional</h2>
        <p>
          MAYA ha actuado en circuitos internacionales clave, construyendo una
          reputación por actuaciones sólidas y seguras en entornos exigentes. Su
          presencia global refleja autoridad musical, capacidad de adaptación y la
          confianza de públicos diversos en clubes, festivales y eventos
          cuidadosamente curados.
        </p>
      </div>
    </section>

    <!-- ESCENARIOS INTERNACIONALES -->
    <section class="epk-section">
      <h2>Escenarios Internacionales</h2>
      <div class="epk-stages-layout">
        <img class="epk-stages-image" src="/images/epk/epk-world-stages.jpg" alt="Maya Fourteen en Greenvalley Brasil" />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <span class="epk-stage-icon">🦋</span>
            <h3>Greenvalley Brasil 🇧🇷</h3>
            <p>5× #1 Club del mundo, c/ Michael Bibi &amp; Beltran</p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <span class="epk-stage-icon">🌐</span>
            <h3>World Club Dome 🇩🇪</h3>
            <p>#1 Alemania, Black Coffee &amp; Jamie Jones Stage</p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <span class="epk-stage-icon">🌙</span>
            <h3>Terra Solis Dubai 🇦🇪</h3>
            <p>El club de Tomorrowland en el desierto, c/ ANNA &amp; Antdot</p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <span class="epk-stage-icon">🏁</span>
            <h3>Formula 1</h3>
            <p>Grandes Premios de Abu Dhabi &amp; Mónaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <span class="epk-stage-icon">🌍</span>
            <h3>Gira por Europa, Oriente Medio y Asia</h3>
            <p>Presentaciones en Londres, Ámsterdam, Lisboa, Bergen, Frankfurt, Cannes, Mónaco, Ibiza, Dubai y Bali, y destinos clave en Tailandia, Vietnam y Malasia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA PREMIADA -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-award.jpg" alt="Maya Fourteen en el IMS Ibiza 2025" />
      <div class="epk-media-text">
        <h2>Artista Premiada</h2>
        <p>
          MAYA es ganadora de <strong>un Future Talent Award en el IMS Ibiza 2025,
          seleccionada por Pete Tong</strong>, y recibió el <strong>Nicole Moudaber Talent
          Highlight Prize</strong>. También fue seleccionada en el MixMasters Ibiza Get
          Signed Summit 2023, entre miles de artistas, con la participación de
          sellos como Defected, Solid Grooves y Systematic — una validación
          temprana de la industria.
        </p>
      </div>
    </section>

    <!-- VOCES DE LA INDUSTRIA -->
    <section class="epk-section epk-media epk-media-reverse">
      <img class="epk-media-image" src="/images/epk/epk-industry-voices.jpg" alt="Maya Fourteen con Clubbing TV en ADE" />
      <div class="epk-media-text">
        <h2>Voces de la Industria</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;¡Me encantaría tocar contigo algún día!&rdquo;</p>
          <cite>Nicole Moudaber — IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;Es el próximo gran nombre. Hay que seguirla de cerca.&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV — ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;A partir de ahora, esta es tu casa. Las puertas de Ibiza Sonica siempre estarán abiertas para ti.&rdquo;</p>
          <cite>Karlos Sense — Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- PRESENCIA EN MEDIOS -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-media-spotlight.jpg" alt="Maya Fourteen en la portada de Sync Beat Magazine" />
      <div class="epk-media-text">
        <h2>Presencia en Medios</h2>
        <p>
          MAYA fue portada de la revista española Sync Beat Magazine en una
          edición especial dedicada a la nueva generación de artistas de la
          música electrónica. En la entrevista, comparte su recorrido artístico,
          influencias y visión creativa, reflejando su creciente presencia
          internacional dentro del circuito global de la música electrónica.
        </p>
        <ul class="epk-press-list">
          {pressItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONOCIMIENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img class="epk-media-image" src="/images/epk/epk-editorial.jpg" alt="Gray Area: Brazilian DJs You Must Know For 2026" />
      <div class="epk-media-text">
        <h2>Reconocimiento Editorial</h2>
        <p>
          MAYA fue destacada por la plataforma estadounidense Gray Area como una
          de las artistas brasileñas a seguir en 2026, junto a Maz, Beltran,
          Antdot y Aline Rocha. La selección refleja la creciente atención
          internacional en torno a su trabajo y su posicionamiento dentro del
          panorama global actual de la música electrónica.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFÍA -->
    <section class="epk-section">
      <div class="epk-stages-layout">
        <img class="epk-stages-image" src="/images/epk/epk-discography.jpg" alt="Maya Fourteen en el estudio" />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografía</h2>
          <div class="epk-label-card">
            <h3>Systematic Recordings 🇩🇪</h3>
            <p class="epk-label-sub">Sello de los 20 años de Marc Romboy</p>
            <p>
              'Uniqueness' feat. Francesca Posgai — &ldquo;(&hellip;) Un regreso a
              la era dorada del house, con vibraciones atemporales en el espíritu
              de Mood II Swing (&hellip;)&rdquo; — Marc Romboy sobre el tema de
              debut de Maya Fourteen.
            </p>
            <p class="epk-label-tag">TOP 10 Beatport — máximo #8</p>
          </div>
          <div class="epk-label-card">
            <h3>VIVa MUSiC 🇬🇧</h3>
            <p class="epk-label-sub">Sello prestigioso de Steve Lawler</p>
            <p>
              'Feel Better' EP – colaboración junto a Mario Franca (Bedrock |
              Selador), que muestra la versatilidad de MAYA, transitando desde un
              Deep House hacia un Deep Tech más profundo y contundente.
            </p>
          </div>
          <div class="epk-label-card">
            <h3>Dioscuri Records 🇮🇹</h3>
            <p>
              Remix oficial de MAYA para el tema 'Stay' de Costax, publicado junto
              a otros remixes, incluido uno del legendario Timo Maas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SET DESTACADO -->
    <section class="epk-section">
      <h2>Set Destacado</h2>
      <iframe
        class="epk-embed"
        height="166"
        scrolling="no"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen/ancestral-mato-grosso-brazil&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
        title="Maya Fourteen — Ancestral (Mato Grosso, Brazil)"
        loading="lazy"
      ></iframe>
    </section>

    <!-- AUDIENCIA Y ALCANCE GLOBAL -->
    <section class="epk-section">
      <h2>Audiencia y Alcance Global</h2>
      <p>
        El contenido de MAYA en YouTube y SoundCloud supera las 300.000
        reproducciones, alcanzando oyentes en más de 100 países gracias a un
        crecimiento orgánico y sostenido. Sus sets destacan por su precisión
        técnica, fluidez armónica, gusto refinado y una identidad narrativa
        clara, reflejando una demanda internacional constante.
      </p>
      <div class="epk-audience-grid">
        <img src="/images/epk/epk-audience-map.jpg" alt="Alcance global de audiencia de Maya Fourteen" />
        <img src="/images/epk/epk-audience-radio.jpg" alt="Maya Fourteen destacada en Gray Area / Diplo's Revolution / SiriusXM" />
        <img src="/images/epk/epk-audience-greenvalley.jpg" alt="Maya Fourteen en Greenvalley" />
      </div>
      <p class="epk-audience-caption">
        Explora el catálogo de MAYA y descubre su lenguaje musical a través de
        distintos entornos, estados de ánimo y contextos.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imágenes en alta resolución disponibles para uso promocional. Todas las fotografías están protegidas por derechos de autor.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/epk-press-1.jpg" download><img src="/images/epk/epk-press-1.jpg" alt="Foto de prensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-2.jpg" download><img src="/images/epk/epk-press-2.jpg" alt="Foto de prensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-3.jpg" download><img src="/images/epk/epk-press-3.jpg" alt="Foto de prensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-4.jpg" download><img src="/images/epk/epk-press-4.jpg" alt="Foto de prensa de Maya Fourteen" /></a>
        <a href="/images/maya-landing.jpg" download><img src="/images/maya-landing.jpg" alt="Foto de prensa de Maya Fourteen" /></a>
        <a href="/images/maya-landing-bw.jpg" download><img src="/images/maya-landing-bw.jpg" alt="Foto de prensa de Maya Fourteen, blanco y negro" /></a>
      </div>
      <p class="epk-photo-credit">Fotografía: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
    </section>

    <!-- DESCUBRE A MAYA -->
    <section class="epk-section epk-discover">
      <h2>Descubre a MAYA</h2>
      <SocialNav links={discoverLinks} />
    </section>

    <!-- BOOKING & MANAGEMENT -->
    <section class="epk-section epk-booking">
      <h2>Contratación y Gestión Artística</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Para Contratación y Otras Consultas</p>
        <p class="epk-booking-name">Antonio Afonso — Management</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">Enviar correo a hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Disponible para reservas selectas en eventos privados, clubs y
          festivales a nivel internacional. Giras internacionales bajo
          solicitud. Rider profesional completo disponible.
        </p>
      </div>
    </section>
  </main>
</V3BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-epk) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    background: #0a0a0a;
  }

  /* padding-left trimmed to 10px (from a symmetric 14px) for optical
     alignment against the hamburger's ink — see the full measurement
     writeup on the matching rule in V3HomeLayout.astro. */
  :global(.page-epk) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 4% 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* HERO */
  .epk-hero {
    position: relative;
    margin: 0 -4%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .epk-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .epk-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.85) 100%);
  }

  .epk-hero-text {
    position: relative;
    z-index: 1;
    padding: 60px 6% 50px;
  }

  .epk-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 12px 0;
  }

  .epk-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 10px 0;
  }

  .epk-tagline {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 500;
    margin: 0 0 4px 0;
    color: rgba(255, 255, 255, 0.92);
  }

  .epk-subtagline {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* SECTION SHELL */
  .epk-section {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 40px;
  }

  .epk-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0 0 20px 0;
  }

  .epk-section p {
    font-weight: 200;
    line-height: 1.8;
    letter-spacing: 0.02em;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 16px 0;
  }

  .epk-section p:last-child {
    margin-bottom: 0;
  }

  /* MEDIA (image + text) */
  .epk-media {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 40px;
    align-items: center;
  }

  .epk-media-reverse {
    grid-template-columns: 1fr 340px;
  }

  .epk-media-reverse .epk-media-image {
    order: 2;
  }

  .epk-media-image {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 3px;
  }

  /* WORLD STAGES / DISCOGRAPHY layout */
  .epk-stages-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }

  .epk-stages-image {
    width: 100%;
    height: 100%;
    max-height: 560px;
    object-fit: cover;
    border-radius: 3px;
  }

  .epk-stage-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .epk-discography-title {
    grid-column: 1 / -1;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    margin: 0;
  }

  .epk-stage-card,
  .epk-label-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 3px;
    padding: 20px;
  }

  .epk-stage-card.epk-stage-tour {
    grid-column: 1 / -1;
  }

  .epk-stage-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 10px;
    font-size: 1rem;
  }

  .epk-stage-card h3,
  .epk-label-card h3 {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 8px 0;
  }

  .epk-stage-card p,
  .epk-label-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    font-weight: 300;
  }

  .epk-label-sub {
    color: rgba(255, 255, 255, 0.5) !important;
    font-size: 0.82rem !important;
    margin-bottom: 10px !important;
  }

  .epk-label-card p:not(:last-child) {
    margin-bottom: 10px !important;
  }

  .epk-label-tag {
    display: inline-block;
    background: #f4d03f;
    color: #000;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 2px;
  }

  .epk-stage-green { border-color: #4caf50; }
  .epk-stage-blue { border-color: #3b82c4; }
  .epk-stage-gold { border-color: #c9a13b; }
  .epk-stage-orange { border-color: #c4703b; }
  .epk-stage-tour { border-color: rgba(255, 255, 255, 0.2); }

  /* QUOTES */
  .epk-quote {
    margin: 0 0 18px 0;
    padding: 14px 18px;
    background: rgba(244, 208, 63, 0.1);
    border-left: 3px solid #f4d03f;
  }

  .epk-quote p {
    font-style: italic;
    margin: 0 0 6px 0 !important;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk-quote cite {
    font-style: normal;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* PRESS LIST */
  .epk-press-list {
    list-style: none;
    margin: 16px 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
  }

  .epk-press-list li {
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .epk-press-list strong {
    display: block;
    font-size: 0.85rem;
    color: #fff;
    margin-bottom: 2px;
  }

  .epk-press-list a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
  }

  .epk-press-list a:hover {
    color: #fff;
  }

  /* FEATURED SET */
  .epk-embed {
    width: 100%;
    border: none;
    display: block;
    border-radius: 3px;
  }

  /* GLOBAL AUDIENCE */
  .epk-audience-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 16px;
    margin: 20px 0;
  }

  .epk-audience-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 3px;
    aspect-ratio: 1 / 1;
  }

  .epk-audience-grid img:first-child {
    aspect-ratio: 2 / 1;
  }

