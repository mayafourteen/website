---
// EPK rebuilt to mirror the structure and visual richness of the live
// gamma EPK page (https://maya-fourteen-m50qvvw.gamma.site/) rather than
// V3InteriorLayout's single-column text format, which can't carry a
// full-bleed hero photo or card grids. Copy is sourced from that gamma
// page's real text, with a deliberate override: the two award names
// (corrected per project brief).
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import { pressItems } from '../../data/v3/pressItems.js';
import { discoverSocialLinks } from '../../data/v3/discoverSocialLinks.js';
import { images } from '../../data/v3/images.js';
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="Maya Fourteen electronic press kit: bio, credentials, world stages, discography and booking contact."
  bodyClass="page-epk"
  lang="en"
  languageHrefOverrides={{ en: '/v3/epk', pt: '/v3/epk-pt', es: '/v3/epk-es' }}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <HamburgerMenu lang="en" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, electronic press kit hero photo"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Electronic Press Kit</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">International DJ &amp; Producer</p>
        <p class="epk-subtagline">Award-Winning Electronic Artist</p>
      </div>
    </section>

    <!-- ARTIST OVERVIEW -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen performing behind the decks"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artist Overview</h2>
        <p>
          Maya Fourteen is a Brazilian electronic music artist known for a refined,
          narrative-driven approach to sound. She blends organic, progressive, and
          tech-driven elements with a strong melodic instinct, allowing her to adapt
          fluidly to different moods and environments.
        </p>
      </div>
    </section>

    <!-- GLOBAL PERFORMANCES -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen performing at Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Global Performances</h2>
        <p>
          MAYA has performed across key international circuits, building a reputation
          for confident performances in demanding environments. Her global presence
          reflects musical authority, adaptability, and the trust of diverse audiences
          across club, festival, and curated event settings.
        </p>
      </div>
    </section>

    <!-- SELECTED WORLD STAGES -->
    <section class="epk-section">
      <h2>Selected World Stages</h2>
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen performing at Greenvalley, Brazil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <span class="epk-stage-icon">🦋</span>
            <h3>Greenvalley Brazil 🇧🇷</h3>
            <p>5× #1 Club Worldwide, w/ Michael Bibi &amp; Beltran</p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <span class="epk-stage-icon">🌐</span>
            <h3>World Club Dome 🇩🇪</h3>
            <p>#1 Germany, Black Coffee &amp; Jamie Jones Stage</p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <span class="epk-stage-icon">🌙</span>
            <h3>Terra Solis Dubai 🇦🇪</h3>
            <p>Tomorrowland's desert club, w/ ANNA &amp; Antdot</p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <span class="epk-stage-icon">🏁</span>
            <h3>Formula 1</h3>
            <p>Abu Dhabi &amp; Monaco Grand Prix events</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <span class="epk-stage-icon">🌍</span>
            <h3>Europe, Middle East and Asia Tour</h3>
            <p>Gigs in London, Amsterdam, Lisbon, Bergen, Frankfurt, Cannes, Monaco, Ibiza, Dubai, Bali, plus key destinations in Thailand, Vietnam and Malaysia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- AWARD-WINNING ARTIST -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen accepting her award at IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Award-Winning Artist</h2>
        <p>
          MAYA is the recipient of <strong>a Future Talent Award at IMS Ibiza 2025, selected by
          Pete Tong</strong>, and the <strong>Nicole Moudaber Talent Highlight Prize</strong>. In 2023, she
          was selected from thousands of artists at the MixMasters Ibiza Get Signed
          Summit, with labels including Defected, Solid Grooves and Systematic among
          those involved, marking early industry validation.
        </p>
      </div>
    </section>

    <!-- INDUSTRY VOICES -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen with Clubbing TV at ADE"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Industry Voices</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;I would love to play with you one day!&rdquo;</p>
          <cite>Nicole Moudaber, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;She's the next big name. Keep an eye on her.&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;From now on, this is your home. The doors of Ibiza Sonica will always be open for you.&rdquo;</p>
          <cite>Karlos Sense, Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- MEDIA SPOTLIGHT -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen on the cover of Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Media Spotlight</h2>
        <p>
          MAYA was featured on the cover of Spain's Sync Beat Magazine in a special
          edition dedicated to the new generation of electronic music artists. The
          accompanying interview explores her artistic journey, influences, and
          creative vision, reflecting her growing international presence on the
          global electronic music circuit.
        </p>
        <ul class="epk-press-list">
          {pressItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- EDITORIAL RECOGNITION -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Gray Area editorial feature: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Editorial Recognition</h2>
        <p>
          MAYA was highlighted by US-based platform Gray Area as one of the Brazilian
          artists to watch in 2026, featured alongside Maz, Beltran, Antdot, and Aline
          Rocha. The selection reflects growing international attention around her
          work and positioning within today's global electronic music landscape.
        </p>
      </div>
    </section>

    <!-- DISCOGRAPHY -->
    <section class="epk-section">
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen in the studio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discography</h2>
          <div class="epk-label-card">
            <h3>Systematic Recordings 🇩🇪</h3>
            <p class="epk-label-sub">Marc Romboy's 20YRS label</p>
            <p>
              'Uniqueness' feat. Francesca Posgai: &ldquo;(&hellip;) A throwback to the
              golden era of House timeless vibes in the spirit of Mood II Swing
              (&hellip;)&rdquo; — Marc Romboy on Maya Fourteen's "Uniqueness".
            </p>
            <p class="epk-label-tag">TOP 10 Beatport, peaked at #8</p>
          </div>
          <div class="epk-label-card">
            <h3>VIVa MUSiC 🇬🇧</h3>
            <p class="epk-label-sub">Steve Lawler's esteemed imprint</p>
            <p>
              'Feel Better' EP, a two-track collaboration with Mario Franca
              (Bedrock | Selador) showcasing MAYA's versatility, moving from
              dream-like Deep House to a deeper, more driving Deep Tech edge.
            </p>
          </div>
          <div class="epk-label-card">
            <h3>Dioscuri Records 🇮🇹</h3>
            <p>
              MAYA's official remix for Costax's track 'Stay', released alongside
              additional remixes, including one by legendary Timo Maas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURED SET -->
    <section class="epk-section">
      <h2>Featured Set</h2>
      <iframe
        class="epk-embed"
        height="166"
        scrolling="no"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen/ancestral-mato-grosso-brazil&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
        title="Maya Fourteen: Ancestral (Mato Grosso, Brazil)"
        loading="lazy"
      ></iframe>
    </section>

    <!-- GLOBAL AUDIENCE & REACH -->
    <section class="epk-section">
      <h2>Global Audience &amp; Reach</h2>
      <p>
        MAYA's content on YouTube and SoundCloud has surpassed 300K plays, reaching
        listeners in over 100 countries through steady, organic growth. Her mixes
        stand out for technical precision, harmonic flow, refined taste, and a
        distinct storytelling identity, reflecting sustained international listener
        demand.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Map of Maya Fourteen's global listener reach" loading="lazy" />
        <img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen featured on Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" />
        <img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen performing at Greenvalley" loading="lazy" />
      </div>
      <p class="epk-audience-caption">
        Explore MAYA's catalogue and experience her musical language across
        different settings, moods, and contexts.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>High-resolution images available for promotional use. All photos copyright protected.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/epk-press-1.jpg" download><img src={images.epkPress1.src} width={images.epkPress1.width} height={images.epkPress1.height} alt="Maya Fourteen press photo 1" loading="lazy" /></a>
        <a href="/images/epk/epk-press-2.jpg" download><img src={images.epkPress2.src} width={images.epkPress2.width} height={images.epkPress2.height} alt="Maya Fourteen press photo 2" loading="lazy" /></a>
        <a href="/images/epk/epk-press-3.jpg" download><img src={images.epkPress3.src} width={images.epkPress3.width} height={images.epkPress3.height} alt="Maya Fourteen press photo 3" loading="lazy" /></a>
        <a href="/images/epk/epk-press-4.jpg" download><img src={images.epkPress4.src} width={images.epkPress4.width} height={images.epkPress4.height} alt="Maya Fourteen press photo 4" loading="lazy" /></a>
        <a href="/images/maya-landing.jpg" download><img src={images.landingColor.src} srcset={images.landingColor.srcset} sizes="(max-width: 768px) 45vw, 325px" width={images.landingColor.width} height={images.landingColor.height} alt="Maya Fourteen press photo, color" loading="lazy" /></a>
        <a href="/images/maya-landing-bw.jpg" download><img src={images.heroDefault.src} srcset={images.heroDefault.srcset} sizes="(max-width: 768px) 45vw, 325px" width={images.heroDefault.width} height={images.heroDefault.height} alt="Maya Fourteen press photo, black and white" loading="lazy" /></a>
      </div>
      <p class="epk-photo-credit">Photography: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
    </section>

    <!-- DISCOVER MAYA -->
    <section class="epk-section epk-discover">
      <h2>Discover MAYA</h2>
      <SocialNav links={discoverSocialLinks} />
    </section>

    <!-- BOOKING & MANAGEMENT -->
    <section class="epk-section epk-booking">
      <h2>Booking &amp; Management</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">For Bookings &amp; Artist Enquiries</p>
        <p class="epk-booking-name">Antonio Afonso, Management</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">Email hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Available for select private, club and festival bookings worldwide.
          International tours upon request. Full professional rider provided.
        </p>
      </div>
    </section>
  </main>
</V3BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-epk) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    background: #0a0a0a;
  }

  /* padding-left trimmed to 10px (from a symmetric 14px) for optical
     alignment against the hamburger's ink — see the full measurement
     writeup on the matching rule in V3HomeLayout.astro. */
  :global(.page-epk) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 4% 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* HERO */
  .epk-hero {
    position: relative;
    margin: 0 -4%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .epk-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .epk-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.85) 100%);
  }

  .epk-hero-text {
    position: relative;
    z-index: 1;
    padding: 60px 6% 50px;
  }

  .epk-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 12px 0;
  }

  .epk-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 10px 0;
  }

  .epk-tagline {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 500;
    margin: 0 0 4px 0;
    color: rgba(255, 255, 255, 0.92);
  }

  .epk-subtagline {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* SECTION SHELL */
  .epk-section {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 40px;
  }

  .epk-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0 0 20px 0;
  }

  .epk-section p {
    font-weight: 200;
    line-height: 1.8;
    letter-spacing: 0.02em;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 16px 0;
  }

  .epk-section p:last-child {
    margin-bottom: 0;
  }

  /* MEDIA (image + text) */
  .epk-media {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 40px;
    align-items: center;
  }

  .epk-media-reverse {
    grid-template-columns: 1fr 340px;
  }

  .epk-media-reverse .epk-media-image {
    order: 2;
  }

  .epk-media-image {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 3px;
  }

  /* WORLD STAGES / DISCOGRAPHY layout */
  .epk-stages-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }

  .epk-stages-image {
    width: 100%;
    height: 100%;
    max-height: 560px;
    object-fit: cover;
    border-radius: 3px;
  }

  .epk-stage-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .epk-discography-title {
    grid-column: 1 / -1;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    margin: 0;
  }

  .epk-stage-card,
  .epk-label-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 3px;
    padding: 20px;
  }

  .epk-stage-card.epk-stage-tour {
    grid-column: 1 / -1;
  }

  .epk-stage-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 10px;
    font-size: 1rem;
  }

  .epk-stage-card h3,
  .epk-label-card h3 {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 8px 0;
  }

  .epk-stage-card p,
  .epk-label-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    font-weight: 300;
  }

  .epk-label-sub {
    color: rgba(255, 255, 255, 0.5) !important;
    font-size: 0.82rem !important;
    margin-bottom: 10px !important;
  }

  .epk-label-card p:not(:last-child) {
    margin-bottom: 10px !important;
  }

  .epk-label-tag {
    display: inline-block;
    background: #f4d03f;
    color: #000;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 2px;
  }

  .epk-stage-green { border-color: #4caf50; }
  .epk-stage-blue { border-color: #3b82c4; }
  .epk-stage-gold { border-color: #c9a13b; }
  .epk-stage-orange { border-color: #c4703b; }
  .epk-stage-tour { border-color: rgba(255, 255, 255, 0.2); }

  /* QUOTES */
  .epk-quote {
    margin: 0 0 18px 0;
    padding: 14px 18px;
    background: rgba(244, 208, 63, 0.1);
    border-left: 3px solid #f4d03f;
  }

  .epk-quote p {
    font-style: italic;
    margin: 0 0 6px 0 !important;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk-quote cite {
    font-style: normal;
