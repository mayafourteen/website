---
// PT-BR counterpart of epk.astro — same structure/CSS, copy translated
// from the real PT gamma EPK page, with the same award-name override.
// See epk.astro for the full sourcing notes.
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import { pressItems } from '../../data/v3/pressItems.js';
import { discoverSocialLinks } from '../../data/v3/discoverSocialLinks.js';
import { images } from '../../data/v3/images.js';
---

<V3BaseLayout
  title="MAYA FOURTEEN | Mídia Kit"
  description="Mídia Kit de Maya Fourteen: biografia, credenciais, palcos mundiais, discografia e contato para booking."
  bodyClass="page-epk"
  lang="pt"
  languageHrefOverrides={{ en: '/v3/epk', pt: '/v3/epk-pt', es: '/v3/epk-es' }}
  hreflangAlternates={{ en: '/v3/epk', pt: '/v3/epk-pt', es: '/v3/epk-es' }}
  breadcrumbs={[{ name: 'Início', path: '/v3/page-pt' }, { name: 'Mídia Kit', path: '/v3/epk-pt' }]}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <HamburgerMenu lang="pt" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, foto de capa do mídia kit"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Mídia Kit</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ e Produtora Internacional</p>
        <p class="epk-subtagline">Artista Eletrônica Premiada</p>
      </div>
    </section>

    <!-- DNA ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen atrás dos equipamentos"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>DNA Artístico</h2>
        <p>
          MAYA é uma artista brasileira de música eletrônica, originária da Bacia
          Amazônica, com base entre a Europa e a América do Sul. Sua sonoridade
          percorre grooves deep, orgânicos, progressivos e tech, sustentados por uma
          forte intuição melódica e uma identidade artística bem definida.
        </p>
      </div>
    </section>

    <!-- PERFORMANCES GLOBAIS -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen se apresentando na Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Performances Globais</h2>
        <p>
          MAYA já se apresentou em mais de dez países, com passagens pela Europa,
          Oriente Médio, Ásia e América do Sul. Atua em clubes, festivais e eventos
          especiais, transitando com naturalidade de sunsets e formatos mais
          intimistas a grandes palcos.
        </p>
      </div>
    </section>

    <!-- PALCOS MUNDIAIS -->
    <section class="epk-section">
      <h2>Palcos Mundiais</h2>
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen se apresentando na Greenvalley, Brasil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/greenvalleybr/" target="_blank" rel="noopener">Greenvalley Brasil</a> 🇧🇷</h3>
            <p>5× Club nº1 do Mundo, c/ <a class="epk-inline-link" href="https://www.instagram.com/michael_bibi_/" target="_blank" rel="noopener">Michael Bibi</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a></p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/worldclubdome/" target="_blank" rel="noopener">World Club Dome</a> 🇩🇪</h3>
            <p>Maior festival da Alemanha, c/ <a class="epk-inline-link" href="https://www.instagram.com/realblackcoffee/" target="_blank" rel="noopener">Black Coffee</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/jamiejonesmusic/" target="_blank" rel="noopener">Jamie Jones</a></p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/terrasolisdubai/" target="_blank" rel="noopener">Terra Solis Dubai</a> 🇦🇪</h3>
            <p>Club do Tomorrowland no deserto, c/ <a class="epk-inline-link" href="https://www.instagram.com/anahitvardanyanofficial/" target="_blank" rel="noopener">ANNA</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a></p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <h3><a class="epk-inline-link" href="https://soundcloud.com/mayafourteen/maya-f1-after-race-recap" target="_blank" rel="noopener">Formula 1</a></h3>
            <p>Grandes prêmios de Abu Dhabi &amp; Mônaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <h3>Tour Europa, Oriente Médio e Ásia</h3>
            <p>Apresentações em cidades-chave como Londres, Amsterdã, Lisboa, Bergen, Frankfurt, Cannes, Mônaco, Ibiza, Dubai, Bali, Budapeste e Tóquio, além de destinos estratégicos na Tailândia, Vietnã e Malásia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA MULTIPREMIADA -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen recebendo seu prêmio no IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artista Multipremiada</h2>
        <p>
          MAYA é vencedora de <strong>um Future Talent Award no <a class="epk-inline-link" href="https://www.internationalmusicsummit.com/" target="_blank" rel="noopener">IMS</a> Ibiza 2025, selecionada
          por <a class="epk-inline-link" href="https://www.instagram.com/petetongofficial/" target="_blank" rel="noopener">Pete Tong</a></strong>, e recebeu o <strong><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a> Talent Highlight Prize</strong>.
          Também foi selecionada no <a class="epk-inline-link" href="https://www.mixmasters.net/" target="_blank" rel="noopener">MixMasters</a> Ibiza Get Signed Summit 2023, entre
          milhares de participantes, com envolvimento de selos como Defected, Solid
          Grooves e Systematic, uma validação precoce da indústria.
        </p>
      </div>
    </section>

    <!-- VOZES DO MERCADO -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen com a Clubbing TV na ADE"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Vozes do Mercado</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;Eu adoraria dividir a cabine com você um dia!&rdquo;</p>
          <cite>Nicole Moudaber, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;Ela é o próximo grande nome. Fiquem atentos!&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;MAYA, esta é a sua casa. As portas da Ibiza Sonica estarão sempre abertas para você.&rdquo;</p>
          <cite>Karlos Sense, Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- MÍDIA EM DESTAQUE -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen na capa da Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Mídia em Destaque</h2>
        <p>
          MAYA foi capa da revista espanhola Sync Beat, em uma edição especial
          dedicada à nova geração da música eletrônica. A publicação destacou sua
          presença internacional, performances em palcos relevantes e colaborações
          recentes, reforçando seu posicionamento no cenário eletrônico global.
        </p>
        <ul class="epk-press-list">
          {pressItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONHECIMENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Reportagem da Gray Area: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Reconhecimento Editorial</h2>
        <p>
          MAYA foi destacada pela plataforma norte-americana <a class="epk-inline-link" href="https://www.instagram.com/p/DTggbNBDb4H/" target="_blank" rel="noopener">Gray Area</a> como uma das
          artistas brasileiras a acompanhar em 2026, ao lado de <a class="epk-inline-link" href="https://www.instagram.com/mazmusic/" target="_blank" rel="noopener">Maz</a>, <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a>, <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a>
          e <a class="epk-inline-link" href="https://www.instagram.com/djalinerocha/" target="_blank" rel="noopener">Aline Rocha</a>. A seleção reflete a crescente atenção internacional em torno
          do seu trabalho e do seu posicionamento no atual cenário global da música
          eletrônica. Ela também gravou um set exclusivo para o <a class="epk-inline-link" href="https://soundcloud.com/entergrayarea/maya-fourteen-exclusive-set-for-ocho-by-gray-area-225" target="_blank" rel="noopener">OCHO by Gray Area</a>.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFIA -->
    <section class="epk-section">
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen no estúdio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografia</h2>
          <div class="epk-label-card">
            <h3><a class="epk-inline-link" href="https://www.systematic-recordings.com/" target="_blank" rel="noopener">Systematic Recordings</a> 🇩🇪</h3>
            <p class="epk-label-sub">Edição especial de 20 anos da label de <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a></p>
            <p>
              <a class="epk-inline-link" href="https://www.beatport.com/track/uniqueness-feat-francesca/19198825" target="_blank" rel="noopener">'Uniqueness'</a> feat. Francesca Posgai: &ldquo;(&hellip;) Um resgate
              elegante da era dourada do House, com a atemporalidade de Mood II Swing
              (&hellip;)&rdquo; — <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> sobre "Uniqueness".
            </p>
            <p class="epk-label-tag">TOP 10 Beatport, pico #8</p>
          </div>
          <div class="epk-label-card">
            <h3><a class="epk-inline-link" href="https://vivamusicltd.com/" target="_blank" rel="noopener">VIVa MUSiC</a> 🇬🇧</h3>
            <p class="epk-label-sub">Selo conceituado de <a class="epk-inline-link" href="https://www.instagram.com/djstevelawler/" target="_blank" rel="noopener">Steve Lawler</a></p>
            <p>
              'Feel Better' EP, colaboração de duas faixas com <a class="epk-inline-link" href="https://www.instagram.com/mario_f_franca/" target="_blank" rel="noopener">Mario Franca</a>
              (Bedrock | Selador), destacando a versatilidade de MAYA, indo do
              Organic House mais etéreo a uma identidade Deep Tech, intensa e
              pulsante.
            </p>
          </div>
          <div class="epk-label-card">
            <h3>Dioscuri Records 🇮🇹</h3>
            <p>
              Primeiro remix oficial de MAYA para 'Stay', faixa original de Costax,
              lançado junto a outros remixes, incluindo uma versão assinada pelo
              lendário <a class="epk-inline-link" href="https://www.instagram.com/timo.maas/" target="_blank" rel="noopener">Timo Maas</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SET EM DESTAQUE -->
    <section class="epk-section">
      <h2>Set em Destaque</h2>
      <iframe
        class="epk-embed"
        height="166"
        scrolling="no"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen/ancestral-mato-grosso-brazil&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
        title="Maya Fourteen: Ancestral (Mato Grosso, Brazil)"
        loading="lazy"
      ></iframe>
      <a class="epk-inline-link epk-video-link" href="/v3/video-sets-pt">Assistir aos sets em vídeo completos &rarr;</a>
    </section>

    <!-- ALCANCE GLOBAL E AUDIÊNCIA -->
    <section class="epk-section">
      <h2>Alcance Global e Audiência</h2>
      <p>
        O conteúdo da MAYA no <a class="epk-inline-link" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">SoundCloud</a> e no <a class="epk-inline-link" href="https://www.youtube.com/@MayaFourteen" target="_blank" rel="noopener">YouTube</a> (+300 mil plays) alcança
        ouvintes em mais de 100 países, com crescimento orgânico e engajamento
        consistente. Seus sets circulam globalmente entre públicos, plataformas e
        curadores, ampliando sua presença internacional além do circuito físico de
        apresentações.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Mapa do alcance global de ouvintes de Maya Fourteen" loading="lazy" />
        <img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen em destaque na Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" />
        <img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen se apresentando na Greenvalley" loading="lazy" />
      </div>
      <p class="epk-audience-caption">
        Explore os sets da MAYA nas principais plataformas.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imagens em alta resolução disponíveis para uso promocional. Todas as fotos são protegidas por direitos autorais.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/epk-press-3.jpg" download><img src={images.epkPress3.src} width={images.epkPress3.width} height={images.epkPress3.height} alt="Maya Fourteen em um retrato editorial de moda" loading="lazy" /></a>
        <a href="/images/epk/epk-world-stages.jpg" download><img src={images.epkWorldStages.src} srcset={images.epkWorldStages.srcset} sizes="(max-width: 768px) 45vw, 325px" width={images.epkWorldStages.width} height={images.epkWorldStages.height} alt="Maya Fourteen se apresentando na Greenvalley, Brasil" loading="lazy" /></a>
        <a href="/images/epk/epk-overview.jpg" download><img src={images.epkOverview.src} srcset={images.epkOverview.srcset} sizes="(max-width: 768px) 45vw, 325px" width={images.epkOverview.width} height={images.epkOverview.height} alt="Maya Fourteen atrás dos equipamentos" loading="lazy" /></a>
        <a href="/images/epk/epk-fendi.jpg" download><img src={images.epkFendi.src} srcset={images.epkFendi.srcset} sizes="(max-width: 768px) 45vw, 325px" width={images.epkFendi.width} height={images.epkFendi.height} alt="Maya Fourteen tocando em um evento da Fendi" loading="lazy" /></a>
      </div>
      <p class="epk-photo-credit">Fotografia: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
      <div class="epk-download-actions">
        <a class="cta-button" href="/downloads/MAYA-FOURTEEN-PRESS-PHOTOS.zip" download>Baixar Fotos de Imprensa</a>
        <a class="cta-button cta-button-outline" href="/downloads/MAYA-FOURTEEN-EPK-PT.pdf" download>Baixar Mídia Kit (PDF)</a>
      </div>
    </section>

    <!-- CONHEÇA MAYA -->
    <section class="epk-section epk-discover">
      <h2>Conheça MAYA</h2>
      <SocialNav links={discoverSocialLinks} />
    </section>

    <!-- BOOKING & MANAGEMENT -->
    <section class="epk-section epk-booking">
      <h2>Booking &amp; Management</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Para Bookings e Informações</p>
        <p class="epk-booking-name">Antonio Afonso, Management</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">Enviar e-mail para hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Disponível para bookings selecionados em clubes, festivais e eventos
          privados. Tours internacionais mediante solicitação. Rider profissional
          completo disponível.
        </p>
      </div>
    </section>
  </main>
</V3BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-epk) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    background: #0a0a0a;
  }

  /* padding-left trimmed to 10px (from a symmetric 14px) for optical
     alignment against the hamburger's ink — see the full measurement
     writeup on the matching rule in V3HomeLayout.astro. */
  :global(.page-epk) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 4% 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* HERO */
  .epk-hero {
    position: relative;
    margin: 0 -4%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .epk-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .epk-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.85) 100%);
  }

  .epk-hero-text {
    position: relative;
    z-index: 1;
    padding: 60px 6% 50px;
  }

  .epk-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 12px 0;
  }

  .epk-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 300;
