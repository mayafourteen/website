---
// PT-BR counterpart of epk.astro — same structure/CSS, copy translated
// from the real PT gamma EPK page, with the same award-name and Beatport
// overrides. See epk.astro for the full sourcing notes.
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import { pressItems } from '../../data/v3/pressItems.js';
import { socialLinks } from '../../data/v3/socialLinks.js';

const discoverLinks = socialLinks.filter((l) =>
  ['instagram', 'youtube', 'soundcloud', 'spotify'].includes(l.name)
);
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="EPK de Maya Fourteen — biografia, credenciais, palcos mundiais, discografia e contato para booking."
  bodyClass="page-epk"
  lang="pt"
  languageHrefOverrides={{ en: '/v3/epk', pt: '/v3/epk-pt', es: '/v3/epk-es' }}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <HamburgerMenu lang="pt" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img class="epk-hero-image" src="/images/epk/epk-hero.jpg" alt="Maya Fourteen" />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Press Kit Eletrônico</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ e Produtora Internacional</p>
        <p class="epk-subtagline">Artista Eletrônica Premiada</p>
      </div>
    </section>

    <!-- DNA ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-overview.jpg" alt="Maya Fourteen se apresentando" />
      <div class="epk-media-text">
        <h2>DNA Artístico</h2>
        <p>
          MAYA é uma artista brasileira de música eletrônica, originária da Bacia
          Amazônica, com base entre a Europa e a América do Sul. Sua sonoridade
          percorre grooves deep, orgânicos, progressivos e tech, sustentados por uma
          forte intuição melódica e uma identidade artística bem definida.
        </p>
      </div>
    </section>

    <!-- PERFORMANCES GLOBAIS -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-global-performances.jpg" alt="Maya Fourteen na Terra Solis Dubai" />
      <div class="epk-media-text">
        <h2>Performances Globais</h2>
        <p>
          MAYA já se apresentou em mais de dez países, com passagens pela Europa,
          Oriente Médio, Ásia e América do Sul. Atua em clubes, festivais e eventos
          especiais, transitando com naturalidade de sunsets e formatos mais
          intimistas a grandes palcos.
        </p>
      </div>
    </section>

    <!-- PALCOS MUNDIAIS -->
    <section class="epk-section">
      <h2>Palcos Mundiais</h2>
      <div class="epk-stages-layout">
        <img class="epk-stages-image" src="/images/epk/epk-world-stages.jpg" alt="Maya Fourteen na Greenvalley Brasil" />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <span class="epk-stage-icon">🦋</span>
            <h3>Greenvalley Brasil 🇧🇷</h3>
            <p>5× Club nº1 do Mundo, c/ Michael Bibi &amp; Beltran</p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <span class="epk-stage-icon">🌐</span>
            <h3>World Club Dome 🇩🇪</h3>
            <p>Maior festival da Alemanha, c/ Black Coffee &amp; Jamie Jones</p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <span class="epk-stage-icon">🌙</span>
            <h3>Terra Solis Dubai 🇦🇪</h3>
            <p>Club do Tomorrowland no deserto, c/ ANNA &amp; Antdot</p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <span class="epk-stage-icon">🏁</span>
            <h3>Formula 1</h3>
            <p>Grandes prêmios de Abu Dhabi &amp; Mônaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <span class="epk-stage-icon">🌍</span>
            <h3>Tour Europa, Oriente Médio e Ásia</h3>
            <p>Apresentações em cidades-chave como Londres, Amsterdã, Lisboa, Bergen, Frankfurt, Cannes, Mônaco, Ibiza, Dubai e Bali, além de destinos estratégicos na Tailândia, Vietnã e Malásia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA MULTIPREMIADA -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-award.jpg" alt="Maya Fourteen no IMS Ibiza 2025" />
      <div class="epk-media-text">
        <h2>Artista Multipremiada</h2>
        <p>
          MAYA é vencedora do <strong>Future Talent Award do IMS Ibiza 2025, selecionada
          por Pete Tong</strong>, e recebeu o <strong>Nicole Moudaber Talent Highlight Prize</strong>.
          Também foi selecionada no MixMasters Ibiza Get Signed Summit 2023, entre
          milhares de participantes, com envolvimento de selos como Defected, Solid
          Grooves e Systematic — uma validação precoce da indústria.
        </p>
      </div>
    </section>

    <!-- VOZES DO MERCADO -->
    <section class="epk-section epk-media epk-media-reverse">
      <img class="epk-media-image" src="/images/epk/epk-industry-voices.jpg" alt="Maya Fourteen com a Clubbing TV na ADE" />
      <div class="epk-media-text">
        <h2>Vozes do Mercado</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;Eu adoraria dividir a cabine com você um dia!&rdquo;</p>
          <cite>Nicole Moudaber — IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;Ela é o próximo grande nome. Fiquem atentos!&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV — ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;MAYA, esta é a sua casa. As portas da Ibiza Sonica estarão sempre abertas para você.&rdquo;</p>
          <cite>Karlos Sense — Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- MÍDIA EM DESTAQUE -->
    <section class="epk-section epk-media">
      <img class="epk-media-image" src="/images/epk/epk-media-spotlight.jpg" alt="Maya Fourteen na capa da Sync Beat Magazine" />
      <div class="epk-media-text">
        <h2>Mídia em Destaque</h2>
        <p>
          MAYA foi capa da revista espanhola Sync Beat, em uma edição especial
          dedicada à nova geração da música eletrônica. A publicação destacou sua
          presença internacional, performances em palcos relevantes e colaborações
          recentes, reforçando seu posicionamento no cenário eletrônico global.
        </p>
        <ul class="epk-press-list">
          {pressItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONHECIMENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img class="epk-media-image" src="/images/epk/epk-editorial.jpg" alt="Gray Area: Brazilian DJs You Must Know For 2026" />
      <div class="epk-media-text">
        <h2>Reconhecimento Editorial</h2>
        <p>
          MAYA foi destacada pela plataforma norte-americana Gray Area como uma das
          artistas brasileiras a acompanhar em 2026, ao lado de Maz, Beltran, Antdot
          e Aline Rocha. A seleção reflete a crescente atenção internacional em torno
          do seu trabalho e do seu posicionamento no atual cenário global da música
          eletrônica.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFIA -->
    <section class="epk-section">
      <div class="epk-stages-layout">
        <img class="epk-stages-image" src="/images/epk/epk-discography.jpg" alt="Maya Fourteen no estúdio" />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografia</h2>
          <div class="epk-label-card">
            <h3>Systematic Records 🇩🇪</h3>
            <p class="epk-label-sub">Edição especial de 20 anos da label de Marc Romboy</p>
            <p>
              'Uniqueness' feat. Francesca Posgai — &ldquo;(&hellip;) Um resgate
              elegante da era dourada do House, com a atemporalidade de Mood II Swing
              (&hellip;)&rdquo; — Marc Romboy sobre "Uniqueness".
            </p>
            <p class="epk-label-tag">TOP 10 no Beatport</p>
          </div>
          <div class="epk-label-card">
            <h3>VIVa MUSiC 🇬🇧</h3>
            <p class="epk-label-sub">Selo conceituado de Steve Lawler</p>
            <p>
              'Feel Better' EP – colaboração de duas faixas com Mario Franca
              (Bedrock | Selador), destacando a versatilidade de MAYA, indo do
              Organic House mais etéreo a uma identidade Deep Tech, intensa e
              pulsante.
            </p>
          </div>
          <div class="epk-label-card">
            <h3>Dioscuri Records 🇮🇹</h3>
            <p>
              Primeiro remix oficial de MAYA para 'Stay', faixa original de Costax,
              lançado junto a outros remixes, incluindo uma versão assinada pelo
              lendário Timo Maas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SET EM DESTAQUE -->
    <section class="epk-section">
      <h2>Set em Destaque</h2>
      <iframe
        class="epk-embed"
        height="166"
        scrolling="no"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen/ancestral-mato-grosso-brazil&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
        title="Maya Fourteen — Ancestral (Mato Grosso, Brazil)"
        loading="lazy"
      ></iframe>
    </section>

    <!-- ALCANCE GLOBAL E AUDIÊNCIA -->
    <section class="epk-section">
      <h2>Alcance Global e Audiência</h2>
      <p>
        O conteúdo da MAYA no SoundCloud e no YouTube (+300 mil plays) alcança
        ouvintes em mais de 100 países, com crescimento orgânico e engajamento
        consistente. Seus sets circulam globalmente entre públicos, plataformas e
        curadores, ampliando sua presença internacional além do circuito físico de
        apresentações.
      </p>
      <div class="epk-audience-grid">
        <img src="/images/epk/epk-audience-map.jpg" alt="Alcance global de ouvintes de Maya Fourteen" />
        <img src="/images/epk/epk-audience-radio.jpg" alt="Maya Fourteen em destaque na Gray Area / Diplo's Revolution / SiriusXM" />
        <img src="/images/epk/epk-audience-greenvalley.jpg" alt="Maya Fourteen na Greenvalley" />
      </div>
      <p class="epk-audience-caption">
        Explore os sets da MAYA nas principais plataformas.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imagens em alta resolução disponíveis para uso promocional. Todas as fotos são protegidas por direitos autorais.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/epk-press-1.jpg" download><img src="/images/epk/epk-press-1.jpg" alt="Foto de imprensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-2.jpg" download><img src="/images/epk/epk-press-2.jpg" alt="Foto de imprensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-3.jpg" download><img src="/images/epk/epk-press-3.jpg" alt="Foto de imprensa de Maya Fourteen" /></a>
        <a href="/images/epk/epk-press-4.jpg" download><img src="/images/epk/epk-press-4.jpg" alt="Foto de imprensa de Maya Fourteen" /></a>
        <a href="/images/maya-landing.jpg" download><img src="/images/maya-landing.jpg" alt="Foto de imprensa de Maya Fourteen" /></a>
        <a href="/images/maya-landing-bw.jpg" download><img src="/images/maya-landing-bw.jpg" alt="Foto de imprensa de Maya Fourteen, preto e branco" /></a>
      </div>
    </section>

    <!-- CONHEÇA MAYA -->
    <section class="epk-section epk-discover">
      <h2>Conheça MAYA</h2>
      <SocialNav links={discoverLinks} />
    </section>

    <!-- BOOKING & MANAGEMENT -->
    <section class="epk-section epk-booking">
      <h2>Booking &amp; Management</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Para Bookings e Informações</p>
        <p class="epk-booking-name">Antonio Afonso — Management</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">Enviar e-mail para hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Disponível para bookings selecionados em clubes, festivais e eventos
          privados. Tours internacionais mediante solicitação. Rider profissional
          completo disponível.
        </p>
      </div>
    </section>
  </main>
</V3BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-epk) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    background: #0a0a0a;
  }

  :global(.page-epk) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 4% 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* HERO */
  .epk-hero {
    position: relative;
    margin: 0 -4%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .epk-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .epk-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.85) 100%);
  }

  .epk-hero-text {
    position: relative;
    z-index: 1;
    padding: 60px 6% 50px;
  }

  .epk-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 12px 0;
  }

  .epk-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 300;
    margin: 0 0 10px 0;
  }

  .epk-tagline {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 500;
    margin: 0 0 4px 0;
    color: rgba(255, 255, 255, 0.92);
  }

  .epk-subtagline {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* SECTION SHELL */
  .epk-section {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 40px;
  }

  .epk-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0 0 20px 0;
  }

  .epk-section p {
    font-weight: 200;
    line-height: 1.8;
    letter-spacing: 0.02em;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 16px 0;
  }

  .epk-section p:last-child {
    margin-bottom: 0;
  }

  /* MEDIA (image + text) */
  .epk-media {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 40px;
    align-items: center;
  }

  .epk-media-reverse {
    grid-template-columns: 1fr 340px;
  }

  .epk-media-reverse .epk-media-image {
    order: 2;
  }

  .epk-media-image {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 3px;
  }

  /* WORLD STAGES / DISCOGRAPHY layout */
  .epk-stages-layout {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }

  .epk-stages-image {
    width: 100%;
    height: 100%;
    max-height: 560px;
    object-fit: cover;
    border-radius: 3px;
  }

  .epk-stage-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .epk-discography-title {
    grid-column: 1 / -1;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    margin: 0;
  }

  .epk-stage-card,
  .epk-label-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 3px;
    padding: 20px;
  }

  .epk-stage-card.epk-stage-tour {
    grid-column: 1 / -1;
  }

  .epk-stage-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 10px;
    font-size: 1rem;
  }

  .epk-stage-card h3,
  .epk-label-card h3 {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 8px 0;
  }

  .epk-stage-card p,
  .epk-label-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    font-weight: 300;
  }

  .epk-label-sub {
    color: rgba(255, 255, 255, 0.5) !important;
    font-size: 0.82rem !important;
    margin-bottom: 10px !important;
  }

  .epk-label-card p:not(:last-child) {
    margin-bottom: 10px !important;
  }

  .epk-label-tag {
    display: inline-block;
    background: #f4d03f;
    color: #000;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 2px;
  }

  .epk-stage-green { border-color: #4caf50; }
  .epk-stage-blue { border-color: #3b82c4; }
  .epk-stage-gold { border-color: #c9a13b; }
  .epk-stage-orange { border-color: #c4703b; }
  .epk-stage-tour { border-color: rgba(255, 255, 255, 0.2); }

  /* QUOTES */
  .epk-quote {
    margin: 0 0 18px 0;
    padding: 14px 18px;
    background: rgba(244, 208, 63, 0.1);
    border-left: 3px solid #f4d03f;
  }

  .epk-quote p {
    font-style: italic;
    margin: 0 0 6px 0 !important;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk-quote cite {
    font-style: normal;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* PRESS LIST */
  .epk-press-list {
    list-style: none;
    margin: 16px 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
  }

  .epk-press-list li {
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .epk-press-list strong {
    display: block;
    font-size: 0.85rem;
    color: #fff;
    margin-bottom: 2px;
  }

  .epk-press-list a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
  }

  .epk-press-list a:hover {
    color: #fff;
  }

  /* FEATURED SET */
  .epk-embed {
    width: 100%;
    border: none;
    display: block;
    border-radius: 3px;
  }

  /* GLOBAL AUDIENCE */
  .epk-audience-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 16px;
    margin: 20px 0;
  }

  .epk-audience-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 3px;
    aspect-ratio: 1 / 1;
  }

  .epk-audience-grid img:first-child {
    aspect-ratio: 2 / 1;
  }

  .epk-audience-caption {
    font-style: italic;
    color: rgba(255, 255, 255, 0.6) !important;
  }

  /* PRESS PHOTOS */
  .epk-photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 20px;
  }

  .epk-photo-grid a {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 3px;
    position: relative;
  }

  .epk-photo-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

