---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import { pressItems } from '../../data/v3/pressItems.js';
---

<V3InteriorLayout
  title="Press & Media"
  eyebrow="Why the industry is paying attention"
  description="Maya Fourteen has been featured across international electronic music media platforms."
  heroImage="/images/epk/epk-hero.jpg"
  hasEsSibling
>
  <p>
    Maya Fourteen has been featured across international electronic music media platforms.
  </p>

  <ul class="link-list">
    {pressItems.map((item) => (
      <li>
        <strong>{item.outlet}</strong>
        <a href={item.href} target="_blank">{item.label}</a>
      </li>
    ))}
  </ul>
</V3InteriorLayout>
