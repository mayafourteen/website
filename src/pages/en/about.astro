---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
---

<V3InteriorLayout
  title="About"
  eyebrow="Who is Maya"
  description="Discover the biography, sound and international career of award-winning electronic music artist Maya Fourteen."
  hasEsSibling
>
  <p>
    Award-winning Brazilian electronic music artist Maya Fourteen moves seamlessly across genres,
    shaping sound through performance, production and curation. Her work has built a strong
    international audience and carries depth and unmistakable taste.
  </p>
  <p>
    Maya has been a musician since childhood. That shaped her ear, resulting in emotionally
    driven, story-telling sets, capable of blending deep, tech, organic and progressive elements
    into evolving journeys that pull you in, and grow on you.
  </p>
  <p>
    Born where the Amazon Basin begins, in Mato Grosso, and now based between Europe and South
    America, she has performed around the world, in major capital cities and key electronic
    music destinations, with releases on respected electronic music labels.
  </p>

  <a class="read-on" href="/en/epk"><span class="read-on-bracket">[</span> explore <span class="read-on-bracket">]</span></a>
</V3InteriorLayout>

<style>
  /* Scoped to this page's own <p> tags (Astro scopes styles to the file
     that literally writes the markup, not the receiving V3InteriorLayout
     slot) — so this can't leak into Press/Audio Sets/Video Sets/Book,
     which share the same layout but should stay left-aligned. */
  p {
    text-align: justify;
  }

  /* Quiet "continue into the EPK" link, sits below the intro as an
     invitation rather than a hard button. Serif to echo the page title,
     lightly tracked, brightens and eases open on hover. */
  .read-on {
    display: block;
    text-align: center;
    margin-top: 36px;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    color: #d9a96a;
    text-decoration: none;
    transition: color 0.3s ease, letter-spacing 0.3s ease;
    /* Enters exactly like the landing page's [ enter ]: same smoothReveal
       fade (opacity + blur + translateY), 1.9s start, 2.2s duration, then
       the breathing pulse picks up at 4.1s once the reveal has landed. */
    opacity: 0;
    animation:
      smoothReveal 2.2s cubic-bezier(0.19, 1, 0.22, 1) 1.9s forwards,
      readOnBreathe 3s ease-in-out 4.1s infinite;
  }

  .read-on:hover,
  .read-on:focus-visible {
    color: #fff;
    letter-spacing: 0.09em;
  }

  /* Bracket glyphs shrunk and nudged to hug the word, mirroring the
     landing page's [ enter ] treatment so the two invitations read as the
     same gesture. */
  .read-on-bracket {
    display: inline-block;
    font-size: 0.72em;
    vertical-align: 0.09em;
  }

  @keyframes readOnBreathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @media (max-width: 768px) {
    p {
      text-align: left;
    }
  }
</style>
