---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
---

<V3InteriorLayout
  title="About"
  eyebrow="Who is Maya"
  description="Discover the biography, sound and international career of award-winning electronic music artist Maya Fourteen."
  hasEsSibling
>
  <p>
    Maya Fourteen is a Brazilian DJ, producer and curator, born where the Amazon Basin begins, in
    Mato Grosso, and now based between Europe and South America.
  </p>
  <p>
    She found her purpose in electronic music in 2020, and in 2025 won a Future Talent Award at
    IMS Ibiza. She has released on labels such as Marc Romboy's Systematic Recordings and played
    from Green Valley, five times voted the world's number one club, to major capitals across
    three continents and more than fifteen countries.
  </p>
  <p>
    Her sets move across deep, tech, organic and progressive, emotionally driven and
    story-telling, journeys that grow on you.
  </p>

  <a class="read-on" href="/en/epk">Read on &rarr;</a>
</V3InteriorLayout>

<style>
  /* Scoped to this page's own <p> tags (Astro scopes styles to the file
     that literally writes the markup, not the receiving V3InteriorLayout
     slot) — so this can't leak into Press/Audio Sets/Video Sets/Book,
     which share the same layout but should stay left-aligned. */
  p {
    text-align: justify;
  }

  /* Quiet "continue into the EPK" link, sits below the intro as an
     invitation rather than a hard button. Serif to echo the page title,
     lightly tracked, brightens and eases open on hover. */
  .read-on {
    display: inline-block;
    margin-top: 10px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.3s ease, letter-spacing 0.3s ease;
  }

  .read-on:hover,
  .read-on:focus-visible {
    color: #fff;
    letter-spacing: 0.2em;
  }

  @media (max-width: 768px) {
    p {
      text-align: left;
    }
  }
</style>
