---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
---

<V3InteriorLayout
  title="About"
  eyebrow="Who is Maya"
  description="Discover the biography, sound and international career of award-winning electronic music artist Maya Fourteen."
  hasEsSibling
>
  <p>
    Award-winning electronic music artist Maya Fourteen moves fluidly across genres, shaping sound
    through performance, production and curation. With a strong international following and
    performances on respected stages worldwide, her presence carries depth and unmistakable taste.
  </p>
  <p>
    Born where the Amazon Basin begins, in Mato Grosso, Brazil, and now based between Europe and
    South America, Maya is known for sets that are emotionally driven and story-telling, blending
    deep, tech, organic and progressive elements into journeys that grow on you.
  </p>
  <p>
    Her work spans releases on renowned international labels and performances across three
    continents and over fifteen countries.
  </p>

  <a class="read-on" href="/en/epk">Read on &rarr;</a>
</V3InteriorLayout>

<style>
  /* Scoped to this page's own <p> tags (Astro scopes styles to the file
     that literally writes the markup, not the receiving V3InteriorLayout
     slot) — so this can't leak into Press/Audio Sets/Video Sets/Book,
     which share the same layout but should stay left-aligned. */
  p {
    text-align: justify;
  }

  /* Quiet "continue into the EPK" link, sits below the intro as an
     invitation rather than a hard button. Serif to echo the page title,
     lightly tracked, brightens and eases open on hover. */
  .read-on {
    display: inline-block;
    margin-top: 10px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.3s ease, letter-spacing 0.3s ease;
  }

  .read-on:hover,
  .read-on:focus-visible {
    color: #fff;
    letter-spacing: 0.2em;
  }

  @media (max-width: 768px) {
    p {
      text-align: left;
    }
  }
</style>
