---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterSignup from '../../components/v3/NewsletterSignup.astro';
---

{/* Unlisted newsletter landing page: not in any menu, shared directly
    (IG stories, link-in-bio). Background: the "safe" photo, b&w. */}
<V3InteriorLayout
  title="Subscribe"
  eyebrow="The inner circle"
  description="Every new set and video set reaches this list before it goes public. Release news, dates and private invitations that never make it to social media."
  hasEsSibling
  heroImage="/images/subscribe-hero-safe.webp"
  heroImageAlt="Maya Fourteen opening a vault door"
>
  <p>
    Every new set and video set reaches this list before it goes public. Release news, dates and private invitations that never make it to social media.
  </p>
  <p>
    One email when something matters. No noise, ever. Leave with one click whenever you want.
  </p>
  <p class="subscribe-close">Join the inner circle:</p>

  <NewsletterSignup lang="en" formOnly />
</V3InteriorLayout>

<style>
  p {
    text-align: center;
  }

  .subscribe-close {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15em !important;
    color: rgba(255, 255, 255, 0.9) !important;
    margin-top: 30px !important;
  }

  /* Desktop composition: Maya stands on the left of the photo, so the
     whole text column moves to the right, over the dark door, and
     left-aligns. She owns the light, the words own the shadow. Phones
     keep the centered stack (the photo's sides crop away there). */
  @media (min-width: 900px) {
    :global(.page-v2-interior .content-wrapper) {
      max-width: 470px !important;
      margin-right: 4% !important;
      margin-left: auto !important;
      text-align: left !important;
    }

    :global(.page-v2-interior .eyebrow),
    :global(.page-v2-interior .page-title) {
      text-align: left !important;
    }

    p,
    .subscribe-close {
      text-align: left;
    }
  }
</style>
