---
// Self-hosted fonts (fontsource, bundled locally): removes the two
// Google Fonts round-trips from the critical path and the GDPR gray zone
// of shipping visitor IPs to Google. Same families/weights as before.
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/inter/200.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
// EPK rebuilt to mirror the structure and visual richness of the live
// gamma EPK page (https://maya-fourteen-m50qvvw.gamma.site/) rather than
// V3InteriorLayout's single-column text format, which can't carry a
// full-bleed hero photo or card grids. Copy is sourced from that gamma
// page's real text, with a deliberate override: the two award names
// (corrected per project brief).
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import TextFooter from '../../components/v3/TextFooter.astro';
import BackToTop from '../../components/v3/BackToTop.astro';
import { discoverSocialLinks } from '../../data/v3/discoverSocialLinks.js';
import { images } from '../../data/v3/images.js';

// EPK-only Media Spotlight list — deliberately separate from pressItems.js
// (the /press page's own list): different order, drops the plain "Sync
// Beat Magazine" entry in favor of its Cover counterpart, and adds a Gray
// Area (US) entry whose label is localized per language (unlike every
// other entry here, which stays English across all three EPK pages,
// matching the site's established pattern for outlet labels).
const mediaSpotlightItems = [
  { outlet: 'DJ Mag LATAM', href: 'https://djmagla.com/conoce-a-maya-fourteen-la-artista-brasilena-que-esta-llevando-su-talento-a-nuevos-lugares-del-mundo', label: 'Read article' },
  { outlet: 'Mixmag Brazil', href: 'https://mixmag.com.br/feature/conheca-maya-fourteen-artista-brasileira-reconhecida-por-nicole-moudaber-e-pete-tong', label: 'Read article' },
  { outlet: 'Sync Beat Magazine Cover', href: 'https://music.beepd.co/card/syncbeatmagazine', label: 'View cover feature' },
  { outlet: 'Clubbing TV', href: 'https://clubbingtv.com/shows/view/5593/lds-with-maya-fourteen-ade-2023-spaces/', label: 'Watch feature' },
  { outlet: 'Gray Area (US)', href: 'https://www.instagram.com/p/DTggbNBDb4H/', label: 'VIEW FEATURE' },
  { outlet: 'Play BPM', href: 'https://playbpm.com.br/colunas/play-bpm-indica/maya/', label: 'Read article' },
  { outlet: 'Alataj', href: 'https://alataj.com.br/15-to-understand/maya', label: 'Read article' },
  { outlet: 'EKM', href: 'https://ekm.co/maya-fourteen-uniqueness/', label: 'Read review' },
];
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="Download the official electronic press kit for award-winning artist Maya Fourteen, featuring her bio, credentials, world stages and discography."
  bodyClass="page-epk"
  lang="en"
  languageHrefOverrides={{ en: '/en/epk', pt: '/pt/epk', es: '/es/epk' }}
  hreflangAlternates={{ en: '/en/epk', pt: '/pt/epk', es: '/es/epk' }}
  breadcrumbs={[{ name: 'Home', path: '/en' }, { name: 'EPK', path: '/en/epk' }]}
>
  <Fragment slot="head">
    <!-- media="print" + onload swap takes this off the render-blocking path
         — same CSS applies once loaded, only the paint-timing changes.
         noscript fallback covers the no-JS case. -->
    <noscript></noscript>
  </Fragment>

  <HamburgerMenu lang="en" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, electronic press kit hero photo"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Electronic Press Kit</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">International DJ &amp; Producer</p>
        <p class="epk-subtagline">Award-Winning Electronic Artist</p>
      </div>
    </section>

    <!-- ARTIST OVERVIEW -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen performing behind the decks"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artist Overview</h2>
        <p>
          Maya Fourteen is a Brazilian electronic music artist known for a refined,
          narrative-driven approach to sound. She blends organic, progressive, and
          tech-driven elements with a strong melodic instinct, allowing her to adapt
          fluidly to different moods and environments.
        </p>
        <blockquote class="epk-artist-quote">
          <p>"I love to adapt to the environment, the time of day, the energy in the room. The palette changes, but the identity remains." <cite>Maya Fourteen</cite></p>
        </blockquote>
      </div>
    </section>

    <!-- GLOBAL PERFORMANCES -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen performing at Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Global Performances</h2>
        <p>
          MAYA has performed across key international circuits, building a reputation
          for confident performances in demanding environments. Her global presence
          reflects musical authority, adaptability, and the trust of diverse audiences
          across club, festival, and curated event settings.
        </p>
      </div>
    </section>

    <!-- SELECTED WORLD STAGES -->
    <section class="epk-section">
      <h2>Selected World Stages</h2>
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen performing at Greenvalley, Brazil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/greenvalleybr/" target="_blank" rel="noopener">Greenvalley Brazil</a> 🇧🇷</h3>
            <p>5× #1 Club Worldwide, with <a class="epk-inline-link" href="https://www.instagram.com/michael_bibi_/" target="_blank" rel="noopener">Michael Bibi</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a></p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/worldclubdome/" target="_blank" rel="noopener">World Club Dome</a> 🇩🇪</h3>
            <p>Germany's biggest festival, with <a class="epk-inline-link" href="https://www.instagram.com/jamiejonesmusic/" target="_blank" rel="noopener">Jamie Jones</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/hotsince82/" target="_blank" rel="noopener">Hot Since 82</a></p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/terrasolisdubai/" target="_blank" rel="noopener">Terra Solis Dubai</a> 🇦🇪</h3>
            <p>Tomorrowland's desert club, with <a class="epk-inline-link" href="https://www.instagram.com/anahitvardanyanofficial/" target="_blank" rel="noopener">ANNA</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a></p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <h3><a class="epk-inline-link" href="https://soundcloud.com/mayafourteen/maya-f1-after-race-recap" target="_blank" rel="noopener">Formula 1</a> &#127937;</h3>
            <p>Private after-parties at the Abu Dhabi &amp; Monaco Grands Prix</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <h3>Europe, Middle East and Asia Tour &#129705;</h3>
            <p>Performing across three continents, with highlights in London, Amsterdam, Lisbon, Frankfurt, Ibiza, Cannes, Monaco, Budapest, Dubai, Tokyo, Bangkok, Kuala Lumpur and Bali, MAYA continues to consolidate her presence in electronic music's leading markets.</p>
          </div>
          <p class="epk-setstories">Set stories: <a class="epk-inline-link" href="/en/sets/greenvalley">Greenvalley</a> &middot; <a class="epk-inline-link" href="/en/sets/sls-dubai">SLS Dubai</a> &middot; <a class="epk-inline-link" href="/en/sets/amazon-basin">Amazon Basin</a> &middot; <a class="epk-inline-link" href="/en/sets/fendi-yachthouse">FENDI Yachthouse</a></p>
        </div>
      </div>
    </section>

    <!-- AWARD-WINNING ARTIST -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen accepting her award at IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Award-Winning Artist</h2>
        <p>
          MAYA is the winner of <strong>a prestigious Future Talent Award at <a class="epk-inline-link" href="https://www.internationalmusicsummit.com/" target="_blank" rel="noopener">IMS</a> Ibiza 2025, selected by
          <a class="epk-inline-link" href="https://www.instagram.com/petetongofficial/" target="_blank" rel="noopener">Pete Tong</a></strong>, and recipient of the <strong><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a> Talent Highlight Prize</strong>, a personal distinction from one of the most respected voices in the industry.
        </p>
        <p>
          At the MixMasters Ibiza Summit 2023, she was selected among thousands of artists worldwide, in a
          process curated by labels such as <a class="epk-inline-link" href="https://www.instagram.com/defectedrecords/" target="_blank" rel="noopener">Defected</a>, <a class="epk-inline-link" href="https://www.instagram.com/solidgroovesuk/" target="_blank" rel="noopener">Solid Grooves</a> and <a class="epk-inline-link" href="https://www.instagram.com/systematicrecordings/" target="_blank" rel="noopener">Systematic</a>.
          It was there that <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> first heard her work, the encounter that would lead to her debut on Systematic Recordings.
        </p>
      </div>
    </section>

    <!-- INDUSTRY VOICES -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image epk-media-image--voices"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen interviewed by Laureline Teste of Clubbing TV on a rooftop"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Industry Voices</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;She's the next big name. Keep an eye on her.&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;I would love to play with you one day!&rdquo;</p>
          <cite>Nicole Moudaber, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;From now on, this is your home. The doors of Ibiza Sonica will always be open for you.&rdquo;</p>
          <cite>Karlos Sense, Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- BOOKING CTA (mid-page, after the proof) -->
    <section class="epk-section epk-bookband">
      <p class="epk-bookband-line">Available for club, festival and select private bookings worldwide.</p>
      <a class="epk-bookband-cta" href="#get-in-touch">[ book maya ]</a>
    </section>

    <!-- MEDIA SPOTLIGHT -->
    <section class="epk-section epk-media epk-media-spotlight">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 480px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen on the cover of Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Media Spotlight</h2>
        <p>
          MAYA was featured on the cover of Spain's Sync Beat Magazine in a special
          edition dedicated to the new generation of electronic music artists. The
          accompanying interview explores her artistic journey, influences, and
          creative vision, reflecting her growing international presence on the
          global electronic music circuit.
        </p>
        <ul class="epk-press-list">
          {mediaSpotlightItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- EDITORIAL RECOGNITION -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Gray Area editorial feature: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Editorial Recognition</h2>
        <p>
          MAYA was highlighted by US-based platform <a class="epk-inline-link" href="https://grayarea.co" target="_blank" rel="noopener">Gray Area</a> as one of the Brazilian
          artists to watch in 2026, featured alongside <a class="epk-inline-link" href="https://www.instagram.com/mazmusic/" target="_blank" rel="noopener">Maz</a>, <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a>, <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a>, and <a class="epk-inline-link" href="https://www.instagram.com/djalinerocha/" target="_blank" rel="noopener">Aline
          Rocha</a>. The selection reflects growing international attention around her
          work and positioning within today's global electronic music landscape.
        </p>
      </div>
    </section>

    <!-- DISCOGRAPHY -->
    <section class="epk-section">
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen in the studio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discography</h2>
          <div class="epk-discography-layout">
            <div class="epk-label-card">
              <h3><a class="epk-inline-link" href="https://www.systematic-recordings.com/" target="_blank" rel="noopener">Systematic Recordings</a> 🇩🇪</h3>
              <p class="epk-label-sub"><a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a>'s iconic label</p>
              <p>
                MAYA's debut single <a class="epk-inline-link" href="https://www.beatport.com/track/uniqueness-feat-francesca/19198825" target="_blank" rel="noopener">'Uniqueness'</a>, featuring spoken word vocals by Francesca Posgai, was handpicked by <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> for the 20th anniversary album of Systematic Recordings, released alongside Carl Cox, Josh Wink, Rodriguez Jr. and Gui Boratto, to name a few.
              </p>
              <p>
                Romboy first heard the track at the Ibiza Summit and instantly fell in love with its distinctive sound and empowering energy: &ldquo;It's a throwback to the golden era of House, evoking timeless vibes akin to Mood II Swing.&rdquo;
              </p>
              <p class="epk-label-tag">TOP 10 Beatport, peaked at #8</p>
            </div>
            <div class="epk-discography-side">
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://vivamusicltd.com/" target="_blank" rel="noopener">VIVa MUSiC</a> 🇬🇧</h3>
                <p class="epk-label-sub"><a class="epk-inline-link" href="https://www.instagram.com/djstevelawler/" target="_blank" rel="noopener">Steve Lawler</a>'s esteemed imprint</p>
                <p>
                  'Feel Better' EP, a two-track collaboration with <a class="epk-inline-link" href="https://www.instagram.com/mario_f_franca/" target="_blank" rel="noopener">Mario Franca</a>
                  (<a class="epk-inline-link" href="https://bedrock.org.uk/" target="_blank" rel="noopener">Bedrock</a> | <a class="epk-inline-link" href="https://seladorrecordings.com/" target="_blank" rel="noopener">Selador</a>) showcasing MAYA's versatility, moving from
                  dream-like Deep House to a deeper, more driving Deep Tech edge.
                </p>
              </div>
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://www.instagram.com/dioscurirecords/" target="_blank" rel="noopener">Dioscuri Records</a> 🇮🇹</h3>
                <p class="epk-label-sub"><a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>'s imprint, born in Italy, raised in the UK</p>
                <p>
                  MAYA's remix debut: her official remix for <a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>'s track 'Stay', released
                  alongside additional remixes, including one by legendary <a class="epk-inline-link" href="https://www.instagram.com/timo.maas/" target="_blank" rel="noopener">Timo Maas</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- GLOBAL AUDIENCE & REACH -->
    <section class="epk-section">
      <h2>Global Audience &amp; Reach</h2>
      <p>
        MAYA's combined content on <a class="epk-inline-link" href="https://www.youtube.com/@MayaFourteen" target="_blank" rel="noopener">YouTube</a> and <a class="epk-inline-link" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">SoundCloud</a> has surpassed 330K plays, reaching
        listeners in over 100 countries through steady, organic growth. Her mixes
        stand out for technical precision, harmonic flow, refined taste, and a
        distinct storytelling identity, reflecting sustained international listener
        demand.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Map of Maya Fourteen's global listener reach" loading="lazy" />
        <a href="https://soundcloud.com/mayafourteen/maya-ocho-siriusxm" target="_blank" rel="noopener"><img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen featured on Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" /></a>
        <a href="https://www.youtube.com/watch?v=mWqUmkWs3wY" target="_blank" rel="noopener"><img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen performing at Greenvalley" loading="lazy" /></a>
      </div>
      <p class="epk-audience-caption">
        Every set is a journey. Choose yours.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>High-resolution images available for promotional use. All photos copyright protected.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/press/press-kit-1.jpg" download><img src="/images/epk/press/press-kit-1-thumb.webp" width={images.epkPressKit1.width} height={images.epkPressKit1.height} alt="Maya Fourteen, editorial portrait seated on a staircase" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-2.jpg" download><img src="/images/epk/press/press-kit-2-thumb.webp" width={images.epkPressKit2.width} height={images.epkPressKit2.height} alt="Maya Fourteen, studio portrait" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-3.jpg" download><img src="/images/epk/press/press-kit-3-thumb.webp" width={images.epkPressKit3.width} height={images.epkPressKit3.height} alt="Maya Fourteen, fashion portrait in a doorway" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-4.jpg" download><img src="/images/epk/press/press-kit-4-thumb.webp" width={images.epkPressKit4.width} height={images.epkPressKit4.height} alt="Maya Fourteen, portrait at sunset in the desert" loading="lazy" /></a>
      </div>
      <p class="epk-photo-credit">Photography: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
      <div class="epk-download-actions">
        <a class="cta-button" href="https://drive.google.com/open?id=1Y0dyWs18uc7w8QbKFj_pbmrpeX81bu_j" target="_blank" rel="noopener">Download Press Kit</a>
        <a class="cta-button cta-button-outline" href="https://drive.google.com/open?id=1XacZsWwys1ieA5C3hLZzSoFWPFS_yh2z" target="_blank" rel="noopener">Download EPK (PDF)</a>
      </div>
    </section>

    <!-- GET IN TOUCH -->
    <section class="epk-section epk-booking" id="get-in-touch">
      <h2>Get in Touch</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Booking &amp; Management</p>
        <p class="epk-booking-name">Antonio Afonso</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Available for select private, club and festival bookings worldwide.<br />
          International tours upon request. Full professional rider provided.
        </p>
      </div>
    </section>

    <!-- SOCIAL FOOTER -->
    <section class="epk-discover">
      <SocialNav links={discoverSocialLinks} />
    </section>

  </main>

  <TextFooter lang="en" />
  <BackToTop />
</V3BaseLayout>

<style>
  /* Set-story links: foot of the cards column, spanning its full width so
     they justify with the tour box above (not the page's left spine). */
  .epk-stage-cards .epk-setstories {
    grid-column: 1 / -1;
    margin: 0;
    font-size: 0.82rem;
