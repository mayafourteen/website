---
import V3InteriorLayout from '../layouts/V3InteriorLayout.astro';
import { pressItems } from '../data/v3/pressItems.js';
---

<V3InteriorLayout
  title="Press & Media"
  eyebrow="Por qué la industria está atenta"
  description="Maya Fourteen ha sido destacada en las principales plataformas internacionales de medios de música electrónica."
  heroImage="/images/epk/epk-hero.jpg"
  hasEsSibling
>
  <p>
    Maya Fourteen ha sido destacada en las principales plataformas internacionales de medios de música
    electrónica.
  </p>

  <ul class="link-list">
    {pressItems.map((item) => (
      <li>
        <strong>{item.outlet}</strong>
        <a href={item.href} target="_blank">{item.label}</a>
      </li>
    ))}
  </ul>
</V3InteriorLayout>
