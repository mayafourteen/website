---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBackground from '../../components/HeroBackground.astro';
---

<BaseLayout
  noindex
  title="MAYA FOURTEEN"
  description="Official website of award-winning electronic music artist Maya Fourteen."
  bodyClass="page-landing"
>
  <Fragment slot="head">
    <!--
      Automatic language routing. Runs as early/blocking as page-transitions.js
      so there's no flash of this page before redirecting — this page itself
      is not meant to be seen, only its background during the brief redirect.
      1. A saved preference (set when a visitor picks a language manually via
         LanguageMenu) always wins.
      2. Otherwise, detect from navigator.language / navigator.languages.
      3. Anything that isn't pt/es defaults to English, the international
         fallback, per the routing rules.
      No-JS visitors get a <noscript> meta-refresh to /page-en instead.
    -->
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'maya-lang-pref';
        var SUPPORTED = ['en', 'pt', 'es'];

        function detectFromBrowser() {
          var langs = (navigator.languages && navigator.languages.length)
            ? navigator.languages
            : [navigator.language || 'en'];

          for (var i = 0; i < langs.length; i++) {
            var code = String(langs[i]).toLowerCase();
            if (code.indexOf('pt') === 0) return 'pt';
            if (code.indexOf('es') === 0) return 'es';
            if (code.indexOf('en') === 0) return 'en';
          }
          return 'en';
        }

        var target = 'en';
        try {
          var stored = localStorage.getItem(STORAGE_KEY);
          target = (stored && SUPPORTED.indexOf(stored) !== -1) ? stored : detectFromBrowser();
        } catch (e) {
          target = detectFromBrowser();
        }

        window.location.replace('/legacy/page-' + target);
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/legacy/page-en" />
    </noscript>
  </Fragment>

  <div class="container">
    <HeroBackground src="/images/maya-landing.jpg" alt="Maya Fourteen" />
    <noscript>
      <div class="noscript-fallback">
        <a href="page-en.html">English</a>
        <span class="dot">•</span>
        <a href="page-pt.html">Português</a>
        <span class="dot">•</span>
        <a href="page-es.html">Español</a>
      </div>
    </noscript>
  </div>
</BaseLayout>

<style>
  :global(.page-landing) {
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
  }

  .container {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  .noscript-fallback {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 2.5vw;
    color: white;
    font-weight: 300;
    letter-spacing: 0.25em;
    font-size: 2.2vw;
    white-space: nowrap;
  }

  .noscript-fallback a {
    color: white;
    text-decoration: none;
  }

  .dot {
    font-size: 1.2em;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .noscript-fallback {
      font-size: 5.5vw;
      gap: 6vw;
    }
  }
</style>
