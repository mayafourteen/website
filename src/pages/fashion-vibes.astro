    </section>

    <!-- BOOKING & MANAGEMENT: left-aligned contact block inside a subtle
         inner card, plain inline links (email white, WhatsApp orange) not
         buttons — matches the Gamma reference's actual structure, which is
         flatter than a button-CTA pattern. The beepd logo footer strip
         (round 1) was removed in round 2 per client request. -->
    <section class="fv-section fv-booking fade-item">
      <h2>Booking &amp; Management</h2>
      <div class="fv-booking-card">
        <div class="fv-booking-content">
          <p class="fv-booking-heading">For Bookings &amp; Artist Enquiries</p>
          <p class="fv-booking-name">Antonio Afonso, Management</p>
          <p class="fv-booking-contact">
            Email: <a class="fv-booking-link" href="mailto:hello@mayafourteen.com">hello@mayafourteen.com</a>
          </p>
          <p class="fv-booking-contact">
            <span aria-hidden="true">&#128222;</span> +55 47 99935-3919
            <span aria-hidden="true">&nbsp;I&nbsp;</span>
            <a class="fv-booking-link fv-booking-link-accent" href="https://wa.me/5547999353919" target="_blank" rel="noopener">WhatsApp</a>
          </p>
          <p class="fv-booking-note">
