    </section>
  </main>

  <TextFooter />

  <script>
    // Click-to-load facades (Sound & Atmosphere): the real YouTube/
    // SoundCloud iframe is only created once a visitor actually clicks —
    // keeps third-party embed JS out of the initial page load entirely.
    // The parent .fv-embed-item starts as a small grid tile (see CSS) and
    // gets .fv-embed-item--expanded on click so the injected iframe has
    // room to actually be usable (16:9 for video, a fixed height for
    // audio) instead of playing inside a tiny thumbnail.
    document.querySelectorAll<HTMLButtonElement>('.fv-embed-facade').forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.dataset.embedSrc;
        if (!src) return;
        const iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.title = btn.dataset.embedTitle ?? '';
        iframe.className = 'fv-embed-injected';
        if (btn.dataset.embedType === 'video') {
          iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
          iframe.allowFullscreen = true;
        } else {
          iframe.allow = 'autoplay';
          iframe.scrolling = 'no';
        }
        btn.closest('.fv-embed-item')?.classList.add('fv-embed-item--expanded');
        btn.replaceWith(iframe);
      });
    });
  </script>

  <script>
    // Scroll-triggered entrance: every .fade-item starts hidden (see the
    // matching CSS) and gets .is-visible added the first time it enters
    // the viewport, then is unobserved so it never replays. Respects
    // prefers-reduced-motion by skipping the animation entirely — content
    // is just present from the start for those users, see the CSS guard.
    const revealEls = document.querySelectorAll<HTMLElement>('.fade-item');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      revealEls.forEach((el) => el.classList.add('is-visible'));
    } else if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );
      revealEls.forEach((el) => observer.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add('is-visible'));
    }
  </script>
</V3BaseLayout>

<style is:global>
  /* Scroll-triggered entrance, not a load-time animation: every element
     starts hidden and gets .is-visible added by the IntersectionObserver
     script below the first time it scrolls into view (once — the
     observer unobserves after triggering), so each section reveals as
     the visitor actually reaches it rather than all firing on page load.
     One pattern, one duration, one easing, site-wide on this page. */
  .fade-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .fade-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
