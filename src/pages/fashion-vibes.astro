              <path d="M12 3c2.5 2.7 4 5.9 4 9s-1.5 6.3-4 9c-2.5-2.7-4-5.9-4-9s1.5-6.3 4-9z" />
            </svg>
          </span>
          <span class="fv-discover-label">Website</span>
        </a>
        {fashionDiscoverLinks.map((link) => (
          <a
            class="fv-discover-item"
            href={link.href}
            target="_blank"
            rel="noopener"
            title={link.title}
            aria-label={`${link.title} (opens in a new tab)`}
