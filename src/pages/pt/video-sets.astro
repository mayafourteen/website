---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterSignup from '../../components/v3/NewsletterSignup.astro';
import { videoSets } from '../../data/v3/videoSets.js';
---

<V3InteriorLayout
  title="Vídeo"
  eyebrow="Ela também se apresenta ao vivo"
  description="Assista aos sets em vídeo e apresentações ao vivo de Maya Fourteen no YouTube."
  heroImage="/images/video-hero-greenvalley.webp"
  heroImageCredit
  heroImageAlt="Maya Fourteen se apresentando na Greenvalley, Brasil"
  hasEsSibling
>
  <p>
    Sets completos e imagens de apresentações, publicados conforme são lançados.
  </p>

  <ul class="video-list">
    {videoSets.map((video) => (
      <li>
        <div class="video-frame">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={video.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="video-caption">{video.title}</p>
      </li>
    ))}
  </ul>

  <a class="cta-button" href="https://www.youtube.com/@MayaFourteen" target="_blank">Assistir no YouTube</a>
  <h2 class="set-stories-heading">Histórias dos sets</h2>
  <ul class="set-stories">
    <li><a href="/pt/sets/greenvalley">Greenvalley - Abertura do 17º Aniversário</a></li>
    <li><a href="/pt/sets/sls-dubai">SLS Dubai - 75 Andares Acima</a></li>
    <li><a href="/pt/sets/amazon-basin">Amazon Basin - Uma Jornada ao Pôr do Sol em Casa</a></li>
    <li><a href="/pt/sets/fendi-yachthouse">FENDI x Yachthouse - 300 Metros de Altura</a></li>
  </ul>
  <NewsletterSignup lang="pt" />
</V3InteriorLayout>

<style>
  .video-list {
    list-style: none;
    margin: 0 0 32px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .video-frame {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .video-frame iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-caption {
    margin: 10px 0 0 0;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.65);
  }

  .set-stories-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    letter-spacing: 0.06em;
    font-size: 1.35em;
    margin: 1.8em 0 0.4em;
  }

  .set-stories {
    list-style: none;
    margin: 0;
    padding: 0;
    line-height: 2.1;
    font-size: 0.92em;
  }

  .set-stories a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.85;
  }

  .set-stories a:hover {
    opacity: 1;
  }
</style>
