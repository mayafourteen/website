---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterCTA from '../../components/v3/NewsletterCTA.astro';
import { mixes, originalTracks, feelBetterFallback, buildEmbedUrl } from '../../data/v3/audioSets.js';
---

<V3InteriorLayout
  title="Áudio"
  eyebrow="Qual é o som dela"
  description="Ouça os sets em áudio e lançamentos de Maya Fourteen no SoundCloud."
  heroImage="/images/epk/epk-discography.jpg"
  hasEsSibling
>
  <p>
    Mixes, faixas originais e remixes, direto do SoundCloud e do Spotify.
  </p>

  <p class="section-title">DJ Mixes</p>
  <ul class="audio-list">
    {mixes.map((track, index) => (
      <li>
        <iframe
          class="audio-embed"
          height="166"
          scrolling="no"
          src={buildEmbedUrl(track.url)}
          title={track.title}
          loading={index === 0 ? 'eager' : 'lazy'}
        ></iframe>
        <p class="audio-caption">{track.title}</p>
        {track.setStory && (
          <a class="audio-story-link" href={`/pt/sets/${track.setStory}`}>[ ler a história ]</a>
        )}
      </li>
    ))}
  </ul>

  <p class="section-title">Faixas Originais</p>
  <ul class="audio-list">
    {originalTracks.map((track) => (
      <li>
        <iframe
          class="audio-embed"
          height="166"
          scrolling="no"
          src={buildEmbedUrl(track.url)}
          title={track.title}
          loading="lazy"
        ></iframe>
        <p class="audio-caption">{track.title}</p>
      </li>
    ))}
    <li>
      <a class="beatport-fallback" href={feelBetterFallback.href} target="_blank" rel="noopener">
        <span class="beatport-fallback-title">EP 'Feel Better', com Mario Franca</span>
        <span class="beatport-fallback-meta">Ouça o lançamento da VIVa MUSiC no Beatport</span>
      </a>
    </li>
  </ul>

  <div class="audio-cta-row">
    <a class="cta-button" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">+ no SoundCloud</a>
    <a class="cta-button" href="https://www.beatport.com/artist/maya-fourteen/1218920" target="_blank" rel="noopener">+ no Beatport</a>
    <a class="cta-button" href="https://open.spotify.com/artist/0A89st7lXBJ5UE96h8Ku0r" target="_blank" rel="noopener">+ no Spotify</a>
  </div>
  <NewsletterCTA lang="pt" />
</V3InteriorLayout>

<style>
  .audio-list {
    list-style: none;
    margin: 0 0 8px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .audio-embed {
    width: 100%;
    border: none;
    display: block;
    border-radius: 3px;
  }

  .audio-caption {
    margin: 10px 0 0 0;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.65);
  }

  .audio-story-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: #d9a96a;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .audio-story-link:hover {
    opacity: 0.8;
  }

  .beatport-fallback {
    display: block;
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 3px;
    text-decoration: none;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .beatport-fallback:hover {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.06);
  }

  .beatport-fallback-title {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 4px;
  }

  .beatport-fallback-meta {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .audio-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    /* Three buttons span the content width: first flush left, last flush
       right (justified with the players above), middle centered. Wraps
       back to a plain stacked row on narrow screens. */
    justify-content: space-between;
  }

  /* Stacked on phones: equal full-width buttons (mixed label lengths made
     the centered stack look ragged, Antonio 2026-07-22). */
  @media (max-width: 560px) {
    .audio-cta-row .cta-button {
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }
  }
</style>
