---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterSignup from '../../components/v3/NewsletterSignup.astro';
---

{/* Unlisted newsletter landing page: not in any menu, shared directly
    (IG stories, link-in-bio). Background: the "safe" photo, b&w. */}
<V3InteriorLayout
  title="Inscreva-se"
  eyebrow="O círculo próximo"
  description="Cada novo set e video set chega a esta lista antes de ir a público. Novidades de lançamentos, datas e convites privados que nunca aparecem nas redes."
  hasEsSibling
  heroImage="/images/subscribe-hero-safe.webp"
  heroImageAlt="Maya Fourteen opening a vault door"
>
  <p>
    Cada novo set e video set chega a esta lista antes de ir a público. Novidades de lançamentos, datas e convites privados que nunca aparecem nas redes.
  </p>
  <p>
    Um email quando algo importa. Sem ruído, nunca. Saia com um clique quando quiser.
  </p>
  <p class="subscribe-close">Entre para o círculo próximo:</p>

  <NewsletterSignup lang="pt" formOnly />
</V3InteriorLayout>

<style>
  p {
    text-align: center;
  }

  .subscribe-close {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15em !important;
    color: rgba(255, 255, 255, 0.9) !important;
    margin-top: 30px !important;
  }
</style>
