---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterSignup from '../../components/v3/NewsletterSignup.astro';
---

<V3InteriorLayout
  title="Info & Contato"
  eyebrow="Entre em contato"
  description="Entre em contato com a artista premiada de música eletrônica Maya Fourteen para bookings, representação de agência e contato com a imprensa."
  heroImage="/images/epk/epk-award.jpg"
  hasEsSibling
>
  <p>
    Disponível para datas em clubes, line-ups de festivais e eventos privados selecionados ao
    redor do mundo. Para bookings, representação de agência ou contato com a imprensa, fale por
    qualquer um dos canais abaixo.
  </p>
  <p>
    Para solicitações de booking, inclua a data, o local ou evento, e a cidade para uma resposta
    rápida sobre disponibilidade.
  </p>

  <div class="contact-actions">
    <a class="cta-button" href="mailto:hello@mayafourteen.com?subject=Solicita%C3%A7%C3%A3o%20de%20booking%20para%20Maya%20Fourteen">Enviar e-mail para hello@mayafourteen.com</a>
    <a class="cta-button" href="https://wa.me/5547999353919?text=Solicita%C3%A7%C3%A3o%20de%20booking%20para%20Maya%20Fourteen%3A" target="_blank" rel="noopener">WhatsApp +55 47 99935 3919</a>
    <a class="cta-button" href="https://www.instagram.com/mayafourteen/" target="_blank" rel="noopener">DM no Instagram</a>
  </div>
  <NewsletterSignup lang="pt" />
</V3InteriorLayout>

<style>
  .contact-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    margin-top: 8px;
  }
</style>
