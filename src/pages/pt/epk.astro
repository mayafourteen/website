---
// Self-hosted fonts (fontsource, bundled locally): removes the two
// Google Fonts round-trips from the critical path and the GDPR gray zone
// of shipping visitor IPs to Google. Same families/weights as before.
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/inter/200.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
// PT-BR counterpart of epk.astro — same structure/CSS, copy translated
// from the real PT gamma EPK page, with the same award-name override.
// See epk.astro for the full sourcing notes.
import V3BaseLayout from '../../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../../components/v3/HamburgerMenu.astro';
import SocialNav from '../../components/v3/SocialNav.astro';
import TextFooter from '../../components/v3/TextFooter.astro';
import { discoverSocialLinks } from '../../data/v3/discoverSocialLinks.js';
import { images } from '../../data/v3/images.js';

// EPK-only Media Spotlight list — see epk.astro for the full sourcing
// notes. Only Gray Area (US)'s label is localized; every other outlet
// label stays English, matching the site's established pattern.
const mediaSpotlightItems = [
  { outlet: 'DJ Mag LATAM', href: 'https://djmagla.com/conoce-a-maya-fourteen-la-artista-brasilena-que-esta-llevando-su-talento-a-nuevos-lugares-del-mundo', label: 'Read article' },
  { outlet: 'Mixmag Brazil', href: 'https://mixmag.com.br/feature/conheca-maya-fourteen-artista-brasileira-reconhecida-por-nicole-moudaber-e-pete-tong', label: 'Read article' },
  { outlet: 'Sync Beat Magazine Cover', href: 'https://music.beepd.co/card/syncbeatmagazine', label: 'View cover feature' },
  { outlet: 'Clubbing TV', href: 'https://clubbingtv.com/shows/view/5593/lds-with-maya-fourteen-ade-2023-spaces/', label: 'Watch feature' },
  { outlet: 'Gray Area (US)', href: 'https://www.instagram.com/p/DTggbNBDb4H/', label: 'VER PUBLICAÇÃO' },
  { outlet: 'Play BPM', href: 'https://playbpm.com.br/colunas/play-bpm-indica/maya/', label: 'Read article' },
  { outlet: 'Alataj', href: 'https://alataj.com.br/15-to-understand/maya', label: 'Read article' },
  { outlet: 'EKM', href: 'https://ekm.co/maya-fourteen-uniqueness/', label: 'Read review' },
];
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="Baixe o mídia kit oficial da artista premiada Maya Fourteen, com biografia, credenciais, palcos internacionais e discografia."
  bodyClass="page-epk"
  lang="pt"
  languageHrefOverrides={{ en: '/en/epk', pt: '/pt/epk', es: '/es/epk' }}
  hreflangAlternates={{ en: '/en/epk', pt: '/pt/epk', es: '/es/epk' }}
  breadcrumbs={[{ name: 'Início', path: '/pt' }, { name: 'EPK', path: '/pt/epk' }]}
>
  <Fragment slot="head">
    <!-- media="print" + onload swap takes this off the render-blocking path
         — same CSS applies once loaded, only the paint-timing changes.
         noscript fallback covers the no-JS case. -->
    <noscript></noscript>
  </Fragment>

  <HamburgerMenu lang="pt" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, foto de capa do mídia kit"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Electronic Press Kit</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ e Produtora Internacional</p>
        <p class="epk-subtagline">Artista Eletrônica Premiada</p>
      </div>
    </section>

    <!-- DNA ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen atrás dos equipamentos"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>DNA Artístico</h2>
        <p>
          MAYA é uma artista brasileira de música eletrônica, originária da Bacia
          Amazônica, com base entre a Europa e a América do Sul. Sua sonoridade
          percorre grooves deep, orgânicos, progressivos e tech, sustentados por uma
          forte intuição melódica e uma identidade artística bem definida.
        </p>
        <blockquote class="epk-artist-quote">
          <p>"Eu me adapto ao ambiente, ao horário, à energia da pista. A paleta muda, mas a identidade permanece."</p>
          <cite>Maya Fourteen</cite>
        </blockquote>
      </div>
    </section>

    <!-- PERFORMANCES GLOBAIS -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen se apresentando na Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Performances Globais</h2>
        <p>
          Com apresentações em três continentes, MAYA construiu uma trajetória que
          atravessa clubes, festivais e eventos exclusivos na Europa, Ásia, Oriente
          Médio e América do Sul. Sua leitura de pista e adaptação a cada contexto
          fazem dela uma artista versátil, sempre fiel à própria identidade sonora.
        </p>
      </div>
    </section>

    <!-- PALCOS MUNDIAIS -->
    <section class="epk-section">
      <h2>Palcos Mundiais</h2>
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen se apresentando na Greenvalley, Brasil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/greenvalleybr/" target="_blank" rel="noopener">Greenvalley Brasil</a> 🇧🇷</h3>
            <p>5× Club nº1 do Mundo, com <a class="epk-inline-link" href="https://www.instagram.com/michael_bibi_/" target="_blank" rel="noopener">Michael Bibi</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a></p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/worldclubdome/" target="_blank" rel="noopener">World Club Dome</a> 🇩🇪</h3>
            <p>O maior club festival da Alemanha, com <a class="epk-inline-link" href="https://www.instagram.com/jamiejonesmusic/" target="_blank" rel="noopener">Jamie Jones</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/hotsince82/" target="_blank" rel="noopener">Hot Since 82</a></p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/terrasolisdubai/" target="_blank" rel="noopener">Terra Solis Dubai</a> 🇦🇪</h3>
            <p>Oásis do Tomorrowland no deserto de Dubai, com <a class="epk-inline-link" href="https://www.instagram.com/anahitvardanyanofficial/" target="_blank" rel="noopener">ANNA</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a></p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <h3><a class="epk-inline-link" href="https://soundcloud.com/mayafourteen/maya-f1-after-race-recap" target="_blank" rel="noopener">Formula 1</a> 🏁</h3>
            <p>After-parties privadas nos GPs de Abu Dhabi &amp; Mônaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <h3>Tour Internacional 🪩</h3>
            <p>Presente em mais de 15 países, com destaque para Londres, Amsterdã, Lisboa, Frankfurt, Ibiza, Cannes, Mônaco, Budapeste, Dubai, Tóquio, Bangkok, Kuala Lumpur e Bali.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA MULTIPREMIADA -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen recebendo seu prêmio no IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artista Multipremiada</h2>
        <p>
          MAYA venceu um prestigioso <strong>Future Talent Award</strong> no <a class="epk-inline-link" href="https://www.internationalmusicsummit.com/" target="_blank" rel="noopener">IMS</a> Ibiza 2025, selecionada
          por <a class="epk-inline-link" href="https://www.instagram.com/petetongofficial/" target="_blank" rel="noopener">Pete Tong</a>, e recebeu o <strong><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a> Talent Highlight Prize</strong>, distinção pessoal de uma das vozes mais respeitadas da indústria.
        </p>
        <p>
          No <strong>MixMasters Ibiza Summit 2023</strong>, foi selecionada entre milhares de artistas de todo
          o mundo, num processo com curadoria de selos como <a class="epk-inline-link" href="https://www.instagram.com/defectedrecords/" target="_blank" rel="noopener">Defected</a>, <a class="epk-inline-link" href="https://www.instagram.com/solidgroovesuk/" target="_blank" rel="noopener">Solid Grooves</a> e <a class="epk-inline-link" href="https://www.instagram.com/systematicrecordings/" target="_blank" rel="noopener">Systematic</a>.
        </p>
      </div>
    </section>

    <!-- VOZES DO MERCADO -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image epk-media-image--voices"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen entrevistada por Laureline Teste, da Clubbing TV, em um terraço"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Vozes do Mercado</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;Ela é o próximo grande nome. Fiquem atentos!&rdquo;</p>
          <cite>Laureline Teste, <a class="epk-inline-link" href="https://www.instagram.com/clubbingtv/" target="_blank" rel="noopener">Clubbing TV</a>, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;Eu adoraria dividir a cabine com você um dia!&rdquo;</p>
          <cite><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a>, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;MAYA, esta é sua casa. As portas da Ibiza Sonica estarão sempre abertas para você.&rdquo;</p>
          <cite>Karlos Sense, <a class="epk-inline-link" href="https://www.instagram.com/ibizasonica/" target="_blank" rel="noopener">Ibiza Sonica</a></cite>
        </blockquote>
      </div>
    </section>

    <!-- MÍDIA EM DESTAQUE -->
    <section class="epk-section epk-media epk-media-spotlight">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 480px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen na capa da Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Mídia em Destaque</h2>
        <p>
          MAYA foi capa da revista espanhola <a class="epk-inline-link" href="https://www.instagram.com/syncbeatmagazine/" target="_blank" rel="noopener">Sync Beat</a>, em uma edição especial
          dedicada à nova geração da música eletrônica. A publicação destacou sua
          presença internacional, performances em palcos relevantes e colaborações
          recentes, reforçando seu posicionamento no cenário eletrônico.
        </p>
        <ul class="epk-press-list">
          {mediaSpotlightItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONHECIMENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Reportagem da Gray Area: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Reconhecimento Editorial</h2>
        <p>
          MAYA foi destacada pela plataforma norte-americana <a class="epk-inline-link" href="https://grayarea.co" target="_blank" rel="noopener">Gray Area</a> como uma das
          artistas brasileiras a acompanhar em 2026, ao lado de <a class="epk-inline-link" href="https://www.instagram.com/mazmusic/" target="_blank" rel="noopener">Maz</a>, <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a>, <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a>
          e <a class="epk-inline-link" href="https://www.instagram.com/djalinerocha/" target="_blank" rel="noopener">Aline Rocha</a>. A seleção reflete a crescente atenção internacional em torno
          de seu trabalho e de seu posicionamento no atual cenário global da música
          eletrônica.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFIA -->
    <section class="epk-section">
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen no estúdio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografia</h2>
          <div class="epk-discography-layout">
            <div class="epk-label-card">
              <h3><a class="epk-inline-link" href="https://www.systematic-recordings.com/" target="_blank" rel="noopener">Systematic Recordings</a> 🇩🇪</h3>
              <p class="epk-label-sub">Selo icônico de <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a></p>
              <p>
                O single de estreia de MAYA, <a class="epk-inline-link" href="https://www.beatport.com/track/uniqueness-feat-francesca/19198825" target="_blank" rel="noopener">'Uniqueness'</a>, com vocais de Francesca Posgai, foi escolhido a dedo por <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> para o álbum do 20º aniversário da Systematic Recordings, lançado juntamente com temas de <a class="epk-inline-link" href="https://www.instagram.com/carlcoxofficial/" target="_blank" rel="noopener">Carl Cox</a>, <a class="epk-inline-link" href="https://www.instagram.com/joshwink1/" target="_blank" rel="noopener">Josh Wink</a>, <a class="epk-inline-link" href="https://www.instagram.com/rodriguezjrmusic/" target="_blank" rel="noopener">Rodriguez Jr.</a> e <a class="epk-inline-link" href="https://www.instagram.com/guiboratto/" target="_blank" rel="noopener">Gui Boratto</a>.
              </p>
              <p>
                Romboy ouviu o tema pela primeira vez no MixMasters Ibiza Summit e o descreveu como um resgate à era dourada da dance music, com uma atemporalidade que evoca Mood II Swing.
              </p>
              <p class="epk-label-tag">TOP 10 Beatport, posição #8</p>
            </div>
            <div class="epk-discography-side">
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://vivamusicltd.com/" target="_blank" rel="noopener">VIVa MUSiC</a> 🇬🇧</h3>
                <p class="epk-label-sub">Selo conceituado de <a class="epk-inline-link" href="https://www.instagram.com/djstevelawler/" target="_blank" rel="noopener">Steve Lawler</a></p>
                <p>
                  'Feel Better' EP, colaboração de duas faixas com <a class="epk-inline-link" href="https://www.instagram.com/mario_f_franca/" target="_blank" rel="noopener">Mario Franca</a>
                  (<a class="epk-inline-link" href="https://bedrock.org.uk/" target="_blank" rel="noopener">Bedrock</a> | <a class="epk-inline-link" href="https://seladorrecordings.com/" target="_blank" rel="noopener">Selador</a>), destacando a versatilidade de MAYA, indo do
                  Organic House mais etéreo a uma identidade Deep Tech, intensa e
                  pulsante.
                </p>
              </div>
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://www.instagram.com/dioscurirecords/" target="_blank" rel="noopener">Dioscuri Records</a> 🇮🇹</h3>
                <p class="epk-label-sub">Selo de <a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>, da Itália para Londres</p>
                <p>
                  Estreia de MAYA como remixer: seu remix oficial para 'Stay', tema de <a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>, lançado junto a outros remixes, incluindo um assinado pelo
                  lendário <a class="epk-inline-link" href="https://www.instagram.com/timo.maas/" target="_blank" rel="noopener">Timo Maas</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ALCANCE GLOBAL E AUDIÊNCIA -->
    <section class="epk-section">
      <h2>Alcance Global e Audiência</h2>
      <p>
        O conteúdo combinado da MAYA no <a class="epk-inline-link" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">SoundCloud</a> e no <a class="epk-inline-link" href="https://www.youtube.com/@MayaFourteen" target="_blank" rel="noopener">YouTube</a> soma mais de 330 mil plays, alcançando
        ouvintes em mais de 100 países, com crescimento orgânico e engajamento
        consistente. Seus sets circulam globalmente entre públicos, plataformas e
        curadores, ampliando sua presença internacional além do circuito físico de
        apresentações.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Mapa do alcance global de ouvintes de Maya Fourteen" loading="lazy" />
        <a href="https://soundcloud.com/mayafourteen/maya-ocho-siriusxm" target="_blank" rel="noopener"><img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen em destaque na Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" /></a>
        <a href="https://www.youtube.com/watch?v=mWqUmkWs3wY" target="_blank" rel="noopener"><img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen se apresentando na Greenvalley" loading="lazy" /></a>
      </div>
      <p class="epk-audience-caption">
        Cada set é uma viagem. Escolha a sua.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imagens em alta resolução disponíveis para uso promocional. Todas as fotos são protegidas por direitos autorais.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/press/press-kit-1.jpg" download><img src="/images/epk/press/press-kit-1-thumb.webp" width={images.epkPressKit1.width} height={images.epkPressKit1.height} alt="Maya Fourteen, retrato editorial sentada em uma escada" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-2.jpg" download><img src="/images/epk/press/press-kit-2-thumb.webp" width={images.epkPressKit2.width} height={images.epkPressKit2.height} alt="Maya Fourteen, retrato de estúdio" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-3.jpg" download><img src="/images/epk/press/press-kit-3-thumb.webp" width={images.epkPressKit3.width} height={images.epkPressKit3.height} alt="Maya Fourteen, retrato de moda em uma porta" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-4.jpg" download><img src="/images/epk/press/press-kit-4-thumb.webp" width={images.epkPressKit4.width} height={images.epkPressKit4.height} alt="Maya Fourteen, retrato ao pôr do sol no deserto" loading="lazy" /></a>
      </div>
      <p class="epk-photo-credit">Fotografia: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
      <div class="epk-download-actions">
        <a class="cta-button" href="https://drive.google.com/open?id=1Y0dyWs18uc7w8QbKFj_pbmrpeX81bu_j" target="_blank" rel="noopener">Baixar Fotos</a>
        <a class="cta-button cta-button-outline" href="https://drive.google.com/open?id=1XacZsWwys1ieA5C3hLZzSoFWPFS_yh2z" target="_blank" rel="noopener">Baixar EPK (PDF)</a>
      </div>
    </section>

    <!-- ENTRE EM CONTATO -->
    <section class="epk-section epk-booking">
      <h2>Entre em Contato</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Booking &amp; Management</p>
        <p class="epk-booking-name">Antonio Afonso</p>
        <div class="epk-booking-actions">
