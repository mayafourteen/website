---
import V3InteriorLayout from '../../layouts/V3InteriorLayout.astro';
import NewsletterSignup from '../../components/v3/NewsletterSignup.astro';
---

{/* Unlisted newsletter landing page: not in any menu, shared directly
    (IG stories, link-in-bio). Background: the "safe" photo, b&w. */}
<V3InteriorLayout
  title="Suscríbete"
  eyebrow="El círculo cercano"
  description="Cada nuevo set y video set llega a esta lista antes de hacerse público. Novedades de lanzamientos, fechas e invitaciones privadas que nunca llegan a las redes."
  hasEsSibling
  heroImage="/images/subscribe-hero-safe.webp"
  heroImageAlt="Maya Fourteen opening a vault door"
>
  <p>
    Cada nuevo set y video set llega a esta lista antes de hacerse público. Novedades de lanzamientos, fechas e invitaciones privadas que nunca llegan a las redes.
  </p>
  <p>
    Un email cuando algo importa. Sin ruido, nunca. Sal con un clic cuando quieras.
  </p>
  <p class="subscribe-close">Únete al círculo cercano:</p>

  <NewsletterSignup lang="es" formOnly />
</V3InteriorLayout>

<style>
  p {
    text-align: center;
  }

  .subscribe-close {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15em !important;
    color: rgba(255, 255, 255, 0.9) !important;
    margin-top: 30px !important;
  }
</style>
