---
// ES counterpart of epk.astro — same structure/CSS, copy translated
// from the real ES gamma EPK page. New page: ES has no other interior
// pages (About/Press/etc stay EN/PT only, per the project's ES
// deferral), but EPK is an explicit exception per this brief. See
// epk.astro for the full sourcing notes.
import V3BaseLayout from '../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import SocialNav from '../components/v3/SocialNav.astro';
import { pressItems } from '../data/v3/pressItems.js';
import { discoverSocialLinks } from '../data/v3/discoverSocialLinks.js';
import TextFooter from '../components/v3/TextFooter.astro';
import { images } from '../data/v3/images.js';
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="Descarga el EPK oficial de la artista premiada Maya Fourteen, con biografía, credenciales, escenarios internacionales y discografía."
  bodyClass="page-epk"
  lang="es"
  languageHrefOverrides={{ en: '/epk', pt: '/epk-pt', es: '/epk-es' }}
  hreflangAlternates={{ en: '/epk', pt: '/epk-pt', es: '/epk-es' }}
  breadcrumbs={[{ name: 'Inicio', path: '/page-es' }, { name: 'EPK', path: '/epk-es' }]}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css">
  </Fragment>

  {/* navItems has no 'es' key (ES has no other interior pages) — falls back to the English nav automatically */}
  <HamburgerMenu lang="es" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, foto de portada del EPK"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Press Kit Electrónico</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ y Productora Internacional</p>
        <p class="epk-subtagline">Artista Electrónica Premiada</p>
      </div>
    </section>

    <!-- PERFIL ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen detrás de los platos"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Perfil Artístico</h2>
        <p>
          Maya Fourteen es una artista brasileña de música electrónica conocida por
          un enfoque refinado y narrativo del sonido. Fusiona elementos orgánicos,
          progresivos y de carácter tech con un fuerte instinto melódico, lo que le
          permite adaptarse con fluidez a distintos estados de ánimo y entornos.
        </p>
      </div>
    </section>

    <!-- TRAYECTORIA INTERNACIONAL -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen actuando en Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Trayectoria Internacional</h2>
        <p>
          MAYA ha actuado en circuitos internacionales clave, construyendo una
          reputación por actuaciones sólidas y seguras en entornos exigentes. Su
          presencia global refleja autoridad musical, capacidad de adaptación y la
          confianza de públicos diversos en clubes, festivales y eventos
          cuidadosamente curados.
        </p>
      </div>
    </section>

    <!-- ESCENARIOS INTERNACIONALES -->
    <section class="epk-section">
      <h2>Escenarios Internacionales</h2>
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen actuando en Greenvalley, Brasil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/greenvalleybr/" target="_blank" rel="noopener">Greenvalley Brasil</a> 🇧🇷</h3>
            <p>5× #1 Club del mundo, c/ <a class="epk-inline-link" href="https://www.instagram.com/michael_bibi_/" target="_blank" rel="noopener">Michael Bibi</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a></p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/worldclubdome/" target="_blank" rel="noopener">World Club Dome</a> 🇩🇪</h3>
            <p>#1 Alemania, <a class="epk-inline-link" href="https://www.instagram.com/realblackcoffee/" target="_blank" rel="noopener">Black Coffee</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/jamiejonesmusic/" target="_blank" rel="noopener">Jamie Jones</a> Stage</p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/terrasolisdubai/" target="_blank" rel="noopener">Terra Solis Dubai</a> 🇦🇪</h3>
            <p>El club de Tomorrowland en el desierto, c/ <a class="epk-inline-link" href="https://www.instagram.com/anahitvardanyanofficial/" target="_blank" rel="noopener">ANNA</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a></p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <h3><a class="epk-inline-link" href="https://soundcloud.com/mayafourteen/maya-f1-after-race-recap" target="_blank" rel="noopener">Formula 1</a></h3>
            <p>Grandes Premios de Abu Dhabi &amp; Mónaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <h3>Gira por Europa, Oriente Medio y Asia</h3>
            <p>Presentaciones en Londres, Ámsterdam, Lisboa, Bergen, Frankfurt, Cannes, Mónaco, Ibiza, Dubai, Bali, Budapest y Tokio, y destinos clave en Tailandia, Vietnam y Malasia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA PREMIADA -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen recibiendo su premio en el IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artista Premiada</h2>
        <p>
          MAYA es ganadora de <strong>un Future Talent Award en el <a class="epk-inline-link" href="https://www.internationalmusicsummit.com/" target="_blank" rel="noopener">IMS</a> Ibiza 2025,
          seleccionada por <a class="epk-inline-link" href="https://www.instagram.com/petetongofficial/" target="_blank" rel="noopener">Pete Tong</a></strong>, y recibió el <strong><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a> Talent
          Highlight Prize</strong>. También fue seleccionada en el <a class="epk-inline-link" href="https://www.mixmasters.net/" target="_blank" rel="noopener">MixMasters</a> Ibiza Get
          Signed Summit 2023, entre miles de artistas, con la participación de
          sellos como Defected, Solid Grooves y Systematic, una validación
          temprana de la industria.
        </p>
      </div>
    </section>

    <!-- VOCES DE LA INDUSTRIA -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen con Clubbing TV en ADE"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Voces de la Industria</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;¡Me encantaría tocar contigo algún día!&rdquo;</p>
          <cite>Nicole Moudaber, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;Es el próximo gran nombre. Hay que seguirla de cerca.&rdquo;</p>
          <cite>Laureline Teste, Clubbing TV, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;A partir de ahora, esta es tu casa. Las puertas de Ibiza Sonica siempre estarán abiertas para ti.&rdquo;</p>
          <cite>Karlos Sense, Ibiza Sonica</cite>
        </blockquote>
      </div>
    </section>

    <!-- PRESENCIA EN MEDIOS -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen en la portada de Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Presencia en Medios</h2>
        <p>
          MAYA fue portada de la revista española Sync Beat Magazine en una
          edición especial dedicada a la nueva generación de artistas de la
          música electrónica. En la entrevista, comparte su recorrido artístico,
          influencias y visión creativa, reflejando su creciente presencia
          internacional dentro del circuito global de la música electrónica.
        </p>
        <ul class="epk-press-list">
          {pressItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONOCIMIENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Reportaje de Gray Area: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Reconocimiento Editorial</h2>
        <p>
          MAYA fue destacada por la plataforma estadounidense <a class="epk-inline-link" href="https://www.instagram.com/p/DTggbNBDb4H/" target="_blank" rel="noopener">Gray Area</a> como una
          de las artistas brasileñas a seguir en 2026, junto a <a class="epk-inline-link" href="https://www.instagram.com/mazmusic/" target="_blank" rel="noopener">Maz</a>, <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a>,
          <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a> y <a class="epk-inline-link" href="https://www.instagram.com/djalinerocha/" target="_blank" rel="noopener">Aline Rocha</a>. La selección refleja la creciente atención
          internacional en torno a su trabajo y su posicionamiento dentro del
          panorama global actual de la música electrónica. También grabó un set
          exclusivo para <a class="epk-inline-link" href="https://soundcloud.com/entergrayarea/maya-fourteen-exclusive-set-for-ocho-by-gray-area-225" target="_blank" rel="noopener">OCHO by Gray Area</a>.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFÍA -->
    <section class="epk-section">
      <div class="epk-stages-layout">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen en el estudio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografía</h2>
          <div class="epk-label-card">
            <h3><a class="epk-inline-link" href="https://www.systematic-recordings.com/" target="_blank" rel="noopener">Systematic Recordings</a> 🇩🇪</h3>
            <p class="epk-label-sub">Sello de los 20 años de <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a></p>
            <p>
              <a class="epk-inline-link" href="https://www.beatport.com/track/uniqueness-feat-francesca/19198825" target="_blank" rel="noopener">'Uniqueness'</a> feat. Francesca Posgai: &ldquo;(&hellip;) Un regreso a
              la era dorada del house, con vibraciones atemporales en el espíritu
              de Mood II Swing (&hellip;)&rdquo;, <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> sobre el tema de
              debut de Maya Fourteen.
            </p>
            <p class="epk-label-tag">TOP 10 Beatport, máximo #8</p>
          </div>
          <div class="epk-label-card">
            <h3><a class="epk-inline-link" href="https://vivamusicltd.com/" target="_blank" rel="noopener">VIVa MUSiC</a> 🇬🇧</h3>
            <p class="epk-label-sub">Sello prestigioso de <a class="epk-inline-link" href="https://www.instagram.com/djstevelawler/" target="_blank" rel="noopener">Steve Lawler</a></p>
            <p>
              'Feel Better' EP, colaboración junto a <a class="epk-inline-link" href="https://www.instagram.com/mario_f_franca/" target="_blank" rel="noopener">Mario Franca</a> (Bedrock |
              Selador), que muestra la versatilidad de MAYA, transitando desde un
              Deep House hacia un Deep Tech más profundo y contundente.
            </p>
          </div>
          <div class="epk-label-card">
            <h3>Dioscuri Records 🇮🇹</h3>
            <p>
              Remix oficial de MAYA para el tema 'Stay' de Costax, publicado junto
              a otros remixes, incluido uno del legendario <a class="epk-inline-link" href="https://www.instagram.com/timo.maas/" target="_blank" rel="noopener">Timo Maas</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SET DESTACADO -->
    <section class="epk-section">
      <h2>Set Destacado</h2>
      <iframe
        class="epk-embed"
        height="166"
        scrolling="no"
        src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/mayafourteen/ancestral-mato-grosso-brazil&color=%23ffffff&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=false"
        title="Maya Fourteen: Ancestral (Mato Grosso, Brazil)"
        loading="lazy"
      ></iframe>
      <a class="epk-inline-link epk-video-link" href="/video-sets">Ver los sets en video completos &rarr;</a>
    </section>

    <!-- AUDIENCIA Y ALCANCE GLOBAL -->
    <section class="epk-section">
      <h2>Audiencia y Alcance Global</h2>
      <p>
        El contenido de MAYA en <a class="epk-inline-link" href="https://www.youtube.com/@MayaFourteen" target="_blank" rel="noopener">YouTube</a> y <a class="epk-inline-link" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">SoundCloud</a> supera las 300.000
        reproducciones, alcanzando oyentes en más de 100 países gracias a un
        crecimiento orgánico y sostenido. Sus sets destacan por su precisión
        técnica, fluidez armónica, gusto refinado y una identidad narrativa
        clara, reflejando una demanda internacional constante.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Mapa del alcance global de audiencia de Maya Fourteen" loading="lazy" />
        <img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen destacada en Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" />
        <img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen actuando en Greenvalley" loading="lazy" />
      </div>
      <p class="epk-audience-caption">
        Explora el catálogo de MAYA y descubre su lenguaje musical a través de
        distintos entornos, estados de ánimo y contextos.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imágenes en alta resolución disponibles para uso promocional. Todas las fotografías están protegidas por derechos de autor.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/press/press-kit-1.jpg" download><img src={images.epkPressKit1.src} width={images.epkPressKit1.width} height={images.epkPressKit1.height} alt="Maya Fourteen, retrato editorial sentada en una escalera" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-2.jpg" download><img src={images.epkPressKit2.src} width={images.epkPressKit2.width} height={images.epkPressKit2.height} alt="Maya Fourteen, retrato de estudio" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-3.jpg" download><img src={images.epkPressKit3.src} width={images.epkPressKit3.width} height={images.epkPressKit3.height} alt="Maya Fourteen, retrato de moda en una puerta" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-4.jpg" download><img src={images.epkPressKit4.src} width={images.epkPressKit4.width} height={images.epkPressKit4.height} alt="Maya Fourteen, retrato al atardecer en el desierto" loading="lazy" /></a>
      </div>
      <p class="epk-photo-credit">Fotografía: <a href="https://www.instagram.com/diegofotografias/" target="_blank" rel="noopener noreferrer">Diego Jarschel</a></p>
      <div class="epk-download-actions">
        <a class="cta-button" href="https://drive.google.com/open?id=1Y0dyWs18uc7w8QbKFj_pbmrpeX81bu_j" target="_blank" rel="noopener">Descargar Fotos de Prensa</a>
        <a class="cta-button cta-button-outline" href="https://drive.google.com/open?id=1XacZsWwys1ieA5C3hLZzSoFWPFS_yh2z" target="_blank" rel="noopener">Descargar EPK (PDF)</a>
      </div>
    </section>

    <!-- DESCUBRE A MAYA -->
    <section class="epk-section epk-discover">
      <h2>Descubre a MAYA</h2>
      <SocialNav links={discoverSocialLinks} />
    </section>

    <!-- BOOKING & MANAGEMENT -->
    <section class="epk-section epk-booking">
      <h2>Contratación y Gestión Artística</h2>
      <div class="epk-booking-card">
        <p class="epk-booking-heading">Para Contratación y Otras Consultas</p>
        <p class="epk-booking-name">Antonio Afonso, Management</p>
        <div class="epk-booking-actions">
          <a class="cta-button" href="mailto:hello@mayafourteen.com">Enviar correo a hello@mayafourteen.com</a>
          <a class="cta-button cta-button-outline" href="https://wa.me/5547999353919" target="_blank">WhatsApp +55 47 99935 3919</a>
        </div>
        <p class="epk-booking-note">
          Disponible para reservas selectas en eventos privados, clubs y
          festivales a nivel internacional. Giras internacionales bajo
          solicitud. Rider profesional completo disponible.
        </p>
      </div>
    </section>

  </main>

  <TextFooter />
</V3BaseLayout>

<style is:global>
  .fade-item {
    opacity: 0;
    animation: smoothReveal 1.1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes smoothReveal {
    from { opacity: 0; filter: blur(10px); transform: translateY(18px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
</style>

<style>
  :global(.page-epk) {
    color: #fff;
    font-family: 'Inter', sans-serif;
    background: #0a0a0a;
  }

  /* padding-left trimmed to 10px (from a symmetric 14px) for optical
     alignment against the hamburger's ink — see the full measurement
     writeup on the matching rule in V3HomeLayout.astro. */
  :global(.page-epk) :global(.language-menu-trigger) {
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    padding: 10px 14px 10px 10px;
    color: rgba(255, 255, 255, 0.9);
  }

  .epk {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 4% 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* HERO */
  .epk-hero {
    position: relative;
    margin: 0 -4%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .epk-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    /* Unlike every other interior page's hero, this one stays full color —
       same treatment as the landing page, since it shares that page's hero
       file (see images.js's epkHero comment). Do not add the grayscale
       filter other interior heroes use. */
  }

  .epk-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.85) 100%);
  }

  .epk-hero-text {
    position: relative;
    z-index: 1;
    padding: 60px 6% 50px;
  }

  .epk-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
