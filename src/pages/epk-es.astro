---
// ES counterpart of epk.astro — same structure/CSS, copy translated
// from the real ES gamma EPK page. New page: ES has no other interior
// pages (About/Press/etc stay EN/PT only, per the project's ES
// deferral), but EPK is an explicit exception per this brief. See
// epk.astro for the full sourcing notes.
import V3BaseLayout from '../layouts/V3BaseLayout.astro';
import HamburgerMenu from '../components/v3/HamburgerMenu.astro';
import SocialNav from '../components/v3/SocialNav.astro';
import { discoverSocialLinks } from '../data/v3/discoverSocialLinks.js';
import { images } from '../data/v3/images.js';

// EPK-only Media Spotlight list — see epk.astro for the full sourcing
// notes. Only Gray Area (US)'s label is localized; every other outlet
// label stays English, matching the site's established pattern.
const mediaSpotlightItems = [
  { outlet: 'DJ Mag LATAM', href: 'https://djmagla.com/conoce-a-maya-fourteen-la-artista-brasilena-que-esta-llevando-su-talento-a-nuevos-lugares-del-mundo', label: 'Read article' },
  { outlet: 'Mixmag Brazil', href: 'https://mixmag.com.br/feature/conheca-maya-fourteen-artista-brasileira-reconhecida-por-nicole-moudaber-e-pete-tong', label: 'Read article' },
  { outlet: 'Sync Beat Magazine Cover', href: 'https://issuu.com/syncbeatmagazine/docs/maya_-_english', label: 'View cover feature' },
  { outlet: 'Clubbing TV', href: 'https://clubbingtv.com/shows/view/5593/lds-with-maya-fourteen-ade-2023-spaces/', label: 'Watch feature' },
  { outlet: 'Gray Area (US)', href: 'https://www.instagram.com/p/DTggbNBDb4H/', label: 'VER PUBLICACIÓN' },
  { outlet: 'Play BPM', href: 'https://playbpm.com.br/colunas/play-bpm-indica/maya/', label: 'Read article' },
  { outlet: 'Alataj', href: 'https://alataj.com.br/15-to-understand/maya', label: 'Read article' },
  { outlet: 'EKM', href: 'https://ekm.co/maya-fourteen-uniqueness/', label: 'Read review' },
];
---

<V3BaseLayout
  title="MAYA FOURTEEN | EPK"
  description="Descarga el EPK oficial de la artista premiada Maya Fourteen, con biografía, credenciales, escenarios internacionales y discografía."
  bodyClass="page-epk"
  lang="es"
  languageHrefOverrides={{ en: '/epk', pt: '/epk-pt', es: '/epk-es' }}
  hreflangAlternates={{ en: '/epk', pt: '/epk-pt', es: '/epk-es' }}
  breadcrumbs={[{ name: 'Inicio', path: '/page-es' }, { name: 'EPK', path: '/epk-es' }]}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" />
    <!-- media="print" + onload swap takes this off the render-blocking path
         — same CSS applies once loaded, only the paint-timing changes.
         noscript fallback covers the no-JS case. -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Inter:wght@200;300;400;500&display=swap" rel="stylesheet"></noscript>
    <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/fontawesome.min.css"></noscript>
    <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/brands.min.css"></noscript>
  </Fragment>

  {/* navItems has no 'es' key (ES has no other interior pages) — falls back to the English nav automatically */}
  <HamburgerMenu lang="es" />

  <main class="epk">
    <!-- HERO -->
    <section class="epk-hero">
      <img
        class="epk-hero-image"
        src={images.epkHero.src}
        srcset={images.epkHero.srcset}
        sizes="100vw"
        width={images.epkHero.width}
        height={images.epkHero.height}
        alt="Maya Fourteen, foto de portada del EPK"
        loading="eager"
        fetchpriority="high"
      />
      <div class="epk-hero-text">
        <p class="epk-eyebrow">Electronic Press Kit</p>
        <h1 class="epk-name">MAYA FOURTEEN</h1>
        <p class="epk-tagline">DJ y Productora Internacional</p>
        <p class="epk-subtagline">Artista Electrónica Premiada</p>
      </div>
    </section>

    <!-- PERFIL ARTÍSTICO -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkOverview.src}
        srcset={images.epkOverview.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkOverview.width}
        height={images.epkOverview.height}
        alt="Maya Fourteen detrás de los platos"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Perfil Artístico</h2>
        <p>
          Maya Fourteen es una artista brasileña de música electrónica conocida por
          un enfoque refinado y narrativo del sonido. Fusiona elementos orgánicos,
          progresivos y de carácter tech con un fuerte instinto melódico, lo que le
          permite adaptarse con fluidez a distintos estados de ánimo y entornos.
        </p>
      </div>
    </section>

    <!-- TRAYECTORIA INTERNACIONAL -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkGlobalPerformances.src}
        srcset={images.epkGlobalPerformances.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkGlobalPerformances.width}
        height={images.epkGlobalPerformances.height}
        alt="Maya Fourteen actuando en Terra Solis Dubai"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Trayectoria Internacional</h2>
        <p>
          Con actuaciones en tres continentes, MAYA ha construido una trayectoria que
          atraviesa clubes, festivales y eventos exclusivos en Europa, Asia, Oriente
          Medio y América del Sur. Su lectura de pista y su adaptación a cada contexto
          la convierten en una artista versátil, siempre fiel a su propia identidad
          sonora.
        </p>
      </div>
    </section>

    <!-- ESCENARIOS INTERNACIONALES -->
    <section class="epk-section">
      <h2>Escenarios Internacionales</h2>
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkWorldStages.src}
          srcset={images.epkWorldStages.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkWorldStages.width}
          height={images.epkWorldStages.height}
          alt="Maya Fourteen actuando en Greenvalley, Brasil"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <div class="epk-stage-card epk-stage-green">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/greenvalleybr/" target="_blank" rel="noopener">Greenvalley Brasil</a> 🇧🇷</h3>
            <p>5× #1 Club del mundo, en su 17º aniversario, con <a class="epk-inline-link" href="https://www.instagram.com/michael_bibi_/" target="_blank" rel="noopener">Michael Bibi</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a></p>
          </div>
          <div class="epk-stage-card epk-stage-blue">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/worldclubdome/" target="_blank" rel="noopener">World Club Dome</a> 🇩🇪</h3>
            <p>El mayor club festival de Alemania, con <a class="epk-inline-link" href="https://www.instagram.com/jamiejonesmusic/" target="_blank" rel="noopener">Jamie Jones</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/hotsince82/" target="_blank" rel="noopener">Hot Since 82</a></p>
          </div>
          <div class="epk-stage-card epk-stage-gold">
            <h3><a class="epk-inline-link" href="https://www.instagram.com/terrasolisdubai/" target="_blank" rel="noopener">Terra Solis Dubai</a> 🇦🇪</h3>
            <p>Oasis de Tomorrowland en el desierto de Dubái, con <a class="epk-inline-link" href="https://www.instagram.com/anahitvardanyanofficial/" target="_blank" rel="noopener">ANNA</a> &amp; <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a></p>
          </div>
          <div class="epk-stage-card epk-stage-orange">
            <h3><a class="epk-inline-link" href="https://soundcloud.com/mayafourteen/maya-f1-after-race-recap" target="_blank" rel="noopener">Formula 1</a> 🏁</h3>
            <p>After-parties privadas en los GPs de Abu Dhabi &amp; Mónaco</p>
          </div>
          <div class="epk-stage-card epk-stage-tour">
            <h3>Tour Internacional 🪩</h3>
            <p>Presente en más de 15 países, con especial protagonismo en Londres, Ámsterdam, Lisboa, Frankfurt, Ibiza, Cannes, Mónaco, Budapest, Dubái, Tokio, Bangkok, Kuala Lumpur y Bali, entre otros.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ARTISTA PREMIADA -->
    <section class="epk-section epk-media">
      <img
        class="epk-media-image"
        src={images.epkAward.src}
        srcset={images.epkAward.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkAward.width}
        height={images.epkAward.height}
        alt="Maya Fourteen recibiendo su premio en el IMS Ibiza 2025"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Artista Premiada</h2>
        <p>
          MAYA es ganadora de un prestigioso <strong>Future Talent Award</strong> en el <a class="epk-inline-link" href="https://www.internationalmusicsummit.com/" target="_blank" rel="noopener">IMS</a> Ibiza 2025,
          seleccionada por <a class="epk-inline-link" href="https://www.instagram.com/petetongofficial/" target="_blank" rel="noopener">Pete Tong</a>, y recibió el <strong><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a> Talent
          Highlight Prize</strong>, una distinción personal de una de las voces más respetadas de la industria.
        </p>
        <p>
          En el <strong>MixMasters Ibiza Summit 2023</strong>, fue seleccionada entre miles de artistas de
          todo el mundo, en un proceso con la curaduría de sellos como <a class="epk-inline-link" href="https://www.instagram.com/defectedrecords/" target="_blank" rel="noopener">Defected</a>, <a class="epk-inline-link" href="https://www.instagram.com/solidgroovesuk/" target="_blank" rel="noopener">Solid Grooves</a> y <a class="epk-inline-link" href="https://www.instagram.com/systematicrecordings/" target="_blank" rel="noopener">Systematic</a>.
        </p>
      </div>
    </section>

    <!-- VOCES DE LA INDUSTRIA -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkIndustryVoices.src}
        srcset={images.epkIndustryVoices.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkIndustryVoices.width}
        height={images.epkIndustryVoices.height}
        alt="Maya Fourteen entrevistada por Laureline Teste, de Clubbing TV, en una terraza"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Voces de la Industria</h2>
        <blockquote class="epk-quote">
          <p>&ldquo;Es el próximo gran nombre. Hay que seguirla de cerca.&rdquo;</p>
          <cite>Laureline Teste, <a class="epk-inline-link" href="https://www.instagram.com/clubbingtv/" target="_blank" rel="noopener">Clubbing TV</a>, ADE</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;¡Me encantaría tocar contigo algún día!&rdquo;</p>
          <cite><a class="epk-inline-link" href="https://www.instagram.com/nicolemoudaber/" target="_blank" rel="noopener">Nicole Moudaber</a>, IMS Ibiza</cite>
        </blockquote>
        <blockquote class="epk-quote">
          <p>&ldquo;A partir de ahora, esta es tu casa. Las puertas de Ibiza Sonica siempre estarán abiertas para ti.&rdquo;</p>
          <cite>Karlos Sense, <a class="epk-inline-link" href="https://www.instagram.com/ibizasonica/" target="_blank" rel="noopener">Ibiza Sonica</a></cite>
        </blockquote>
      </div>
    </section>

    <!-- PRESENCIA EN MEDIOS -->
    <section class="epk-section epk-media epk-media-spotlight">
      <img
        class="epk-media-image"
        src={images.epkMediaSpotlight.src}
        srcset={images.epkMediaSpotlight.srcset}
        sizes="(max-width: 768px) 92vw, 480px"
        width={images.epkMediaSpotlight.width}
        height={images.epkMediaSpotlight.height}
        alt="Maya Fourteen en la portada de Sync Beat Magazine"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Presencia en Medios</h2>
        <p>
          MAYA fue portada de la revista española <a class="epk-inline-link" href="https://www.instagram.com/syncbeatmagazine/" target="_blank" rel="noopener">Sync Beat Magazine</a> en una
          edición especial dedicada a la nueva generación de artistas de la
          música electrónica. En la entrevista, comparte su recorrido artístico,
          influencias y visión creativa, reflejando su creciente presencia
          internacional dentro del circuito de la música electrónica.
        </p>
        <ul class="epk-press-list">
          {mediaSpotlightItems.map((item) => (
            <li>
              <strong>{item.outlet}</strong>
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- RECONOCIMIENTO EDITORIAL -->
    <section class="epk-section epk-media epk-media-reverse">
      <img
        class="epk-media-image"
        src={images.epkEditorial.src}
        srcset={images.epkEditorial.srcset}
        sizes="(max-width: 768px) 92vw, 340px"
        width={images.epkEditorial.width}
        height={images.epkEditorial.height}
        alt="Reportaje de Gray Area: Brazilian DJs You Must Know For 2026"
        loading="lazy"
      />
      <div class="epk-media-text">
        <h2>Reconocimiento Editorial</h2>
        <p>
          MAYA fue destacada por la plataforma estadounidense <a class="epk-inline-link" href="https://www.instagram.com/p/DTggbNBDb4H/" target="_blank" rel="noopener">Gray Area</a> como una
          de las artistas brasileñas a seguir en 2026, junto a <a class="epk-inline-link" href="https://www.instagram.com/mazmusic/" target="_blank" rel="noopener">Maz</a>, <a class="epk-inline-link" href="https://www.instagram.com/beltran/" target="_blank" rel="noopener">Beltran</a>,
          <a class="epk-inline-link" href="https://www.instagram.com/brunoantdot/" target="_blank" rel="noopener">Antdot</a> y <a class="epk-inline-link" href="https://www.instagram.com/djalinerocha/" target="_blank" rel="noopener">Aline Rocha</a>. La selección refleja la creciente atención
          internacional en torno a su trabajo y su posicionamiento dentro del
          panorama global actual de la música electrónica.
        </p>
      </div>
    </section>

    <!-- DISCOGRAFÍA -->
    <section class="epk-section">
      <div class="epk-stages-layout epk-worldstages">
        <img
          class="epk-stages-image"
          src={images.epkDiscography.src}
          srcset={images.epkDiscography.srcset}
          sizes="(max-width: 768px) 92vw, 340px"
          width={images.epkDiscography.width}
          height={images.epkDiscography.height}
          alt="Maya Fourteen en el estudio"
          loading="lazy"
        />
        <div class="epk-stage-cards">
          <h2 class="epk-discography-title">Discografía</h2>
          <div class="epk-discography-layout">
            <div class="epk-label-card">
              <h3><a class="epk-inline-link" href="https://www.systematic-recordings.com/" target="_blank" rel="noopener">Systematic Recordings</a> 🇩🇪</h3>
              <p class="epk-label-sub">Sello icónico de <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a></p>
              <p>
                El sencillo debut de MAYA, <a class="epk-inline-link" href="https://www.beatport.com/track/uniqueness-feat-francesca/19198825" target="_blank" rel="noopener">'Uniqueness'</a>, con voces de Francesca Posgai, fue elegido personalmente por <a class="epk-inline-link" href="https://www.instagram.com/marcromboy/" target="_blank" rel="noopener">Marc Romboy</a> para el álbum del 20.º aniversario de Systematic Recordings, publicado junto con temas de <a class="epk-inline-link" href="https://www.instagram.com/carlcoxofficial/" target="_blank" rel="noopener">Carl Cox</a>, <a class="epk-inline-link" href="https://www.instagram.com/joshwink1/" target="_blank" rel="noopener">Josh Wink</a>, <a class="epk-inline-link" href="https://www.instagram.com/rodriguezjrmusic/" target="_blank" rel="noopener">Rodriguez Jr.</a> y <a class="epk-inline-link" href="https://www.instagram.com/guiboratto/" target="_blank" rel="noopener">Gui Boratto</a>.
              </p>
              <p>
                Romboy escuchó el tema por primera vez en el Ibiza Summit y lo describió como un rescate a la era dorada de la dance music, con una atemporalidad que evoca a Mood II Swing.
              </p>
              <p class="epk-label-tag">TOP 10 Beatport, máximo #8</p>
            </div>
            <div class="epk-discography-side">
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://vivamusicltd.com/" target="_blank" rel="noopener">VIVa MUSiC</a> 🇬🇧</h3>
                <p class="epk-label-sub">Sello prestigioso de <a class="epk-inline-link" href="https://www.instagram.com/djstevelawler/" target="_blank" rel="noopener">Steve Lawler</a></p>
                <p>
                  'Feel Better' EP, colaboración junto a <a class="epk-inline-link" href="https://www.instagram.com/mario_f_franca/" target="_blank" rel="noopener">Mario Franca</a> (<a class="epk-inline-link" href="https://bedrock.org.uk/" target="_blank" rel="noopener">Bedrock</a> |
                  <a class="epk-inline-link" href="https://seladorrecordings.com/" target="_blank" rel="noopener">Selador</a>), que muestra la versatilidad de MAYA, transitando desde un
                  Deep House hacia un Deep Tech más profundo y contundente.
                </p>
              </div>
              <div class="epk-label-card">
                <h3><a class="epk-inline-link" href="https://www.instagram.com/dioscurirecords/" target="_blank" rel="noopener">Dioscuri Records</a> 🇮🇹</h3>
                <p class="epk-label-sub">Sello de <a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>, de Italia a Londres</p>
                <p>
                  Debut de MAYA como remixer: su remix oficial para el tema 'Stay', de <a class="epk-inline-link" href="https://www.instagram.com/costaxmusic/" target="_blank" rel="noopener">Costax</a>, publicado junto a otros remixes, incluido uno del legendario <a class="epk-inline-link" href="https://www.instagram.com/timo.maas/" target="_blank" rel="noopener">Timo Maas</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AUDIENCIA Y ALCANCE GLOBAL -->
    <section class="epk-section">
      <h2>Audiencia y Alcance Global</h2>
      <p>
        El contenido combinado de MAYA en <a class="epk-inline-link" href="https://www.youtube.com/@MayaFourteen" target="_blank" rel="noopener">YouTube</a> y <a class="epk-inline-link" href="https://soundcloud.com/mayafourteen" target="_blank" rel="noopener">SoundCloud</a> supera las 350.000
        reproducciones, alcanzando oyentes en más de 100 países gracias a un
        crecimiento orgánico y sostenido. Sus sets destacan por su precisión
        técnica, fluidez armónica, gusto refinado y una identidad narrativa
        clara, reflejando una demanda internacional constante.
      </p>
      <div class="epk-audience-grid">
        <img src={images.epkAudienceMap.src} width={images.epkAudienceMap.width} height={images.epkAudienceMap.height} alt="Mapa del alcance global de audiencia de Maya Fourteen" loading="lazy" />
        <a href="https://soundcloud.com/mayafourteen/maya-ocho-siriusxm" target="_blank" rel="noopener"><img src={images.epkAudienceRadio.src} width={images.epkAudienceRadio.width} height={images.epkAudienceRadio.height} alt="Maya Fourteen destacada en Gray Area / Diplo's Revolution / SiriusXM" loading="lazy" /></a>
        <a href="https://www.youtube.com/watch?v=mWqUmkWs3wY" target="_blank" rel="noopener"><img src={images.epkAudienceGreenvalley.src} width={images.epkAudienceGreenvalley.width} height={images.epkAudienceGreenvalley.height} alt="Maya Fourteen actuando en Greenvalley" loading="lazy" /></a>
      </div>
      <p class="epk-audience-caption">
        Cada set es un viaje. Elige el tuyo.
      </p>
    </section>

    <!-- PRESS PHOTOS -->
    <section class="epk-section">
      <h2>Press Photos</h2>
      <p>Imágenes en alta resolución disponibles para uso promocional. Todas las fotografías están protegidas por derechos de autor.</p>
      <div class="epk-photo-grid">
        <a href="/images/epk/press/press-kit-1.jpg" download><img src={images.epkPressKit1.src} width={images.epkPressKit1.width} height={images.epkPressKit1.height} alt="Maya Fourteen, retrato editorial sentada en una escalera" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-2.jpg" download><img src={images.epkPressKit2.src} width={images.epkPressKit2.width} height={images.epkPressKit2.height} alt="Maya Fourteen, retrato de estudio" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-3.jpg" download><img src={images.epkPressKit3.src} width={images.epkPressKit3.width} height={images.epkPressKit3.height} alt="Maya Fourteen, retrato de moda en una puerta" loading="lazy" /></a>
        <a href="/images/epk/press/press-kit-4.jpg" download><img src={images.epkPressKit4.src} width={images.epkPressKit4.width} height={images.epkPressKit4.height} alt="Maya Fourteen, retrato al atardecer en el desierto" loading="lazy" /></a>
